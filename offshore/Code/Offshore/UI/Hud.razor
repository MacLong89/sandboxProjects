@using Sandbox
@using Sandbox.UI
@using Offshore
@inherits PanelComponent
@namespace Offshore.UI

<root>
	@if ( Game is not null )
	{
		<div class="safe-hud">
			<label class="title">Offshore</label>
			<label class="status">@Status</label>
			<label class="hint">WASD move · Space cast · E menu</label>
		</div>
	}
</root>

@code
{
	private OffshoreGameController Game => OffshoreGameController.Instance;
	private string Status => Game?.StatusMessage ?? "Loading...";

	protected override int BuildHash() => System.HashCode.Combine( Status );
}

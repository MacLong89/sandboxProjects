	void ExecuteAdvanceTarget( TimeAdvanceTarget target )
	{
		if ( !CanManage() )
			return;

		CloseAdvanceMenu();

		if ( target == TimeAdvanceTarget.OneWeek )
			CaptureWeekSummaryBeforeAdvance();

		var result = DynastyApp.League.AdvanceToTarget( target );
		ApplyTimeResult( result, AdvanceTargetSuccessMessage( target, result.Success ) );

		if ( target == TimeAdvanceTarget.OneWeek && result.Success )
			ShowWeekSummaryIfCaptured();
	}

	static string AdvanceTargetSuccessMessage( TimeAdvanceTarget target, bool success )
	{
		if ( !success )
			return "";

		return target switch
		{
			TimeAdvanceTarget.OneWeek => "Week advanced.",
			TimeAdvanceTarget.MidSeason => "Advanced to mid-season.",
			TimeAdvanceTarget.EndRegularSeason => "Advanced to the end of the regular season.",
			TimeAdvanceTarget.SuperBowl => "Advanced through the Super Bowl.",
			TimeAdvanceTarget.NextDraft => "Advanced to the draft.",
			_ => "Time advanced."
		};
	}




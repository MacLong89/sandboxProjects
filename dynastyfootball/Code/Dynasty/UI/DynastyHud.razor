	string NavClass( string tab )
	{
		var active = _tab == tab ? " nav-active" : "";
		var dim = IsNavDimmed( tab ) ? " nav-dimmed" : "";
		return $"nav-btn{active}{dim}";
	}

	bool IsNavDimmed( string tab )
	{
		var state = DynastyApp.League.State;
		if ( state == null )
			return false;

		if ( !FtueHelper.IsTabUnlocked( state, _provider.SelectedTeamId, tab ) )
			return true;

		if ( tab == "draft" && state.Phase != LeaguePhase.Draft )
			return true;

		if ( tab == "freeagency" && ( state.Phase != LeaguePhase.FreeAgency || !state.FreeAgency.IsOpen ) )
			return true;

		return false;
	}

	void RefreshFormationSelection()
	{
		if ( string.IsNullOrEmpty( _formationSelectedSlotKey ) )
		{
			_formationSelectedPlayerId = PlayerId.Empty;
			_formationPlayerDetail = null;
			RefreshPlayerProfile();
			return;
		}

		var slot = _formationRoster.Slots.FirstOrDefault( s => s.SlotKey == _formationSelectedSlotKey );
		if ( slot == null || slot.IsEmpty )
		{
			_formationSelectedPlayerId = PlayerId.Empty;
			_formationPlayerDetail = null;
			RefreshPlayerProfile();
			return;
		}

		_formationSelectedPlayerId = slot.PlayerId;
		_formationPlayerDetail = _provider.GetPlayerDetail( slot.PlayerId );
		RefreshPlayerProfile();
	}

	void SelectFormationSlot( string slotKey )
	{
		_formationSelectedSlotKey = slotKey ?? "";
		if ( IsSpecialTeamsSlot( _formationSelectedSlotKey ) )
			_teamSubTab = "specialteams";
		else if ( _teamSubTab == "lineup" )
			_teamSubTab = "formation";

		_lastRevision = 0;
		Refresh();
		RefreshFormationSelection();

		var slot = _formationRoster.Slots.FirstOrDefault( s => s.SlotKey == _formationSelectedSlotKey );
		if ( slot?.IsEmpty == true && CanManage() )
			OpenFormationPicker();
		else
			StateHasChanged();
	}


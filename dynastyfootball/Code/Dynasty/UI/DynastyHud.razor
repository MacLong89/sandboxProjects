		if ( todo == null )
			return;

		HandleTodo( todo );
	}

	void HandleTodo( ActionTodoItem todo )
	{
		switch ( todo.Action )
		{
			case TodoActionType.Navigate:
				NavigateFromTodo( todo );
				break;
			case TodoActionType.AdvanceDay:
				AdvanceDay();
				break;
			case TodoActionType.AdvanceWeek:
				AdvanceWeek();
				break;
			case TodoActionType.AdvanceNextEvent:
				if ( !string.IsNullOrEmpty( todo.NavigateTab ) )
					SetTab( todo.NavigateTab );
				else
					AdvanceNextEvent();
				break;
		}
	}


	void NavigateFromTodo( ActionTodoItem todo )
	{
		if ( todo.InboxMessageId.HasValue )
		{
			var detail = InboxDetailViewModel.From( DynastyApp.League.State, todo.InboxMessageId.Value );
			if ( detail != null && !string.IsNullOrEmpty( detail.SuggestedTab ) )
			{
				SetTab( detail.SuggestedTab );
				if ( !detail.PlayerId.IsEmpty && detail.SuggestedTab == "team" )
					NavigateToRosterPlayer( detail.PlayerId );
				MarkInboxRead( todo.InboxMessageId.Value );
				return;
			}
		}

		if ( !todo.PlayerId.IsEmpty && todo.NavigateTab == "team" )
		{
			NavigateToRosterPlayer( todo.PlayerId );
			return;
		}

		if ( !string.IsNullOrEmpty( todo.NavigateTab ) )
			SetTab( todo.NavigateTab );
	}


	void ChangeScheduleWeek( int delta )
	{
		var state = DynastyApp.League.State;
		if ( state == null )
			return;

		var focusWeek = ScheduleWeekHelper.GetFocusWeek( state );
		var (minWeek, maxWeek) = ScheduleWeekHelper.GetSeasonWeekRange( state );
		var currentView = focusWeek + _scheduleWeekOffset;
		var nextView = Math.Clamp( currentView + delta, minWeek, maxWeek );
		_scheduleWeekOffset = nextView - focusWeek;
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	void ResetScheduleWeek()
	{
		_scheduleWeekOffset = 0;
		_lastRevision = 0;

		_pendingWeekSummary = false;
		var state = DynastyApp.League.State;
		var teamId = _provider.SelectedTeamId;
		if ( state == null || teamId.IsEmpty )
			return;

		var weekAdvanced = state.CurrentWeek != _summaryClosedWeek
			|| state.CurrentSeason != _summaryClosedSeason
			|| state.Phase != _summaryClosedPhase;

		if ( !weekAdvanced )
			return;

		var summary = WeekSummaryViewModel.Build(
			state,
			teamId,
			_summaryClosedSeason,
			_summaryClosedWeek,
			_summaryClosedPhase );

		DynastyUi.Request( UiRequest.Open( UiWindowType.WeekSummary, new WeekSummaryPayload
		{
			Title = summary.Title,
			Headline = summary.Headline,
			Lines = summary.Lines

	void SubmitFreeAgentOffer()
	{
		if ( !CanManage() || _selectedFaPlayerId.IsEmpty )
			return;

		if ( !int.TryParse( _faOfferYears, out var years ) || years < 1 || years > 7 )
		{
			SetStatus( "Enter valid years (1–7).", true );
			return;
		}

		if ( !int.TryParse( _faOfferSalary, out var salary ) || salary < 750_000 )
		{
			SetStatus( "Enter a valid annual salary.", true );
			return;
		}

		var offer = new ContractOffer
		{
			PlayerId = _selectedFaPlayerId,
			TeamId = _provider.SelectedTeamId,
			Years = years,
			AnnualSalary = salary,
			GuaranteedMoney = (int)( salary * years * 0.4f )
		};

		var result = DynastyApp.League.ExecuteCommand(
			new SubmitContractOfferCommand
			{
				Offer = offer,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Offer submitted — resolving now." : result.Error, !result.Success );
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}


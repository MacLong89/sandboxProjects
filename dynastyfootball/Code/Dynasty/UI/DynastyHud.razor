@using System

@using System.Collections.Generic

@using System.Linq

@using Sandbox

@using Sandbox.UI

@using GameNetworking = Sandbox.Networking

@using Dynasty

@using Dynasty.Core

@using Dynasty.Core.Commands
@using Dynasty.Core.Enums
@using Dynasty.Core.Identifiers
@using Dynasty.Data
@using Dynasty.Domain.Contracts
@using Dynasty.Audio
@using Dynasty.UI.Team
@using Dynasty.UI.ViewModels
@using Dynasty.UI.Components
@using Dynasty.UI.Management

@inherits Panel

@namespace Dynasty.UI

@attribute [StyleSheet( "/Dynasty/UI/DynastyHud.razor.scss" )]

<div class="dynasty-hud @RootClass()">

	<SpectatorBanner />

	<MultiGmTeamClaimPanel />

	<NotificationStack />

	@if ( _home.IsHumanFired )
	{
		<div class="fired-banner ui-region-alert">
			<Label>You've been fired. Start a new franchise from the main menu to continue your GM career.</Label>
			<Button class="btn secondary" Text="Main Menu" onclick=@ExitToMenu />
		</div>
	}

	<TooltipHost />

	<div class="top-bar ui-region-top-bar">

		<div class="brand-block">

			<Label class="brand-kicker">DYNASTY</Label>

			<Label class="brand-name">@_home.LeagueName</Label>

			<Label class="calendar-line muted">@_home.CalendarMonth · Season @_home.Season · Week @_home.Week · Day @_home.DayOfWeek</Label>

		</div>

		<Label class="@($"league-meta phase-badge {PhaseClass()}")">@_home.Phase</Label>

		<div class="hud-actions">

			@if ( !string.IsNullOrEmpty( _saveSlot ) )

			{

				<Label class="save-indicator">Save: @_saveSlot</Label>

			}

			@if ( _inbox.ActionRequiredCount > 0 )

			{

				<Label class="inbox-badge">@_inbox.ActionRequiredCount action(s)</Label>

			}

			<Button class="btn secondary" Text="Save" onclick=@SaveGame />

			<Button class="btn secondary" Text="Main Menu" onclick=@ExitToMenu />

			<Button class="btn primary" Text="Advance Week" onclick=@AdvanceWeek />

			<Button class="btn secondary subtle-time" Text="More…" onclick=@OpenAdvanceMenu />

		</div>

	</div>



	<div class="next-action-bar clickable" @onclick=@OnNextActionClick>

		<Label class="next-label">Next:</Label>

		<Label class="next-text">@_home.NextSuggestedAction</Label>

		<Label class="next-hint muted">Click to go →</Label>

	</div>



	<div class="hud-nav">

		<Button class="@NavClass( "home" )" Text="League Home" onclick='@(() => SetTab( "home" ))' />

		<Button class="@NavClass( "inbox" )" Text="@InboxTabLabel()" onclick='@(() => SetTab( "inbox" ))' />

		<Button class="@NavClass( "team" )" Text="Team" onclick='@(() => SetTab( "team" ))' />

		<Button class="@NavClass( "facilities" )" Text="Facilities" onclick='@(() => SetTab( "facilities" ))' />

		<Button class="@NavClass( "trades" )" Text="Trade Center" onclick='@(() => SetTab( "trades" ))' />

		<Button class="@NavClass( "schedule" )" Text="Schedule" onclick='@(() => SetTab( "schedule" ))' />

		<Button class="@NavClass( "freeagency" )" Text="@FreeAgencyTabLabel()" onclick='@(() => SetTab( "freeagency" ))' />

		<Button class="@NavClass( "draft" )" Text="Draft" onclick='@(() => SetTab( "draft" ))' />

		<Button class="@NavClass( "news" )" Text="News" onclick='@(() => SetTab( "news" ))' />

		<Button class="@NavClass( "legacy" )" Text="Legacy" onclick='@(() => SetTab( "legacy" ))' />

	</div>



	@if ( !string.IsNullOrEmpty( _statusMessage ) )

	{

		<div class="status-bar @_statusClass hud-feedback">@_statusMessage</div>

	}



	<div class="hud-main-row @HudMainClass() ui-region-main">

	<div class="hud-content">

		@if ( _tab == "home" )

		{

			<div class="home-dashboard">

				@if ( _home.Franchise.HasTeam )

				{

					<div class="franchise-hero">

						<div class="franchise-identity">

							<Label class="franchise-abbr">@_home.Franchise.Abbreviation</Label>

							<div class="franchise-text">

								<Label class="franchise-name">@_home.Franchise.DisplayName</Label>

								<div class="franchise-meta">

									<div class="franchise-meta-item">

										<Label class="franchise-meta-val">@_home.Franchise.Record</Label>

										<Label class="franchise-meta-label">Record</Label>

									</div>

									<Label class="franchise-meta-sep">|</Label>

									<div class="franchise-meta-item">

										<Label class="franchise-meta-val">#@_home.Franchise.StandingRank</Label>

										<Label class="franchise-meta-label">Standing</Label>

									</div>

								</div>

							</div>

						</div>

						@if ( _home.Stakes.ShowFtueHint )
						{
							<div class="stakes-banner ftue-banner">
								<Label class="stakes-title">Getting Started</Label>
								<Label class="muted">Follow the To-Do list. Use Sim Rest of Draft if you want to reach football faster.</Label>
							</div>
						}

						<div class="stakes-banner">
							<Label class="stakes-title">Franchise Stakes</Label>
							<div class="stakes-row">
								<Label class="stakes-chip">Dynasty @_home.Stakes.DynastyScore</Label>
								<Label class="stakes-chip">Job Security @_home.Stakes.OwnerJobSecurity%</Label>
								<Label class="stakes-chip">@_home.Stakes.OwnerMandate</Label>
							</div>
							@if ( !string.IsNullOrEmpty( _home.Stakes.SeasonObjective ) )
							{
								<Label class="muted">@_home.Stakes.SeasonObjective</Label>
							}
							@if ( !string.IsNullOrEmpty( _home.Stakes.RivalLabel ) )
							{
								<Label class="stakes-rival">@_home.Stakes.RivalLabel</Label>
							}
						</div>

						<div class="franchise-stats">

							<div class="hero-stat" tooltip="Starters assigned on your lineup — affects simulation strength">

								<Label class="hero-stat-val">@FranchiseLineupLabel()</Label>

								<Label class="hero-stat-label">Lineup</Label>

							</div>

							<div class="hero-stat" tooltip="Average overall of offensive starters on your roster">

								<Label class="hero-stat-val ovr">@_home.Franchise.OffenseOverall</Label>

								<Label class="hero-stat-label">Off OVR</Label>

							</div>

							<div class="hero-stat" tooltip="Average overall of defensive starters on your roster">

								<Label class="hero-stat-val ovr">@_home.Franchise.DefenseOverall</Label>

								<Label class="hero-stat-label">Def OVR</Label>

							</div>

							<div class="hero-stat" tooltip="Weighted team strength used in game simulation">

								<Label class="hero-stat-val ovr team-ovr">@_home.Franchise.TeamOverall</Label>

								<Label class="hero-stat-label">Team OVR</Label>

							</div>

							<div class="hero-stat" tooltip="Franchise reputation — grows with wins and championships">

								<Label class="hero-stat-val">@_home.Franchise.Prestige</Label>

								<Label class="hero-stat-label">Prestige</Label>

							</div>

							<div class="hero-stat" tooltip="Locker room mood — low morale hurts development">

								<Label class="hero-stat-val">@_home.Franchise.Morale</Label>

								<Label class="hero-stat-label">Morale</Label>

							</div>

							<div class="hero-stat">

								<Label class="hero-stat-val">$@(_home.Franchise.CapSpace / 1_000_000)M</Label>

								<Label class="hero-stat-label">Cap Space</Label>

							</div>

							<div class="hero-stat">

								<Label class="hero-stat-val">@_home.Franchise.RosterCount</Label>

								<Label class="hero-stat-label">Roster</Label>

							</div>

							<div class="hero-stat">

								<Label class="hero-stat-val">@_home.Franchise.BuildingWindow</Label>

								<Label class="hero-stat-label">Window</Label>

							</div>

						</div>

						@if ( _home.InboxActionCount > 0 )

						{

							<Button class="btn secondary small" Text="@($"Inbox ({_home.InboxActionCount})")" onclick='@(() => SetTab( "inbox" ))' />

						}

					</div>

				}

				@if ( _home.NextGame.HasGame )

				{

					<div class="next-game-card clickable @(_home.NextGame.IsUserGamePending ? "pulse-cta" : "")" @onclick=@OpenNextGame>

						<div class="next-game-body">

							<Label class="next-game-kicker">@( _home.NextGame.IsComplete ? "Last Game" : "Up Next" ) · Week @_home.NextGame.Week</Label>

							<Label class="next-game-matchup">@_home.NextGame.MatchupLabel</Label>

							<Label class="muted">@_home.NextGame.Opponent @( _home.NextGame.IsHome ? "(Home)" : "(Away)" )</Label>

							@if ( !string.IsNullOrEmpty( _home.NextGame.PlayoffLabel ) )

							{

								<Label class="tag playoff-tag">@_home.NextGame.PlayoffLabel</Label>

							}

						</div>

						@if ( _home.NextGame.IsUserGamePending )

						{

							<div class="next-game-actions">

								<Button class="btn primary small game-cta" Text="Simulate Game" onclick=@OpenNextGame />

							</div>

						}

					</div>

				}

				<div class="home-grid">

					<div class="panel standings">

						<Label class="panel-title">Standings</Label>

						<Label class="muted standings-hint">Click a team for profile</Label>

						<div class="standings-header">

							<Label class="rank-col muted">#</Label>

							<Label class="abbr-col muted">Team</Label>

							<Label class="record-col muted">W-L</Label>

						</div>

						<div class="standings-scroll">

							@foreach ( var row in _home.Standings )

							{

								<StandingsRow
									Rank="@row.Rank"
									Abbreviation="@row.Abbreviation"
									Record="@FormatRecord( row )"
									IsUserTeam="@row.IsUserTeam" />

							}

						</div>

					</div>

					<div class="panel news">

						<Label class="panel-title">League News</Label>

						@if ( _home.RecentNews.Count == 0 )

						{

							<Label class="muted">Advance time to generate league stories.</Label>

						}

						else

						{

							@foreach ( var item in _home.RecentNews )

							{

								<div class="news-row clickable" @onclick='@(() => OpenNewsArticle( item.Id ))'>

									<Label class="tag">@item.Category</Label>

									<Label class="headline">@item.Headline</Label>

									<Label class="muted">@item.WeekLabel</Label>

								</div>

							}

						}

					</div>

				</div>

			</div>

		}

		else if ( _tab == "inbox" )

		{

			<div class="split-layout">

				<div class="panel inbox-panel">

					<Label class="panel-title">Franchise Inbox</Label>

					@if ( _inbox.Messages.Count == 0 )

					{

						<Label class="muted">No pending messages. Advance the week for new opportunities and problems.</Label>

					}

					else

					{

						@foreach ( var msg in _inbox.Messages )

						{

							<div class="@InboxRowClass( msg )" @onclick='@(() => SelectInboxMessage( msg.Id ))'>

								<div class="inbox-header">

									<Label class="tag">@msg.Category</Label>

									<Label class="inbox-subject">@msg.Subject</Label>

									@if ( !msg.IsRead )

									{

										<Label class="unread-dot">●</Label>

									}

								</div>

								<Label class="inbox-preview muted">@msg.Preview</Label>

							</div>

						}

					}

				</div>

				@if ( _inboxDetail != null )

				{

					<div class="panel detail-panel">

						<Label class="panel-title">@_inboxDetail.Subject</Label>

						<Label class="muted">@_inboxDetail.Category · @_inboxDetail.Priority · @_inboxDetail.WeekLabel</Label>

						<Label class="detail-body">@_inboxDetail.Body</Label>

						<Label class="muted">@_inboxDetail.ActionHint</Label>

						<div class="detail-actions">

							@if ( !string.IsNullOrEmpty( _inboxDetail.SuggestedTab ) )

							{

								<Button class="btn primary small" Text="Take Action" onclick=@InboxTakeAction />

							}

							@if ( _inboxDetail.RequiresAction )

							{

								<Label class="muted resolve-note">Complete the action above — Mark Resolved is disabled for required items.</Label>

							}

							else

							{

								<Button class="btn secondary small" Text="Mark Resolved" onclick='@(() => ResolveInbox( _inboxDetail.Id ))' />

							}

						</div>

					</div>

				}

				else

				{

					<div class="panel detail-panel empty-detail">

						<Label class="muted">Select a message to read and respond.</Label>

					</div>

				}

			</div>

		}

		else if ( _tab == "team" )

		{

			<div class="team-screen">

				<div class="team-subnav">

					<Button class="@TeamSubNavClass( "roster" )" Text="Roster" onclick='@(() => SetTeamSubTab( "roster" ))' />

					<Button class="@TeamSubNavClass( "formation" )" Text="Formation View" onclick='@(() => SetTeamSubTab( "formation" ))' />

					<Button class="@TeamSubNavClass( "specialteams" )" Text="Special Teams" onclick='@(() => SetTeamSubTab( "specialteams" ))' />

					<Button class="@TeamSubNavClass( "lineup" )" Text="Lineup" onclick='@(() => SetTeamSubTab( "lineup" ))' />

					<Button class="@TeamSubNavClass( "contracts" )" Text="Contracts" onclick='@(() => SetTeamSubTab( "contracts" ))' />

				</div>

				@if ( ShowGamePlanBar )
				{
					<div class="panel game-plan-bar">
						<Label class="panel-subtitle">Weekly Game Plan</Label>
						<Label class="muted">Choose a focus before your game for a tactical bonus.</Label>
						<div class="game-plan-actions">
							<Button class="btn secondary small" Text="Balanced" onclick='@(() => SetGamePlan( "balanced" ))' />
							<Button class="btn secondary small" Text="Run Heavy" onclick='@(() => SetGamePlan( "runHeavy" ))' />
							<Button class="btn secondary small" Text="Pass Heavy" onclick='@(() => SetGamePlan( "passHeavy" ))' />
							<Button class="btn secondary small" Text="Defensive Focus" onclick='@(() => SetGamePlan( "defensiveFocus" ))' />
						</div>
					</div>
				}

				@if ( _teamSubTab == "formation" || _teamSubTab == "specialteams" )

				{

					<FormationRosterView
						Model="@_formationRoster"
						SelectedSlotKey="@_formationSelectedSlotKey"
						SelectedSlotLabel="@FormationSelectedSlotLabel()"
						SelectedProfile="@_playerProfile"
						CanManage="@CanManage()"
						OnSlotSelected="@SelectFormationSlot"
						OnSideChanged="@SetFormationSide"
						OnFormationChanged="@SetFormationType"
						OnSetStarter="@OpenFormationPicker"
						OnExtend="@OpenExtendModal"
						OnTrade="@FormationTradePlayer"
						OnRelease="@FormationReleasePlayer"
						OnTrainAttribute="@TrainAttribute"
						OnUnlockTrait="@UnlockTrait" />

				}

				else if ( _teamSubTab == "lineup" )

				{

					<LineupPanel
						Model="@_rosterSlots"
						FormationName="@_formationRoster.FormationName"
						OnSlotSelected="@SelectFormationSlot"
						OnOpenFormation='@(() => SetTeamSubTab( "formation" ))'
						OnOpenSpecialTeams='@(() => SetTeamSubTab( "specialteams" ))' />

				}

				else if ( _teamSubTab == "contracts" )

				{

					<div class="team-layout">

						<div class="panel team-contracts-panel">

							<Label class="panel-title">@_teamContracts.TeamName · Contracts</Label>

							<div class="contracts-table">

								<div class="contracts-header">

									<Label class="col-name">Name</Label>

									<Label class="col-pos">Pos</Label>

									<Label class="col-ovr">OVR</Label>

									<Label class="col-years">Years</Label>

									<Label class="col-salary">Salary</Label>

									<Label class="col-guar">Guaranteed</Label>

								</div>

								@foreach ( var p in _teamContracts.Players )

								{

									<div class="contracts-row clickable @( _selectedRosterPlayerId.Value == p.PlayerId.Value ? "selected" : "" )" @onclick='@(() => SelectRosterPlayer( p.PlayerId ))'>

										<Label class="col-name">@p.Name</Label>

										<Label class="col-pos">@p.Position</Label>

										<Label class="col-ovr">@p.Overall</Label>

										<Label class="col-years">@p.YearsRemaining</Label>

										<Label class="col-salary">$@p.AnnualSalary.ToString( "N0" )</Label>

										<Label class="col-guar">$@p.GuaranteedMoney.ToString( "N0" )</Label>

									</div>

								}

							</div>

						</div>

						@if ( _playerProfile != null )

						{

							<div class="panel player-detail">

								<PlayerProfilePanel
									Model="@_playerProfile"
									CanManage="@CanManage()"
									OnClose="@ClosePlayerDetail"
									OnExtend="@OpenExtendModal"
									OnTrade="@OpenTradeModal"
									OnRelease="@OpenReleaseModal"
									OnTrainAttribute="@TrainAttribute"
									OnUnlockTrait="@UnlockTrait" />

							</div>

						}

					</div>

				}

				else

				{

			<div class="team-layout">

				<div class="panel team-main">

					<Label class="panel-title">@_team.DisplayName</Label>

					<div class="stat-grid">

						<Label>Window: @_team.BuildingWindow</Label>

						<Label>Style: @_team.PlayStyle</Label>

						<Label>Prestige: @_team.Prestige</Label>

						<Label>Morale: @_team.Morale</Label>

						<Label>Budget: $@_team.Budget.ToString( "N0" )</Label>

						<Label>Cap Space: $@_team.CapSpace.ToString( "N0" )</Label>

						<Label>Roster: @_team.RosterCount</Label>

					</div>

					<div class="roster-table">

						<div class="roster-header">

							<Label class="col-name">Name</Label>

							<Label class="col-age">Age</Label>

							<Label class="col-pos">Pos</Label>

							<Label class="col-ovr">OVR</Label>

							<Label class="col-health">Health</Label>

						</div>

						@foreach ( var p in _team.Roster )

						{

							<div class="roster-row @( _selectedRosterPlayerId.Value == p.Id.Value ? "selected" : "" )" @onclick='@(() => SelectRosterPlayer( p.Id ))'>

								<Label class="col-name">@p.Name</Label>

								<Label class="col-age">@p.Age</Label>

								<Label class="col-pos">@p.Position</Label>

								<Label class="col-ovr">@p.Overall</Label>

								<Label class="@($"col-health {HealthClass( p.Health )}")">@p.Health</Label>

							</div>

						}

					</div>

				</div>

				@if ( _playerProfile != null )

				{

					<div class="panel player-detail">

						<PlayerProfilePanel
							Model="@_playerProfile"
							CanManage="@CanManage()"
							OnClose="@ClosePlayerDetail"
							OnExtend="@OpenExtendModal"
							OnTrade="@OpenTradeModal"
							OnRelease="@OpenReleaseModal"
							OnTrainAttribute="@TrainAttribute"
							OnUnlockTrait="@UnlockTrait" />

					</div>

				}

			</div>

				}

			</div>

		}

		else if ( _tab == "schedule" )

		{

			<div class="panel">

				<div class="schedule-header">

					<Button class="btn secondary small" Text="◀" onclick='@(() => ChangeScheduleWeek( -1 ))' />

					<div class="schedule-title-block">
						<Label class="panel-title">Week @_schedule.Week · Season @_schedule.Season</Label>
						@if ( !string.IsNullOrEmpty( _schedule.PhaseLabel ) )
						{
							<Label class="muted schedule-phase-label">@_schedule.PhaseLabel</Label>
						}
					</div>

					<Button class="btn secondary small" Text="▶" onclick='@(() => ChangeScheduleWeek( 1 ))' />

					@if ( !_schedule.IsViewingCurrentWeek )

					{

						<Button class="btn secondary small" Text="Current Week" onclick=@ResetScheduleWeek />

					}

					<Button class="@ScheduleFilterClass()" Text="@(_scheduleUserOnly ? "All Games" : "My Games")" onclick=@ToggleScheduleFilter />

				</div>

				@if ( _schedule.Games.Count == 0 )

				{

					<Label class="muted">No games scheduled this week.</Label>

				}

				@foreach ( var g in _schedule.Games )

				{

					<ScheduleGameCard Model="@g" OnOpen="@OpenGame" />

				}

			</div>

		}

		else if ( _tab == "freeagency" )

		{

			<div class="split-layout fa-layout">

				<div class="panel">

					<Label class="panel-title">Free Agency</Label>

					@if ( !_freeAgency.IsOpen )

					{

						<Label class="muted">Free agency is closed. Check back during the offseason.</Label>

					}

					else

					{

						<div class="fa-summary">

							<Label>Cap Space: $@_freeAgency.CapSpace.ToString( "N0" )</Label>

							<Label class="muted">@_freeAgency.AvailableCount agents available · @_freeAgency.PendingOfferCount pending offers</Label>

						</div>

						@if ( _freeAgency.Agents.Count == 0 )

						{

							<Label class="muted">No free agents on the market right now.</Label>

						}

						@foreach ( var agent in _freeAgency.Agents )

						{

							<div class="player-row clickable @( _selectedFaPlayerId.Value == agent.Id.Value ? "selected" : "" )" @onclick='@(() => SelectFreeAgent( agent.Id, agent.AskingSalary ))'>

								<Label class="pos">@agent.Position</Label>

								<Label class="player-name">@agent.Name</Label>

								<Label class="ovr">@agent.Overall OVR</Label>

								<Label class="muted">Age @agent.Age</Label>

								<Label class="salary">$@(agent.AskingSalary / 1_000_000)M/yr</Label>

							</div>

						}

					}

				</div>

				<div class="panel detail-panel">

					@if ( _selectedFaPlayerId.IsEmpty )

					{

						<Label class="muted">Select a free agent to make an offer.</Label>

					}

					else if ( !_freeAgency.IsOpen )

					{

						<Label class="muted">Free agency is not open.</Label>

					}

					else

					{

						@if ( _playerProfile != null )

						{

							<PlayerProfilePanel
								Model="@_playerProfile"
								CanManage="@CanManage()"
								ShowClose=@(false)
								ShowContractActions=@(false)
								OnTrainAttribute="@TrainAttribute"
								OnUnlockTrait="@UnlockTrait" />

						}

						<Label class="panel-title">Contract Offer</Label>

						<Label class="field-label">Years (1–7)</Label>

						<TextEntry class="text-input" Value:bind=@_faOfferYears />

						<Label class="field-label">Annual Salary</Label>

						<TextEntry class="text-input" Value:bind=@_faOfferSalary />

						@if ( CanManage() )

						{

							<Button class="btn primary" Text="Submit Offer" onclick=@SubmitFreeAgentOffer />

						}

						@if ( _freeAgency.PendingOffers.Count > 0 )

						{

							<Label class="panel-subtitle">Your Pending Offers</Label>

							@foreach ( var offer in _freeAgency.PendingOffers )

							{

								<div class="profile-info-row">

									<Label>@offer.PlayerName</Label>

									<Label class="muted">@offer.Years yr · $@offer.AnnualSalary.ToString( "N0" )/yr · @offer.Status</Label>

								</div>

							}

						}

					}

				</div>

			</div>

		}

		else if ( _tab == "draft" )

		{

			<div class="draft-layout">

				<div class="panel draft-header-panel">

					<Label class="panel-title">@_draftBoard.DraftType Draft · Season @_draftBoard.Season</Label>

					@if ( !_draftBoard.IsActive )

					{

						<Label class="muted">Draft complete. Advance time to continue your dynasty.</Label>

					}

					else

					{

						<div class="draft-status-row">

							<div class="draft-status-main">

								<Label class="@($"draft-clock{(_draftBoard.IsUserOnClock ? " your-pick" : "")}")">

									Pick @_draftBoard.CurrentOverallPick / @_draftBoard.TotalPicks · Round @_draftBoard.CurrentRound

								</Label>

								<Label class="muted">On the clock: @_draftBoard.OnClockFullName (@_draftBoard.OnClockTeam)</Label>

								@if ( _draftBoard.IsUserOnClock )

								{

									<Label class="your-pick-label">YOU ARE ON THE CLOCK</Label>

								}

							</div>

							<div class="draft-timer @( DraftPickTimerUrgent() ? "urgent" : "" ) @( _draftBoard.IsUserOnClock ? "your-pick" : "" )">

								<Label class="timer-label">Pick Timer</Label>

								<Label class="timer-value">@DraftPickTimerLabel()</Label>

							</div>

						</div>

						<div class="draft-controls">

							<Button class="btn secondary small" Text="Sim 1 Pick" onclick=@SimOneDraftPick />

							<Button class="btn secondary small" Text="Sim to My Pick" onclick=@SimDraftToHuman />

							<Button class="btn secondary small" Text="Sim Smart" onclick=@SimSmartDraft />

							<Button class="btn primary small recommended-draft" Text="★ Sim Rest of Draft" onclick=@SimRestOfDraft />

							@if ( _draftBoard.IsUserOnClock && !_selectedProspectId.IsEmpty )

							{

								<Button class="btn primary small" Text="Draft Player" onclick=@ConfirmDraftPick />

							}

						</div>

					}

				</div>

				<div class="draft-columns">

					<div class="panel draft-board-panel">

						<Label class="panel-subtitle draft-section-title">Draft Board</Label>

						<div class="draft-board-table">

							<div class="board-header">

								<Label class="board-col-pick">#</Label>

								<Label class="board-col-team">Team</Label>

								<Label class="board-col-player">Player</Label>

							</div>

							@foreach ( var pick in _draftBoard.Board.Take( 80 ) )

							{

								<div class="board-row @( pick.IsOnClock ? "on-clock" : "" ) @( pick.IsUserTeam ? "user-team" : "" ) @( pick.IsComplete ? "complete" : "" )">

									<Label class="board-col-pick">@pick.OverallPick</Label>

									<Label class="board-col-team">@pick.TeamAbbr</Label>

									<Label class="board-col-player">@DraftBoardPlayerLabel( pick )</Label>

								</div>

							}

						</div>

					</div>

					<div class="panel draft-pool-panel">

						<Label class="panel-subtitle draft-section-title">Available Players</Label>

						<div class="prospect-table">

							<div class="prospect-header">

								<Label class="@($"draft-col-rank sortable-header {ProspectSortClass( "rank" )}")" @onclick='@(() => ToggleProspectSort( "rank" ))'>@ProspectSortHeader( "rank", "#" )</Label>

								<Label class="draft-col-name">Name</Label>

								<Label class="@($"draft-col-pos sortable-header {ProspectSortClass( "position" )}")" @onclick='@(() => ToggleProspectSort( "position" ))'>@ProspectSortHeader( "position", "Pos" )</Label>

								<Label class="@($"draft-col-age sortable-header {ProspectSortClass( "age" )}")" @onclick='@(() => ToggleProspectSort( "age" ))'>@ProspectSortHeader( "age", "Age" )</Label>

								<Label class="@($"draft-col-ovr sortable-header {ProspectSortClass( "overall" )}")" @onclick='@(() => ToggleProspectSort( "overall" ))'>@ProspectSortHeader( "overall", "OVR" )</Label>

								<Label class="draft-col-pot">POT</Label>

							</div>

							<div class="prospect-scroll">

								@foreach ( var p in GetSortedProspects() )

								{

									<div class="prospect-row clickable @( _selectedProspectId.Value == p.Id.Value ? "selected" : "" )" @onclick='@(() => SelectProspect( p.Id ))'>

										<Label class="draft-col-rank">@p.Rank</Label>

										<Label class="draft-col-name">@p.Name</Label>

										<Label class="draft-col-pos">@p.Position</Label>

										<Label class="draft-col-age">@p.Age</Label>

										<Label class="draft-col-ovr">@p.Overall</Label>

										<Label class="draft-col-pot">@p.Potential</Label>

									</div>

								}

							</div>

						</div>

						<div class="recent-picks-section">

							<Label class="panel-subtitle draft-section-title">Recent Picks</Label>

						@foreach ( var rp in _draftBoard.RecentPicks )

						{

							<div class="recent-pick-row">

								<Label class="tag">@rp.OverallPick</Label>

								<Label>@($"{rp.TeamAbbr}: {rp.PlayerName}")</Label>

								<Label class="muted">@rp.Detail</Label>

							</div>

						}

						</div>

					</div>

					@if ( _playerProfile != null && _tab == "draft" )

					{

						<div class="panel player-detail draft-prospect-detail">

							<PlayerProfilePanel
								Model="@_playerProfile"
								CanManage="@CanManage()"
								ShowClose=@(false)
								ShowContractActions=@(false)
								OnDraftPick="@DraftSelectedProspect"
								OnTrainAttribute="@TrainAttribute"
								OnUnlockTrait="@UnlockTrait" />

						</div>

					}

				</div>

			</div>

		}

		else if ( _tab == "facilities" )

		{

			<FacilitiesPanel Model="@_facilities" CanManage="@CanManage()" OnUpgrade="@UpgradeFacility" />

		}

		else if ( _tab == "trades" )

		{

			<div class="trade-screen">

				<TradeCenterPanel
					Model="@_tradeCenter"
					CanManage="@CanManage()"
					GetPartnerRoster="@GetTradePartnerRoster"
					OnPlayerView="@OpenTradePlayerProfile"
					OnSubmitTrade="@SubmitTradeFromCenter"
					OnRespondOffer="@RespondTradeOffer" />

				@if ( _playerProfile != null )

				{

					<div class="panel trade-player-profile">

						<PlayerProfilePanel
							Model="@_playerProfile"
							CanManage="@CanManage()"
							ShowClose=@(false)
							ShowContractActions="@_playerProfile.IsUserTeam"
							OnExtend="@OpenExtendModal"
							OnTrade="@OpenTradeModal"
							OnRelease="@OpenReleaseModal"
							OnTrainAttribute="@TrainAttribute"
							OnUnlockTrait="@UnlockTrait" />

					</div>

				}

			</div>

		}

		else if ( _tab == "legacy" )

		{

			<LegacyPanel Model="@_legacy" />

		}

		else if ( _tab == "news" )

		{

			<div class="split-layout">

				<div class="panel">

					<Label class="panel-title">League News</Label>

					@if ( _news.Articles.Count == 0 )

					{

						<Label class="muted">Advance time to generate league stories.</Label>

					}

					@foreach ( var n in _news.Articles )

					{

						<div class="news-row clickable @( _selectedNewsId == n.Id ? "selected" : "" )" @onclick='@(() => OpenNewsArticle( n.Id ))'>

							<Label class="tag">@n.Category</Label>

							<Label class="headline">@n.Headline</Label>

							<Label class="muted">@n.WeekLabel</Label>

						</div>

					}

				</div>

				@if ( _newsDetail != null )

				{

					<div class="panel detail-panel">

						<Label class="panel-title">@_newsDetail.Headline</Label>

						<Label class="muted">@_newsDetail.Category · @_newsDetail.WeekLabel · @_newsDetail.PublishedLabel</Label>

						<Label class="detail-body">@_newsDetail.Body</Label>

					</div>

				}

				else

				{

					<div class="panel detail-panel empty-detail">

						<Label class="muted">Select a story to read the full article.</Label>

					</div>

				}

			</div>

		}

	</div>

	<aside class="action-sidebar ui-region-sidebar">

		<div class="sidebar-header">

			<Label class="sidebar-title">To-Do</Label>

			@if ( _todos.UrgentCount > 0 )

			{

				<Label class="sidebar-urgent">@_todos.UrgentCount urgent</Label>

			}

		</div>

		@if ( _todos.Items.Count == 0 )

		{

			<Label class="muted sidebar-empty">You're all caught up. Advance time for new storylines.</Label>

		}

		else

		{

			@foreach ( var todo in _todos.Items )

			{

				<div class="todo-item @PriorityClass( todo )">

					<div class="todo-top">

						<Label class="todo-title">@todo.Title</Label>

						<Button class="todo-action" Text="@TodoActionLabel( todo )" onclick='@(() => HandleTodoById( todo.Id ))' />

					</div>

					@if ( !string.IsNullOrEmpty( todo.Detail ) )

					{

						<Label class="todo-detail">@todo.Detail</Label>

					}

				</div>

			}

		}

	</aside>

	</div>

	@if ( DynastyUi.IsOpen( UiWindowType.GameViewer ) )

	{

		<GameViewerModal
			Model="@GameViewerPayload()"
			LeagueState="@DynastyApp.League.State"
			VisualizationMode="@_visualizationMode"
			CanManage="@CanManage()"
			OnClose="@CloseGameViewer"
			OnSimulate="@RunSimulateSelectedGame" />

	}

	@if ( DynastyUi.IsOpen( UiWindowType.DraftCeremony ) )

	{

		<DraftCeremonyModal
			Model="@DraftCeremonyPayload()"
			OnDismiss="@CloseDraftCeremony" />

	}

	@if ( DynastyUi.IsOpen( UiWindowType.SessionSummary ) )
	{
		<SessionSummaryModal
			Model="@SessionSummaryPayload()"
			OnConfirm="@ConfirmExitToMenu" />
	}

	@if ( DynastyUi.IsOpen( UiWindowType.FourthDownDecision ) )
	{
		<FourthDownDecisionModal OnChoose="@OnFourthDownChoice" />
	}

	@if ( _showTeamProfile && _teamProfileModal != null )

		if ( !CanManage() || _selectedProspectId.IsEmpty ) return;

		var teamId = _provider.SelectedTeamId;
		var prospectId = _selectedProspectId;
		var current = DynastyApp.League.State.Draft.Order.ElementAtOrDefault( DynastyApp.League.State.Draft.CurrentPickIndex );
		var round = current?.Round ?? 0;
		var overall = current?.OverallPick ?? 0;

		var result = DynastyApp.League.ExecuteCommand(
			new MakeDraftPickCommand
			{
				PickingTeamId = teamId,
				ProspectId = prospectId,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Draft pick submitted." : result.Error, !result.Success );

		if ( result.Success )
		{
			if ( !FtueHelper.ShouldShowDraftCeremony( DynastyApp.League.State, teamId ) )
			{
				_selectedProspectId = default;
				_lastRevision = 0;
				Refresh();
				StateHasChanged();
				return;
			}

			FtueHelper.OnHumanDraftCeremonyShown( DynastyApp.League.State );
			var ceremony = DraftPickCeremonyViewModel.From( DynastyApp.League.State, teamId, prospectId, round, overall );
			DynastyUiManager.Instance.SetGameplayPhase( UiGameplayPhase.Celebration );
			DynastyUi.Request( UiRequest.Open( UiWindowType.DraftCeremony, ceremony ) );
		}

		_selectedProspectId = default;
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	void CloseDraftCeremony()
	{
		DynastyUi.Request( UiRequest.Close( UiWindowType.DraftCeremony ) );
		DynastyUiManager.Instance.SetGameplayPhase( UiGameplayPhase.FranchiseManagement );
		StateHasChanged();
	}

	void UpgradeFacility( FacilityType type )
	{
		if ( !CanManage() ) return;

		var result = DynastyApp.League.ExecuteCommand(
			new UpgradeFacilityCommand
			{
				TeamId = _provider.SelectedTeamId,
				FacilityType = type,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Facility upgraded." : result.Error, !result.Success );
		if ( result.Success )
			DynastyAudio.PlayEconomy();
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	void SubmitTradeFromCenter( PlayerId outgoingPlayerId, TeamId partnerId, PlayerId returnPlayerId )
	{
		if ( !CanManage() ) return;

		var result = DynastyApp.League.ExecuteCommand(
			new SubmitTradeCommand
			{
				FromTeamId = _provider.SelectedTeamId,
				PlayerId = outgoingPlayerId,
				ToTeamId = partnerId,
				ReturnPlayerId = returnPlayerId,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Trade completed." : result.Error, !result.Success );
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	void RespondTradeOffer( Guid offerId, bool accept )
	{
		if ( !CanManage() ) return;

		var result = DynastyApp.League.ExecuteCommand(
			new RespondTradeOfferCommand
			{
				OfferId = offerId,
				Accept = accept,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? (accept ? "Trade accepted." : "Trade declined.") : result.Error, !result.Success );
		if ( result.Success && accept )
			DynastyAudio.PlayEconomy();
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	bool ShowGamePlanBar =>
		DynastyApp.League?.State != null
		&& (DynastyApp.League.State.Phase == LeaguePhase.RegularSeason || DynastyApp.League.State.Phase == LeaguePhase.Playoffs);

	void SetGamePlan( string planKey )
	{
		if ( !CanManage() ) return;

		var plan = planKey switch
		{
			"runHeavy" => WeeklyGamePlan.RunHeavy,
			"passHeavy" => WeeklyGamePlan.PassHeavy,
			"defensiveFocus" => WeeklyGamePlan.DefensiveFocus,
			_ => WeeklyGamePlan.Balanced
		};

		var result = DynastyApp.League.ExecuteCommand(
			new SetWeeklyGamePlanCommand
			{
				TeamId = _provider.SelectedTeamId,
				Plan = plan,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? $"Game plan set: {plan}" : result.Error, !result.Success );
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	bool CanManage() => !GameNetworking.IsActive || GameNetworking.IsHost;



	void SaveGame()

	{

		if ( !CanManage() ) return;

		try

		{

			DynastyApp.Persistence.SaveActiveSlot();

			_saveSlot = DynastyApp.Persistence.ActiveSaveSlot ?? "";

			SetStatus( "Game saved." );

		}

		catch ( Exception ex )

		{

			SetStatus( ex.Message, true );

		}

		StateHasChanged();

	}



	void ExitToMenu()
	{
		var summary = _provider.GetSessionSummary();
		DynastyUi.Request( UiRequest.Open( UiWindowType.SessionSummary, summary ) );
		StateHasChanged();
	}

	void ConfirmExitToMenu()
	{
		DynastyUi.Request( UiRequest.Close( UiWindowType.SessionSummary ) );
		DynastyApp.ReturnToMainMenu( saveFirst: true );
	}



	static string FormatRecord( TeamStandingRow row )

	{

		var ties = row.Ties > 0 ? $"-{row.Ties}" : "";

		return $"{row.Wins}-{row.Losses}{ties}";

	}

	static string FormatTraitsList( IEnumerable<string> traits )

		=> string.Join( ", ", traits.Select( FormatTraitDisplay ) );

	static string FormatTraitDisplay( string trait )

	{

		if ( string.IsNullOrEmpty( trait ) )

			return trait;



		var chars = new List<char>();

		for ( var i = 0; i < trait.Length; i++ )

		{

			var c = trait[i];

			if ( i > 0 && char.IsUpper( c ) && char.IsLower( trait[i - 1] ) )

				chars.Add( ' ' );

			chars.Add( c );

		}

		return new string( chars.ToArray() );

	}

}



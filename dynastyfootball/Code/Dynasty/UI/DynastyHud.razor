	void NavigateSuggestedAction()

	{

		var top = _todos.Items.FirstOrDefault();

		if ( top != null )

		{

			HandleTodo( top );

			return;

		}

		if ( _home.InboxActionCount > 0 )

		{

			SetTab( "inbox" );

			return;

		}

		var state = DynastyApp.League.State;

		if ( state?.Phase == Dynasty.Core.Enums.LeaguePhase.Draft )

			SetTab( "draft" );

		else if ( _home.NextGame.HasGame && !_home.NextGame.IsComplete )

			OpenGame( _home.NextGame.GameId );

		else

			SetTab( "home" );

	}


	int GetLivePickSecondsRemaining()

	{

		var state = DynastyApp.League.State;

		if ( state == null || !state.Draft.IsActive )

			return 0;

		var limit = state.Settings.DraftPickTimerSeconds;

		if ( state.Draft.OnClockSinceUtc == default )

			return limit;

		var elapsed = (int)( DateTime.UtcNow - state.Draft.OnClockSinceUtc ).TotalSeconds;

		return Math.Max( 0, limit - elapsed );

	}



	protected override int BuildHash()

	{

		EnsureFresh();

		EnsureUiSubscription();

		PollNetworkCommandFeedback();

		var hash = new HashCode();
		hash.Add( _tab );
		hash.Add( _home.StateRevision );
		hash.Add( _saveSlot );
		hash.Add( _statusMessage );
		hash.Add( _selectedProspectId );
		hash.Add( _selectedRosterPlayerId );
		hash.Add( _selectedInboxId );
		hash.Add( _selectedNewsId );
		hash.Add( DynastyUi.IsOpen( UiWindowType.GameViewer ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.AdvanceTimeMenu ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.WeekSummary ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.PostGameCelebration ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.FormationPicker ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.TeamReleaseConfirm ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.TeamExtendDialog ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.TeamTradeDialog ) );
		hash.Add( DynastyUi.IsOpen( UiWindowType.DraftCeremony ) );
		hash.Add( _showTeamProfile );
		hash.Add( _teamProfileModal?.Abbreviation ?? "" );
		hash.Add( _todos.Items.Count );
		hash.Add( GetLivePickSecondsRemaining() );
		hash.Add( _prospectSortColumn );
		hash.Add( _prospectSortDescending );
		hash.Add( _teamSubTab );
		hash.Add( _formationSide );
		hash.Add( _formationSelectedSlotKey );
		hash.Add( _formationSelectedPlayerId );
		hash.Add( DynastyUiManager.Instance.ChangeToken );
		return hash.ToHashCode();

	}




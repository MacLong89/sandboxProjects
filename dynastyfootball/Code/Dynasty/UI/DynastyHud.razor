	void ConfirmRelease()
	{
		if ( !CanManage() || _playerDetail == null ) return;

		var result = DynastyApp.League.ExecuteCommand(
			new ReleasePlayerCommand
			{
				TeamId = _provider.SelectedTeamId,
				PlayerId = _playerDetail.Id,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? $"{_playerDetail.Name} released." : result.Error, !result.Success );
		ClosePlayerDetail();
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	void ConfirmExtend()
	{
		if ( !CanManage() || _playerDetail == null ) return;

		if ( !int.TryParse( _extendYearsText, out var years ) || years < 1 )
		{
			SetStatus( "Enter valid years (1–7).", true );
			return;
		}

		if ( !int.TryParse( _extendSalaryText, out var salary ) || salary < 750_000 )
		{
			SetStatus( "Enter a valid annual salary.", true );
			return;
		}

		var result = DynastyApp.League.ExecuteCommand(
			new ExtendContractCommand
			{
				TeamId = _provider.SelectedTeamId,
				PlayerId = _playerDetail.Id,
				Years = years,
				AnnualSalary = salary,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Contract extended." : result.Error, !result.Success );
		if ( result.Success )
			DynastyAudio.PlayEconomy();
		CloseTeamModal();
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}

	void ConfirmTrade()
	{
		if ( !CanManage() || _playerDetail == null || _tradePartnerId.IsEmpty )
		{
			SetStatus( "Select a trade partner.", true );
			return;
		}

		if ( _tradeReturnPlayerId.IsEmpty )
		{
			SetStatus( "Select a player to receive in the trade.", true );
			return;
		}

		var result = DynastyApp.League.ExecuteCommand(
			new SubmitTradeCommand
			{
				FromTeamId = _provider.SelectedTeamId,
				ToTeamId = _tradePartnerId,
				PlayerId = _playerDetail.Id,
				ReturnPlayerId = _tradeReturnPlayerId,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Trade completed." : result.Error, !result.Success );
		ClosePlayerDetail();
		_lastRevision = 0;
		Refresh();
		StateHasChanged();
	}


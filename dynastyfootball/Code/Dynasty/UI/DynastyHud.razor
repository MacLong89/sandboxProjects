		<div class="ui-modal-backdrop team-profile-backdrop ui-anim-fade" @onclick=@CloseTeamProfile>
			<div class="ui-modal-card team-profile-card" @onmousedown='@UiModalHelpers.StopPropagation'>
				<Label class="modal-title">Team Profile</Label>

				<div class="team-profile-hero @( teamProfile.IsUserTeam ? "user-team" : "" )">
					<div class="team-profile-identity">
						<Label class="team-profile-abbr">@teamProfile.Abbreviation</Label>
						<div class="team-profile-text">
							<Label class="team-profile-name">@teamProfile.DisplayName</Label>
							<div class="team-profile-meta">
								<div class="team-profile-meta-item">
									<Label class="team-profile-meta-val">@teamProfile.Record</Label>
									<Label class="team-profile-meta-label">Record</Label>
								</div>
								<Label class="team-profile-meta-sep">|</Label>
								<div class="team-profile-meta-item">
									<Label class="team-profile-meta-val">#@teamProfile.StandingRank</Label>
									<Label class="team-profile-meta-label">Standing</Label>
								</div>
							</div>
						</div>
					</div>

					<div class="team-profile-stats">
						@if ( !string.IsNullOrEmpty( teamProfile.DepthChartLabel ) )
						{
							<div class="profile-stat">
								<Label class="profile-stat-val">@teamProfile.DepthChartLabel</Label>
								<Label class="profile-stat-label">Lineup</Label>
							</div>
						}
						<div class="profile-stat">
							<Label class="profile-stat-val ovr">@teamProfile.OffenseOverall</Label>
							<Label class="profile-stat-label">Off OVR</Label>
						</div>
						<div class="profile-stat">
							<Label class="profile-stat-val ovr">@teamProfile.DefenseOverall</Label>
							<Label class="profile-stat-label">Def OVR</Label>
						</div>
						<div class="profile-stat">
							<Label class="profile-stat-val ovr team-ovr">@teamProfile.TeamOverall</Label>
							<Label class="profile-stat-label">Team OVR</Label>
						</div>
						<div class="profile-stat">
							<Label class="profile-stat-val">@teamProfile.Prestige</Label>
							<Label class="profile-stat-label">Prestige</Label>
						</div>
						<div class="profile-stat">
							<Label class="profile-stat-val">@teamProfile.Morale</Label>
							<Label class="profile-stat-label">Morale</Label>
						</div>
						<div class="profile-stat">
							<Label class="profile-stat-val">$@(teamProfile.CapSpace / 1_000_000)M</Label>
							<Label class="profile-stat-label">Cap Space</Label>
						</div>
						<div class="profile-stat">
							<Label class="profile-stat-val">@teamProfile.RosterCount</Label>
							<Label class="profile-stat-label">Roster</Label>
						</div>
						<div class="profile-stat">
							<Label class="profile-stat-val">@teamProfile.BuildingWindow</Label>
							<Label class="profile-stat-label">Window</Label>
						</div>
					</div>
				</div>

				<Label class="panel-subtitle recent-games-title">Recent Games</Label>
				@if ( teamProfile.RecentGames.Count == 0 )
				{
					<Label class="muted">No completed games this season yet.</Label>
				}
				else
				{
					<div class="recent-games-list">
						@foreach ( var game in teamProfile.RecentGames )
						{
							<div class="recent-game-row clickable @TeamGameResultClass( game.ResultLabel )" @onclick='@(() => OpenTeamProfileGame( game.GameId.Value ))'>
								<Label class="recent-game-week">Wk @game.Week</Label>
								<Label class="recent-game-matchup">@game.MatchupLabel</Label>
								<Label class="recent-game-score">@game.ScoreLine</Label>
								<Label class="recent-game-result">@game.ResultLabel</Label>
							</div>
						}
					</div>
				}

				<div class="modal-actions">
					<Button class="btn secondary" Text="Close" onclick=@CloseTeamProfile />
				</div>
			</div>
		</div>
	}

	@if ( DynastyUi.IsOpen( UiWindowType.AdvanceTimeMenu ) )
	{
		<div class="ui-modal-backdrop ui-anim-fade" style="@UiModalHelpers.ZIndexStyle( UiWindowType.AdvanceTimeMenu )" @onclick='@(() => UiModalHelpers.BackdropClick( UiWindowType.AdvanceTimeMenu, CloseAdvanceMenu ))'>
			<div class="ui-modal-card advance-time-modal" @onmousedown='@UiModalHelpers.StopPropagation'>
				<Label class="modal-title">Advance Time</Label>
				<Label class="muted">Simulate games and league events automatically.</Label>
				<div class="advance-time-options">
					<Button class="btn secondary advance-time-option" Text="Advance Week" onclick='@(() => ExecuteAdvanceTarget( TimeAdvanceTarget.OneWeek ))' />
					<Button class="btn secondary advance-time-option" Text="Advance to Mid-Season" onclick='@(() => ExecuteAdvanceTarget( TimeAdvanceTarget.MidSeason ))' />
					<Button class="btn secondary advance-time-option" Text="Advance to End of Regular Season" onclick='@(() => ExecuteAdvanceTarget( TimeAdvanceTarget.EndRegularSeason ))' />
					<Button class="btn secondary advance-time-option" Text="Advance to Super Bowl" onclick='@(() => ExecuteAdvanceTarget( TimeAdvanceTarget.SuperBowl ))' />
					<Button class="btn secondary advance-time-option" Text="Advance to Next Draft" onclick='@(() => ExecuteAdvanceTarget( TimeAdvanceTarget.NextDraft ))' />
				</div>
				<div class="modal-actions">
					<Button class="btn secondary" Text="Cancel" onclick=@CloseAdvanceMenu />
				</div>
			</div>
		</div>
	}

	@if ( DynastyUi.IsOpen( UiWindowType.WeekSummary ) )
	{
		<div class="ui-modal-backdrop ui-anim-fade" style="@UiModalHelpers.ZIndexStyle( UiWindowType.WeekSummary )" @onclick='@(() => UiModalHelpers.BackdropClick( UiWindowType.WeekSummary, CloseWeekSummary ))'>
			<div class="ui-modal-card week-summary-modal" @onmousedown='@UiModalHelpers.StopPropagation'>
				<Label class="modal-title">@(ActiveWeekSummary()?.Title ?? "Week Summary")</Label>
				@if ( !string.IsNullOrEmpty( ActiveWeekSummary()?.Headline ) )
				{
					<Label class="week-summary-headline">@ActiveWeekSummary()?.Headline</Label>
				}
				<div class="week-summary-lines">
					@foreach ( var line in ActiveWeekSummary()?.Lines ?? Array.Empty<string>() )
					{
						<Label class="week-summary-line">@line</Label>
					}
				</div>
				<div class="modal-actions">
					<Button class="btn secondary" Text="View Inbox" onclick=@WeekSummaryOpenInbox />
					<Button class="btn primary" Text="Continue" onclick=@CloseWeekSummary />

	void AssignFormationPlayer( PlayerId playerId )
	{
		if ( !CanManage() )
		{
			SetStatus( "Only the host can modify the depth chart.", true );
			return;
		}

		if ( string.IsNullOrEmpty( _formationSelectedSlotKey ) )
		{
			SetStatus( "Select a position slot first.", true );
			return;
		}

		if ( playerId.IsEmpty )
			return;

		var state = DynastyApp.League.State;
		if ( state == null )
		{
			SetStatus( "No league loaded.", true );
			return;
		}

		var result = DynastyApp.League.ExecuteCommand(
			new SetDepthChartStarterCommand
			{
				TeamId = _provider.SelectedTeamId,
				SlotKey = _formationSelectedSlotKey,
				PlayerId = playerId,
				ExpectedStateRevision = state.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Depth chart updated." : result.Error, !result.Success );
		DynastyUi.Request( UiRequest.Close( UiWindowType.FormationPicker ) );
		_lastRevision = 0;
		Refresh();
		RefreshFormationSelection();
		StateHasChanged();
	}


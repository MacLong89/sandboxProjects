	void RefreshPlayerProfile()
	{
		if ( _tab == "draft" && !_selectedProspectId.IsEmpty )
		{
			_prospectDetail = _provider.GetProspectDetail( _selectedProspectId );
			_playerProfile = _provider.GetProspectProfile( _selectedProspectId, CanManage() && _draft.IsUserOnClock );
			return;
		}

		if ( _tab == "freeagency" && !_selectedFaPlayerId.IsEmpty )
		{
			_playerDetail = _provider.GetPlayerDetail( _selectedFaPlayerId );
			_playerProfile = _provider.GetPlayerProfile( _selectedFaPlayerId );
			return;
		}

		if ( _tab == "trades" && !_tradeProfilePlayerId.IsEmpty )
		{
			_playerDetail = _provider.GetPlayerDetail( _tradeProfilePlayerId, _tradeProfileTeamId );
			_playerProfile = _provider.GetPlayerProfile( _tradeProfilePlayerId, _tradeProfileTeamId );
			return;
		}

		if ( _tab == "team" && ( _teamSubTab is "formation" or "specialteams" ) && !_formationSelectedPlayerId.IsEmpty )
		{
			_playerDetail = _provider.GetPlayerDetail( _formationSelectedPlayerId );
			_playerProfile = _provider.GetPlayerProfile( _formationSelectedPlayerId );
			return;
		}

		if ( _tab == "team" && !_selectedRosterPlayerId.IsEmpty && _teamSubTab is "roster" or "contracts" )
		{
			_playerDetail = _provider.GetPlayerDetail( _selectedRosterPlayerId );
			_playerProfile = _provider.GetPlayerProfile( _selectedRosterPlayerId );
			return;
		}

		_playerProfile = null;
	}

	void OpenTeamModal( string modal )
	{
		if ( _playerDetail == null )
			return;

		if ( modal == "extend" )
		{
			_extendYearsText = Math.Max( 1, _playerDetail.Contract.YearsRemaining ).ToString();
			_extendSalaryText = _playerDetail.Contract.AnnualSalary.ToString();
		}

		var window = modal switch
		{
			"cut" => UiWindowType.TeamReleaseConfirm,
			"extend" => UiWindowType.TeamExtendDialog,
			"trade" => UiWindowType.TeamTradeDialog,
			_ => UiWindowType.None
		};

		if ( window == UiWindowType.None )
			return;

		var payload = new TeamPlayerDialogPayload { Player = _playerDetail };
		DynastyUi.Request( UiRequest.Open( window, payload ) );
		StateHasChanged();
	}


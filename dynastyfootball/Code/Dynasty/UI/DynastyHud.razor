	void BeginSimulateGame( GameId gameId, bool fromViewer = true )
	{
		if ( !CanManage() )
			return;

		var state = DynastyApp.League.State;
		if ( state != null && FtueHelper.ShouldPromptFourthDownDecision( state ) )
		{
			_pendingSimGameId = gameId;
			_pendingSimFromViewer = fromViewer;
			DynastyUi.Request( UiRequest.Open( UiWindowType.FourthDownDecision, null ) );
			StateHasChanged();
			return;
		}

		if ( fromViewer )
			_ = SimulateSelectedGame();
		else
			_ = SimulateGameById( gameId );
	}

	void OnFourthDownChoice( string choice )
	{
		DynastyUi.Request( UiRequest.Close( UiWindowType.FourthDownDecision ) );

		var plan = choice switch
		{
			"runHeavy" => WeeklyGamePlan.RunHeavy,
			"passHeavy" => WeeklyGamePlan.PassHeavy,
			"blitz" => WeeklyGamePlan.DefensiveFocus,
			_ => WeeklyGamePlan.Balanced
		};

		if ( FtueHelper.ShouldPromptFourthDownDecision( DynastyApp.League.State ) )
		{
			DynastyApp.League.ExecuteCommand(
				new SetWeeklyGamePlanCommand
				{
					TeamId = _provider.SelectedTeamId,
					Plan = plan,
					ExpectedStateRevision = DynastyApp.League.State.StateRevision
				}, Connection.Local?.SteamId ?? 0, true );
		}

		if ( _pendingSimFromViewer )
			_ = SimulateSelectedGame();
		else if ( !_pendingSimGameId.IsEmpty )
			_ = SimulateGameById( _pendingSimGameId );

		_pendingSimGameId = default;
		StateHasChanged();
	}

	async Task SimulateGameById( GameId gameId )
	{
		if ( !CanManage() )
			return;

		var wasUserGame = DynastyApp.League.State.Schedule.Games
			.Any( g => g.Id.Value == gameId.Value
				&& ( g.HomeTeamId.Value == _provider.SelectedTeamId.Value || g.AwayTeamId.Value == _provider.SelectedTeamId.Value ) );

		var result = DynastyApp.League.ExecuteCommand(
			new SimulateGameCommand
			{
				GameId = gameId,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, Connection.Local?.SteamId ?? 0, true );

		SetStatus( result.Success ? "Game simulated." : result.Error, !result.Success );
		_lastRevision = 0;
		Refresh();

		if ( result.Success && wasUserGame )
		{
			var autoReplay = FtueHelper.ShouldAutoOpenReplay( DynastyApp.League.State );
			DynastyUiManager.Instance.SetGameplayPhase( UiGameplayPhase.GameSimulation );
			DynastyUi.Request( UiRequest.Open( UiWindowType.GameViewer, _provider.GetGameViewer( gameId, autoReplay ) ) );
		}

		StateHasChanged();
	}

	async Task SimulateSelectedGame()
	{
		var viewer = DynastyUi.Payload<GameViewerViewModel>( UiWindowType.GameViewer );
		if ( !CanManage() || viewer == null )
			return;

		var gameId = viewer.GameId;
		var wasUserGame = viewer.IsUserGame;

		var result = DynastyApp.League.ExecuteCommand(
			new SimulateGameCommand
			{
				GameId = gameId,
				ExpectedStateRevision = DynastyApp.League.State.StateRevision
			}, 0, true );

		SetStatus( result.Success ? "Game simulated." : result.Error, !result.Success );
		_lastRevision = 0;
		Refresh();
		var refreshed = _provider.GetGameViewer( gameId, FtueHelper.ShouldAutoOpenReplay( DynastyApp.League.State ) );
		DynastyUi.Request( UiRequest.Open( UiWindowType.GameViewer, refreshed ) );

		if ( result.Success && wasUserGame && refreshed != null && TryBuildWinCelebration( refreshed, gameId, out var celebration ) )
		{
			DynastyAudio.PlayMilestone();
			DynastyUi.Request( UiRequest.Close( UiWindowType.GameViewer ) );
			DynastyUiManager.Instance.SetGameplayPhase( UiGameplayPhase.Celebration );
			DynastyUi.Request( UiRequest.Open( UiWindowType.PostGameCelebration, celebration ) );
		}

		StateHasChanged();
	}

	bool TryBuildWinCelebration( GameViewerViewModel viewer, GameId gameId, out PostGameCelebrationViewModel celebration )
	{
		celebration = null;
		var state = DynastyApp.League.State;
		var userId = _provider.SelectedTeamId;
		if ( state == null || userId.IsEmpty || viewer == null )
			return false;

		var game = state.Schedule.Games.FirstOrDefault( g => g.Id.Value == gameId.Value );
		if ( game?.Result == null )
			return false;

		var userIsHome = game.HomeTeamId.Value == userId.Value;
		var userWon = userIsHome ? viewer.HomeWon : viewer.AwayWon;
		if ( !userWon )
			return false;

		celebration = new PostGameCelebrationViewModel
		{
			Title = viewer.WinnerLabel,
			ScoreLine = $"{viewer.Away} {viewer.AwayScore} — {viewer.Home} {viewer.HomeScore}",
			Detail = "Your team takes the W. Prestige and fan happiness increased."
		};
		return true;
	}


	IEnumerable<ProspectRow> GetSortedProspects()

	{

		var list = _draftBoard.AvailableProspects;

		if ( list.Count == 0 )

			return list;



		return _prospectSortColumn switch

		{

			"position" => _prospectSortDescending

				? list.OrderByDescending( p => p.PositionEnum ).ThenBy( p => p.Rank )

				: list.OrderBy( p => p.PositionEnum ).ThenBy( p => p.Rank ),

			"age" => _prospectSortDescending

				? list.OrderByDescending( p => p.AgeYears ).ThenBy( p => p.Rank )

				: list.OrderBy( p => p.AgeYears ).ThenBy( p => p.Rank ),

			"overall" => SortProspectsByRating( list, p => p.OverallRating ),

			_ => _prospectSortDescending

				? list.OrderByDescending( p => p.Rank )

				: list.OrderBy( p => p.Rank ),

		};

	}

	IEnumerable<ProspectRow> SortProspectsByRating( IReadOnlyList<ProspectRow> list, Func<ProspectRow, int?> selector )

	{

		if ( _prospectSortDescending )

		{

			return list

				.OrderByDescending( p => selector( p ).HasValue )

				.ThenByDescending( p => selector( p ) ?? int.MinValue )

				.ThenBy( p => p.Rank );

		}



		return list

			.OrderByDescending( p => selector( p ).HasValue )

			.ThenBy( p => selector( p ) ?? int.MaxValue )

			.ThenBy( p => p.Rank );

	}


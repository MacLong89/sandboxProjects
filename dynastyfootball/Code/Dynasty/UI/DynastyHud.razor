	@if ( DynastyUi.IsOpen( UiWindowType.TeamExtendDialog ) && ActiveTeamPlayer() != null )

	{

		<div class="ui-modal-backdrop ui-anim-fade" style="@UiModalHelpers.ZIndexStyle( UiWindowType.TeamExtendDialog )" @onclick='@(() => UiModalHelpers.BackdropClick( UiWindowType.TeamExtendDialog, CloseTeamModal ))'>
			<div class="ui-modal-card" @onmousedown='@UiModalHelpers.StopPropagation'>
				<Label class="modal-title">Extend @ActiveTeamPlayer().Name</Label>
				<div class="form-row">
					<Label>Years</Label>
					<TextEntry class="text-input" Value:bind=@_extendYearsText />
				</div>
				<div class="form-row">
					<Label>Annual salary</Label>
					<TextEntry class="text-input" Value:bind=@_extendSalaryText />
				</div>
				<Label class="muted">@ExtendContractSummary()</Label>
				<div class="modal-actions">
					<Button class="btn secondary" Text="Cancel" onclick=@CloseTeamModal />
					<Button class="btn primary" Text="Submit Extension" onclick=@ConfirmExtend />
				</div>
			</div>
		</div>

	}

	@if ( DynastyUi.IsOpen( UiWindowType.TeamTradeDialog ) && ActiveTeamPlayer() != null )

	{

		<div class="ui-modal-backdrop ui-anim-fade" style="@UiModalHelpers.ZIndexStyle( UiWindowType.TeamTradeDialog )" @onclick='@(() => UiModalHelpers.BackdropClick( UiWindowType.TeamTradeDialog, CloseTeamModal ))'>
			<div class="ui-modal-card trade-dialog-card" @onmousedown='@UiModalHelpers.StopPropagation'>
				<Label class="modal-title">Trade @ActiveTeamPlayer().Name</Label>
				<Label class="muted">Step 1 complete — now pick a partner, then choose who you receive.</Label>
				<Label class="step-label trade-step-label">Step 2 · Trade partner</Label>
				<div class="trade-partner-list">
					@foreach ( var partner in ActiveTeamPlayer().TradePartners.Take( 12 ) )
					{
						<Button class="@TradePartnerClass( partner.TeamId )" Text="@partner.Abbreviation" onclick='@(() => SelectTradePartnerById( partner.TeamId.Value ))' />
					}
				</div>
				@if ( !_tradePartnerId.IsEmpty )
				{
					<Label class="step-label trade-step-label">Step 3 · Player you receive</Label>
					<div class="panel trade-summary">
						<div class="trade-summary-row">
							<Label class="trade-summary-key">Send</Label>
							<Label class="trade-summary-val">@ActiveTeamPlayer()?.Name</Label>
						</div>
						<div class="trade-summary-row">
							<Label class="trade-summary-key">To</Label>
							<Label class="trade-summary-val">@TradePartnerLabel()</Label>
						</div>
						<div class="trade-receive-block">
							<Label class="trade-summary-key">Receive</Label>
							@if ( _tradeReturnPlayerId.IsEmpty )
							{
								<Label class="trade-receive-empty muted">Choose a player from @TradePartnerAbbreviation()</Label>
								<Button class="btn secondary trade-action-btn" Text="@($"Select Player from {TradePartnerAbbreviation()}")" onclick=@OpenTradeReturnPicker />
							}
							else
							{
								<Label class="trade-receive-name">@TradeReturnPlayerName()</Label>
								<Label class="trade-receive-ovr">@TradeReturnPlayerOverall() OVR</Label>
								<Button class="btn secondary small trade-action-btn" Text="Change Return Player" onclick=@OpenTradeReturnPicker />
							}
						</div>
					</div>
				}
				<div class="modal-actions">
					<Button class="btn secondary" Text="Cancel" onclick=@CloseTeamModal />
					<Button class="btn primary" Text="Propose Trade" Disabled="@(!CanProposeTrade())" onclick=@ConfirmTrade />
				</div>
			</div>
		</div>

		<TradeReturnPickerModal
			Visible="@_tradeReturnPickerOpen"
			PartnerLabel="@TradePartnerLabel()"
			OutgoingPlayerName="@ActiveTeamPlayer()?.Name"
			Candidates="@_tradeReturnCandidates"
			OnSelect="@SelectTradeReturnPlayer"
			OnCancel="@CloseTradeReturnPicker" />

	}

</div>




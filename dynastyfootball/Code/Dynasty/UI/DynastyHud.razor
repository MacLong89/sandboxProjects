	string _lastNetworkErrorShown = "";



	void PollNetworkCommandFeedback()

	{

		var notification = DynastyApp.LastCommandResult;

		if ( notification == null || notification.Success || string.IsNullOrEmpty( notification.Error ) )

			return;



		if ( notification.Error == _lastNetworkErrorShown )

			return;



		_lastNetworkErrorShown = notification.Error;

		DynastyUiManager.Instance.EnqueueNotification( notification.Error, true );

	}



	void EnsureFresh()

	{

		var state = DynastyApp.League.State;

		var revision = state != null ? state.StateRevision : 0UL;

		if ( revision == _lastRevision && _home.StateRevision == revision )

			return;



		_lastRevision = revision;

		Refresh();

	}



	void Refresh()

	{

		var state = DynastyApp.League.State;

		_saveSlot = DynastyApp.Persistence != null ? DynastyApp.Persistence.ActiveSaveSlot ?? "" : "";

		_provider.Update( state );

		_home = _provider.GetHome();

		_inbox = _provider.GetInbox();

		_team = _provider.GetTeamOverview();

		_formationRoster = _provider.GetFormationRoster( GetActiveFormationSide() );

		_rosterSlots = _provider.GetDepthChart();

		_teamContracts = _provider.GetTeamContracts();

		RefreshFormationSelection();

		var focusWeek = ScheduleWeekHelper.GetFocusWeek( state );
		var requestedWeek = focusWeek + _scheduleWeekOffset;
		var viewWeek = ScheduleWeekHelper.ClampViewWeek( state, requestedWeek );
		_scheduleWeekOffset = viewWeek - focusWeek;
		_schedule = _provider.GetSchedule( viewWeek, _scheduleUserOnly );

		_freeAgency = _provider.GetFreeAgency();

		_draft = _provider.GetDraftRoom();

		_draftBoard = _provider.GetDraftBoard();

		_news = _provider.GetNews();

		_facilities = _provider.GetFacilities();

		_tradeCenter = _provider.GetTradeCenter();

		_legacy = _provider.GetLegacy();

		_visualizationMode = state?.Settings.DefaultVisualizationMode ?? GameVisualizationMode.TopDownField;

		if ( !_autoOpenedDraftTab && state?.Phase == Core.Enums.LeaguePhase.Draft )
		{
			_tab = "draft";
			_autoOpenedDraftTab = true;
		}

		_todos = _provider.GetActionTodos();

		RefreshPlayerProfile();

		if ( _selectedInboxId != Guid.Empty )

			_inboxDetail = _provider.GetInboxDetail( _selectedInboxId );

		if ( _selectedNewsId != Guid.Empty )

			_newsDetail = _provider.GetNewsDetail( _selectedNewsId );

		if ( DynastyUi.IsOpen( UiWindowType.GameViewer ) )
		{
			var viewer = DynastyUi.Payload<GameViewerViewModel>( UiWindowType.GameViewer );
			if ( viewer != null )
				DynastyUi.Request( UiRequest.Open( UiWindowType.GameViewer, _provider.GetGameViewer( viewer.GameId ) ) );
		}

	}




	void SetStatus( string message, bool isError = false )

	{

		if ( string.IsNullOrWhiteSpace( message ) )

			return;

		DynastyUiManager.Instance.EnqueueNotification( message, isError );

		_statusMessage = message;

		_statusClass = isError ? "error" : "info";

		_statusClearToken++;

		var token = _statusClearToken;

		_ = ClearStatusAfterDelay( token );

	}

	async Task ClearStatusAfterDelay( int token )

	{

		await Task.Delay( 5000 );

		if ( token != _statusClearToken )

			return;

		_statusMessage = "";

		StateHasChanged();

	}


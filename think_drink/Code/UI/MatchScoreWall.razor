@using Sandbox
@using Sandbox.UI
@using ThinkDrink.UI
@inherits PanelComponent
@namespace ThinkDrink.UI

<root>
	<div class="wall">
		<div class="title">LIVE SCORES</div>
		@foreach ( var row in Rows )
		{
			<div class="row @(row.IsLeader ? "leader" : "")">
				<span class="name">@row.Name</span>
				<span class="score">@row.Score</span>
			</div>
		}
		@if ( Rows.Count == 0 )
		{
			<div class="empty">Waiting for players…</div>
		}
	</div>
</root>

@code
{
	private sealed record ScoreRow( string Name, int Score, bool IsLeader );

	private List<ScoreRow> Rows => ThinkDrinkPlayer.All
		.Where( p => p.IsParticipant )
		.OrderByDescending( p => p.MatchScore )
		.ThenBy( p => p.PlayerName )
		.Select( ( p, i ) => new ScoreRow( p.PlayerName, p.MatchScore, i == 0 && p.MatchScore > 0 ) )
		.ToList();

	private int _revision;

	protected override void OnStart()
	{
		GameEvents.PhaseChanged += OnPhaseChanged;
		GameEvents.AnswerResolved += OnAnswer;
		GameEvents.PlayerListChanged += Bump;
	}

	protected override void OnDestroy()
	{
		GameEvents.PhaseChanged -= OnPhaseChanged;
		GameEvents.AnswerResolved -= OnAnswer;
		GameEvents.PlayerListChanged -= Bump;
	}

	private void OnPhaseChanged( MatchPhase _ ) => Bump();

	private void OnAnswer( string _, bool __ ) => Bump();
	private void Bump() => _revision++;

	protected override int BuildHash() => HashCode.Combine( _revision, Rows.Count );
}

	private int PlayerLobbyHash
	{
		get
		{
			var hash = new HashCode();
			for ( var i = 0; i < ThinkDrinkPlayer.All.Count; i++ )
			{
				var p = ThinkDrinkPlayer.All[i];
				hash.Add( p.PlayerName );
				hash.Add( p.SteamKey );
				hash.Add( p.IsReady );
				hash.Add( p.IsConnected );
				hash.Add( p.IsSpectator );
				hash.Add( p.IsBot );
				hash.Add( p.MatchScore );
				hash.Add( p.HasAnsweredThisRound );
			}
			return hash.ToHashCode();
		}
	}


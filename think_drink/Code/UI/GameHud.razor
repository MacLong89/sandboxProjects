	private OnboardingTipDef CurrentOnboardingTip
	{
		get
		{
			if ( !ShouldRunOnboarding || _onboardingGoalIndex > MaxOnboardingGoalIndex )
				return null;
			if ( _onboardingGoalIndex == _onboardingTipDismissedGoal )
				return null;
			if ( _onboardingTipCooldown )
				return null;
			if ( !CanShowOnboardingGoal( _onboardingGoalIndex ) )
				return null;

			return _onboardingGoalIndex >= 0 && _onboardingGoalIndex < OnboardingTips.Length
				? OnboardingTips[_onboardingGoalIndex]
				: null;
		}
	}

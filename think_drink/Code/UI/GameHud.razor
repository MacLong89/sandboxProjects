	private int XpToNextLevel
	{
		get
		{
			if ( LocalProfile is null ) return 0;
			var level = LocalProfile.Level;
			var xpIntoLevel = LocalProfile.Xp;
			for ( var l = 1; l < level; l++ )
				xpIntoLevel -= GameConstants.XpForLevel( l );
			return Math.Max( 0, GameConstants.XpForLevel( level ) - xpIntoLevel );
		}
	}

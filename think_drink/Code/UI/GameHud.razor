@using Sandbox
@using Sandbox.UI
@using ThinkDrink.UI
@inherits PanelComponent
@namespace ThinkDrink.UI

<root class="@RootClass @(UIManager.ShouldDimBackground ? "ui-dimmed" : "")">
	<div class="vignette @(VignetteActive ? "active" : "")"></div>
	<div class="flash @(FlashCorrect ? "correct" : "wrong") @(FlashMessage != "" ? "show" : "")">@FlashMessage</div>
	@for ( var ti = 0; ti < UIManager.Toasts.Count; ti++ )
	{
		var toast = UIManager.Toasts[ti];
		<div class="toast @(toast.Positive ? "positive" : "neutral")" style="top: @(GetToastTopPercent(ti))%;">@toast.DisplayText</div>
	}
	@if ( !string.IsNullOrEmpty( UiState.LevelUpMessage ) )
	{
		<div class="level-up-banner">@UiState.LevelUpMessage</div>
	}
	@if ( UIManager.ShowBoardTuner )
	{
		<div class="board-tuner">
			<div class="tuner-title">Board tuner</div>
			<div class="tuner-value">@StudioBoardTuner.Readout</div>
			<div class="tuner-help">7/8 size  9/0 up/down  3/4 distance  R reset  ·  Q hide</div>
		</div>
	}
	@if ( UiState.BuzzerHoverActive && !UIManager.HasModalOpen )
	{
		<div class="buzzer-hover-prompt">
			<div class="prompt-key">M1</div>
			<div class="prompt-text">BUZZ</div>
		</div>
	}
	@if ( ShowCrosshair && !UIManager.HasModalOpen )
	{
		<div class="dot-crosshair"></div>
	}
	@if ( UIManager.Tooltip.Visible )
	{
		<div class="ui-tooltip">@UIManager.Tooltip.Text</div>
	}

	@if ( ShowOnboardingModal && CurrentOnboardingTip is { } onboardingTip )
	{
		<div class="onboarding-backdrop"></div>
		<div class="onboarding-panel tutorial-tip">
			<i class="icon onboarding-icon">@onboardingTip.Icon</i>
			<div class="onboarding-title">@onboardingTip.Title</div>
			<div class="onboarding-body">@onboardingTip.Body</div>
			@if ( _onboardingGoalIndex == MaxOnboardingGoalIndex )
			{
				<div class="onboarding-goal">Goal: first to @VotedThreshold points wins.</div>
			}
			<div class="onboarding-actions">
				<div class="onboarding-btn btn ghost" onclick=@HideOnboardingTips><i class="icon">visibility_off</i><span>Hide tips</span></div>
				<div class="onboarding-btn btn primary" onclick=@DismissOnboardingTip>Got it</div>
			</div>
		</div>
	}

	@if ( Phase == MatchPhase.Lobby )
	{
		<div class="lobby @(CountdownActive ? "countdown-active" : "") @(UIManager.IsOverlayOpen ? "shell-suppressed" : "")">
			<div class="logo-block">
				<i class="icon logo">local_bar</i>
				<div class="title">THINK &amp; DRINK</div>
				<div class="tagline">Buzz fast. Answer smart. Climb the board.</div>
			</div>

			<div class="retention-strip">
				@if ( DailyChallenge is not null )
				{
					<div class="retention-chip">Daily: @DailyChallenge.Current/@DailyChallenge.Target @ChallengeNudge</div>
				}
				@if ( LocalProfile?.ConsecutivePlayDays > 0 )
				{
					<div class="retention-chip streak">🔥 @LocalProfile.ConsecutivePlayDays-day streak</div>
				}
				@if ( DailyBonusAvailable )
				{
					<div class="retention-chip bonus">+@GameConstants.DailyFirstMatchXpBonus XP first match today</div>
				}
				<div class="retention-chip featured">Featured: @FeaturedCategory</div>
			</div>

			<div class="lobby-grid">
				<div class="panel players-panel">
					<div class="panel-title"><i class="icon">groups</i> Players (@ConnectedCount/@GameConstants.MaxPlayers)</div>
					@foreach ( var p in Players )
					{
						<div class="player-row @(p.IsBot ? "bot" : "")">
							<div class="name">@p.PlayerName @(p.IsBot ? "🤖" : "")</div>
							<div class="meta">@(p.IsBot ? "Practice partner" : $"Lv {p.LifetimeLevel} · {ProgressionTitles.GetTitle(p.LifetimeLevel)} · {p.LifetimeWins} W")</div>
							<div class="ready @(p.IsReady ? "on" : "")">@(p.IsReady ? "READY" : "…")</div>
						</div>
					}
					@if ( CountdownActive )
					{
						<div class="countdown">Match starts in @CountdownText — look around the studio</div>
					}
					else if ( BotActive )
					{
						<div class="hint bot-hint">Practice Bot is ready — hit READY UP to start.</div>
					}
					else if ( HumanCount == 1 )
					{
						<div class="hint solo-guide">Solo? Tap <strong>PLAY VS BOT</strong> below, then ready up.</div>
					}
					else
					{
						<div class="hint">Need @GameConstants.MinPlayers+ players ready to start</div>
					}
				</div>

				<div class="panel settings-panel">
					<div class="panel-title"><i class="icon">tune</i> Match Settings</div>
					<div class="setting-row">Win threshold: <strong>@VotedThreshold</strong> pts</div>
					<div class="vote-row">
						@foreach ( var t in ThresholdOptions )
						{
							<div class="vote-btn btn @(VotedThreshold == t ? "active" : "")" onclick=@(() => VoteThreshold(t))>@t</div>
						}
					</div>
					<div class="setting-row mode-title">Game mode: <strong>@SelectedMode.DisplayName</strong></div>
					<div class="mode-grid">
						@foreach ( var mode in SelectableModes )
						{
							<div class="mode-btn btn @(SelectedMode.Id == mode.Id ? "active" : "")" onclick=@(() => SelectGameMode(mode.Id))>
								<div class="mode-name">@mode.DisplayName</div>
								<div class="mode-desc">@mode.ShortName · @GetModeBlurb( mode.Id )</div>
							</div>
						}
					</div>
					<div class="setting-row mode-info">@SelectedMode.DisplayName · @LobbyModeTagline</div>

					<div class="ready-btn btn @(LocalReady ? "ready" : "")" onclick=@ToggleReady>
						<i class="icon">@(LocalReady ? "check_circle" : "radio_button_unchecked")</i>
						@(LocalReady ? "READY!" : "READY UP")
					</div>

					@if ( HumanCount == 1 && !BotActive )
					{
						<div class="practice-btn btn highlight" onclick=@StartPractice>
							<i class="icon">smart_toy</i> PLAY VS BOT
						</div>
					}

					<div class="nav-row @(ShowOnboarding ? "disabled" : "")">
						<div class="nav-btn btn @(UIManager.IsWindowOpen(UiWindowId.Leaderboard) ? "open" : "")" onclick=@(() => OpenOverlay(UiScreen.Leaderboard)) onmouseover=@(() => QueueTooltip("Global leaderboards")) onmouseout=@HideTooltip>Leaderboard</div>
						<div class="nav-btn btn @(UIManager.IsWindowOpen(UiWindowId.Profile) ? "open" : "")" onclick=@(() => OpenOverlay(UiScreen.Profile)) onmouseover=@(() => QueueTooltip("Your stats and progression")) onmouseout=@HideTooltip>Profile</div>
						<div class="nav-btn btn @(UIManager.IsWindowOpen(UiWindowId.Challenges) ? "open" : "")" onclick=@(() => OpenOverlay(UiScreen.Challenges)) onmouseover=@(() => QueueTooltip("Daily and weekly goals")) onmouseout=@HideTooltip>Challenges</div>
						<div class="nav-btn btn @(UIManager.IsWindowOpen(UiWindowId.Achievements) ? "open" : "")" onclick=@(() => OpenOverlay(UiScreen.Achievements)) onmouseover=@(() => QueueTooltip("Achievement progress")) onmouseout=@HideTooltip>Achievements</div>
						<div class="nav-btn btn @(UIManager.IsWindowOpen(UiWindowId.Settings) ? "open" : "")" onclick=@(() => OpenOverlay(UiScreen.Settings)) onmouseover=@(() => QueueTooltip("Audio and gameplay options")) onmouseout=@HideTooltip>Settings</div>
					</div>
				</div>
			</div>
		</div>
	}
	else if ( Phase == MatchPhase.PostMatch && LastResult is not null )
	{
		<div class="postmatch @(UIManager.IsOverlayOpen ? "shell-suppressed" : "")">
			<div class="winner-banner">
				<i class="icon">emoji_events</i>
				<div class="winner-name">@LastResult.WinnerName WINS!</div>
			</div>
			<div class="results-grid">
				@foreach ( var p in LastResult.Players )
				{
					<div class="result-row @(p.IsWinner ? "winner" : "") @(p.IsMvp ? "mvp" : "")">
						<div class="rank">#@(LastResult.Players.IndexOf(p) + 1)</div>
						<div class="name">@p.DisplayName @(p.IsMvp ? "★ MVP" : "")</div>
						<div class="score">@p.Score pts</div>
						<div class="detail">@p.Correct correct · +@p.XpEarned XP</div>
					</div>
				}
			</div>
			@if ( LastResult.NewAchievements.Count > 0 )
			{
				<div class="achieve-banner">🏆 New achievements unlocked!</div>
				@foreach ( var id in LastResult.NewAchievements.Take( 4 ) )
				{
					<div class="achieve-row">@GetAchievementTitle( id )</div>
				}
			}
			@if ( LastResult.CompletedChallenges.Count > 0 )
			{
				<div class="challenge-banner">✅ Challenges completed!</div>
				@foreach ( var id in LastResult.CompletedChallenges )
				{
					<div class="achieve-row">@id</div>
				}
			}
			@if ( LocalPostMatchResult?.XpLines?.Count > 0 )
			{
				<div class="xp-breakdown">
					<div class="xp-title">XP Breakdown</div>
					@foreach ( var line in LocalPostMatchResult.XpLines )
					{
						<div class="xp-line">@line</div>
					}
					<div class="xp-total">Total +@LocalPostMatchResult.XpEarned XP</div>
				</div>
			}
			<div class="postmatch-actions">
				@if ( CanSkipPostMatch )
				{
					<div class="skip-btn btn" onclick=@SkipPostMatch>Skip</div>
				}
				<div class="rematch-btn btn" onclick=@Rematch>Rematch</div>
			</div>
			<div class="return-hint">@(CanSkipPostMatch ? "Auto-returning soon…" : $"Returning in {PostMatchText}…")</div>
		</div>
	}
	else
	{
		<div class="match-hud @(ShowPhaseSkipHint ? "has-skip-hint" : "")">
			@if ( LocalPlayer?.IsSpectator == true )
			{
				<div class="spectator-banner">Spectating — you'll play in the next lobby match.</div>
			}

			<div class="win-goal">FIRST TO @WinThreshold WINS</div>
			<div class="phase-ribbon @PhaseRibbonClass">@PhaseRibbonText</div>
			@if ( ShowPhaseSkipHint )
			{
				<div class="phase-skip-hint btn" onclick=@RequestPhaseSkip>Tab — skip reveal (@PhaseSkipCount/@PhaseSkipRequired)</div>
			}

			<div class="top-strip">
				<div class="brand-mini">THINK &amp; DRINK</div>
				<div class="round">@SelectedMode.ShortName · Round @RoundNumber · First to @WinThreshold</div>
				@if ( !string.IsNullOrEmpty( EventBanner ) )
				{
					<div class="event-banner">@EventBanner</div>
				}
			</div>

			<div class="score-strip">
				@foreach ( var p in LiveScores )
				{
					<div class="score-chip @(p.SteamKey == BuzzWinnerKey ? "buzz" : "") @(p.SteamKey == LocalPlayer?.SteamKey ? "you" : "")">
						<span class="chip-name">@p.PlayerName</span>
						<span class="chip-score">@p.MatchScore</span>
						@if ( GetScorePop( p.PlayerName ) is { } pop )
						{
							<span class="score-pop">+@pop</span>
						}
					</div>
				}
			</div>

			@if ( LocalPlayer is not null && UiState.MatchStreak >= 2 && MatchManager.Instance?.LastScorerName == LocalPlayer.PlayerName )
			{
				<div class="streak-badge">🔥 @UiState.MatchStreak streak</div>
			}

			<div class="controls-panel @(ControlsFocused ? "focused" : "") @(Phase == MatchPhase.BuzzIn ? "buzz-phase" : "") @(ControlsInteractive ? "interactive" : "")">
				@if ( ShowAnswerControls )
				{
					<div class="timer @(CreativeSubmitPhase ? "answer" : IsStealTurn ? "steal" : CreativeVotePhase ? "answer" : "answer")">@AnswerPromptTitle — @AnswerWindowText</div>
					@if ( CreativeVotePhase && CreativeVoteOptions.Count > 0 )
					{
						<div class="mcq-row">
							@foreach ( var option in CreativeVoteOptions )
							{
								var letter = option.Letter;
								var isOwn = letter == LocalCreativeLetter;
								<div class="mcq-btn btn @(isOwn ? "disabled" : "")" onclick=@(() => SubmitCreativeVoteClick(letter))>
									<span class="mcq-letter">@letter</span>
									<span class="mcq-text">@option.Text</span>
								</div>
							}
						</div>
						@if ( !string.IsNullOrEmpty( LocalCreativeLetter ) )
						{
							<div class="board-hint">You can't vote for your own quip (marked above).</div>
						}
					}
					else if ( UsesMultipleChoice )
					{
						<div class="mcq-row">
							@if ( !string.IsNullOrEmpty( McqA ) )
							{
								<div class="mcq-btn btn" onclick=@(() => SubmitMcq("A"))><span class="mcq-letter">A</span><span class="mcq-text">@McqA</span></div>
							}
							@if ( !string.IsNullOrEmpty( McqB ) )
							{
								<div class="mcq-btn btn" onclick=@(() => SubmitMcq("B"))><span class="mcq-letter">B</span><span class="mcq-text">@McqB</span></div>
							}
							@if ( !string.IsNullOrEmpty( McqC ) )
							{
								<div class="mcq-btn btn" onclick=@(() => SubmitMcq("C"))><span class="mcq-letter">C</span><span class="mcq-text">@McqC</span></div>
							}
							@if ( !string.IsNullOrEmpty( McqD ) )
							{
								<div class="mcq-btn btn" onclick=@(() => SubmitMcq("D"))><span class="mcq-letter">D</span><span class="mcq-text">@McqD</span></div>
							}
						</div>
					}
					else
					{
						<div class="answer-row">
							<TextEntry @ref="AnswerInput" class="answer-input" placeholder="@AnswerInputPlaceholder" Value:bind="@UiState.AnswerDraft" onsubmit=@SubmitCurrentAnswer />
							<div class="submit-btn btn @(IsStealTurn ? "steal" : "")" onclick=@SubmitCurrentAnswer>@(CreativeSubmitPhase ? "LOCK IN" : IsStealTurn ? "STEAL" : "SUBMIT")</div>
						</div>
					}
				}
				else if ( Phase == MatchPhase.BuzzIn )
				{
					<div class="timer buzz">BUZZ IN! @TimerText · E or click the red buzzer</div>
					<div class="buzz-btn btn armed" onclick=@Buzz>BUZZ!</div>
				}
				else if ( !ShowPredictOffer )
				{
					@if ( GameSettings.Current.ShowHints )
					{
						<div class="board-hint">@MatchHint</div>
					}
					else
					{
						<div class="board-hint">Look toward the question billboard on the back wall</div>
					}
				}

				@if ( ShowPredictOffer )
				{
					@if ( !UiState.PredictionInputOpen )
					{
						<div class="predict-toggle-btn btn" onclick=@OpenPredictionInput>Predict answer for +@GameConstants.PredictionXpBonus XP</div>
					}
					else
					{
						<div class="predict-box">
							<div class="predict-label">Guess the answer for +@GameConstants.PredictionXpBonus XP before it's revealed</div>
							<div class="answer-row">
								<TextEntry @ref="PredictInput" class="answer-input small" placeholder="Your prediction…" Value:bind="@UiState.PredictionDraft" onsubmit=@SubmitPrediction />
								<div class="submit-btn btn small" onclick=@SubmitPrediction>LOCK IN</div>
							</div>
						</div>
					}
				}
			</div>
		</div>
	}

	@if ( UiState.Overlay != UiScreen.Lobby )
	{
		<div class="overlay-backdrop modal-blocker" onclick=@CloseOverlay></div>
		<div class="overlay-panel modal-panel">
			<div class="overlay-header">
				<div class="overlay-title">@OverlayTitle</div>
				<div class="overlay-close btn" onclick=@CloseOverlay><i class="icon">close</i></div>
			</div>
			<div class="overlay-body">
				@if ( UiState.Overlay == UiScreen.Leaderboard )
				{
					<div class="tabs">
						<div class="tab-title">🏆 Wins</div>
						@foreach ( var e in Leaderboard.Wins.Take( 10 ) )
						{
							<div class="lb-row"><span>@e.DisplayName</span><span>@e.Value</span></div>
						}
						<div class="tab-title">✓ Correct</div>
						@foreach ( var e in Leaderboard.CorrectAnswers.Take( 10 ) )
						{
							<div class="lb-row"><span>@e.DisplayName</span><span>@e.Value</span></div>
						}
						<div class="tab-title">🎯 Accuracy (10+ games)</div>
						@foreach ( var e in Leaderboard.Accuracy.Take( 10 ) )
						{
							<div class="lb-row"><span>@e.DisplayName</span><span>@e.Value%</span></div>
						}
						<div class="tab-title">📅 Monthly wins (@CurrentMonthlyPeriod)</div>
						@if ( Leaderboard.MonthlyWins.Count == 0 )
						{
							<div class="lb-empty">No monthly wins yet — win a match this month!</div>
						}
						@foreach ( var e in Leaderboard.MonthlyWins.Take( 10 ) )
						{
							<div class="lb-row"><span>@e.DisplayName</span><span>@e.Value</span></div>
						}
					</div>
				}
				else if ( UiState.Overlay == UiScreen.Profile )
				{
					@if ( LocalProfile is not null )
					{
						<div class="profile-title">@ProgressionTitles.GetTitle( LocalProfile.Level )</div>
						<div class="profile-grid">
							<div class="stat"><label>Level</label><value>@LocalProfile.Level</value></div>
							<div class="stat"><label>XP</label><value>@LocalProfile.Xp</value></div>
							<div class="stat wide"><label>Next level</label><value>@XpToNextLevel XP to go</value></div>
							<div class="stat"><label>Wins</label><value>@LocalProfile.Wins</value></div>
							<div class="stat"><label>Win Rate</label><value>@((LocalProfile.WinRate * 100f).ToString("0"))%</value></div>
							<div class="stat"><label>Accuracy</label><value>@((LocalProfile.Accuracy * 100f).ToString("0"))%</value></div>
							<div class="stat"><label>Streak</label><value>@LocalProfile.CurrentWinStreak (best @LocalProfile.BestWinStreak)</value></div>
							<div class="stat wide"><label>Correct Answers</label><value>@LocalProfile.CorrectAnswers</value></div>
							<div class="stat wide"><label>Monthly Wins</label><value>@LocalProfile.MonthlyWins (@CurrentMonthlyPeriod)</value></div>
						</div>
						@if ( CategoryBadges.Count > 0 )
						{
							<div class="category-badges">
								<div class="badges-title">Category mastery</div>
								@foreach ( var badge in CategoryBadges )
								{
									<div class="category-badge">
										<span class="badge-cat">@badge.Category</span>
										<span class="badge-tier">@badge.Badge</span>
										<span class="badge-count">@badge.Count correct</span>
									</div>
								}
							</div>
						}
					}
					else if ( LocalPlayer is not null )
					{
						<div class="profile-grid">
							<div class="stat"><label>Level</label><value>@LocalPlayer.LifetimeLevel</value></div>
							<div class="stat"><label>Wins</label><value>@LocalPlayer.LifetimeWins</value></div>
							<div class="stat wide"><label>Correct Answers</label><value>@LocalPlayer.LifetimeCorrect</value></div>
							<div class="stat wide"><label>Leaderboard Rank</label><value>@(LocalPlayer.LeaderboardRank > 0 ? $"#{LocalPlayer.LeaderboardRank}" : "—")</value></div>
						</div>
					}
				}
				else if ( UiState.Overlay == UiScreen.Achievements )
				{
					@foreach ( var a in Achievements )
					{
						var unlocked = LocalProfile?.UnlockedAchievements?.Contains( a.Id ) == true;
						var progress = AchievementService.GetProgressValue( LocalProfile, a );
						var target = AchievementService.GetProgressTarget( a );
						var showProgress = !unlocked && target > 1 && progress < target;
						<div class="ach-row @(unlocked ? "unlocked" : "locked")">
							<i class="icon">@a.Icon</i>
							<div class="ach-text">
								<div class="ach-title">@a.Title</div>
								<div class="ach-desc">@a.Description</div>
								@if ( showProgress )
								{
									<div class="ach-progress">@Math.Min( progress, target ) / @target</div>
								}
							</div>
						</div>
					}
				}
				else if ( UiState.Overlay == UiScreen.Challenges )
				{
					@if ( DailyChallenge is not null )
					{
						<div class="challenge-card">
							<div class="ch-label">Daily</div>
							<div class="ch-desc">@DailyChallenge.Description</div>
							<div class="ch-progress">@DailyChallenge.Current / @DailyChallenge.Target · +@DailyChallenge.XpReward XP</div>
						</div>
					}
					@if ( WeeklyChallenge is not null )
					{
						<div class="challenge-card">
							<div class="ch-label">Weekly</div>
							<div class="ch-desc">@WeeklyChallenge.Description</div>
							<div class="ch-progress">@WeeklyChallenge.Current / @WeeklyChallenge.Target · +@WeeklyChallenge.XpReward XP</div>
						</div>
					}
				}
				else if ( UiState.Overlay == UiScreen.Settings )
				{
					<div class="setting-line">Master Volume: @((GameSettings.Current.MasterVolume * 100).ToString("0"))%</div>
					<div class="vol-row">
						<div class="vol-btn btn" onclick=@(() => AdjustVolume( "master", -0.1f ))>-</div>
						<div class="vol-btn btn" onclick=@(() => AdjustVolume( "master", 0.1f ))>+</div>
					</div>
					<div class="setting-line">SFX Volume: @((GameSettings.Current.SfxVolume * 100).ToString("0"))%</div>
					<div class="vol-row">
						<div class="vol-btn btn" onclick=@(() => AdjustVolume( "sfx", -0.1f ))>-</div>
						<div class="vol-btn btn" onclick=@(() => AdjustVolume( "sfx", 0.1f ))>+</div>
					</div>
					<div class="setting-line">Music Volume: @((GameSettings.Current.MusicVolume * 100).ToString("0"))%</div>
					<div class="vol-row">
						<div class="vol-btn btn" onclick=@(() => AdjustVolume( "music", -0.1f ))>-</div>
						<div class="vol-btn btn" onclick=@(() => AdjustVolume( "music", 0.1f ))>+</div>
					</div>
					<div class="setting-line hints-row">
						<span>Show Hints</span>
						<div class="vol-btn btn toggle @(GameSettings.Current.ShowHints ? "active" : "")" onclick=@ToggleHints>@(GameSettings.Current.ShowHints ? "ON" : "OFF")</div>
					</div>
					<div class="setting-line hints-row">
						<span>Auto-ready after matches</span>
						<div class="vol-btn btn toggle @(GameSettings.Current.AutoReady ? "active" : "")" onclick=@ToggleAutoReady>@(GameSettings.Current.AutoReady ? "ON" : "OFF")</div>
					</div>
				}
			</div>
		</div>
	}
</root>

@code
{
	private ThinkDrinkPlayer LocalPlayer => ThinkDrinkPlayer.Local;
	private MatchPhase Phase => MatchManager.Instance?.Phase ?? MatchPhase.Lobby;
	private int RoundNumber => MatchManager.Instance?.RoundNumber ?? 0;
	private int WinThreshold => MatchManager.Instance?.WinThreshold ?? GameConstants.DefaultWinThreshold;
	private string CurrentCategory => MatchManager.Instance?.CurrentCategory ?? "";
	private string QuestionText => MatchManager.Instance?.QuestionText ?? "";

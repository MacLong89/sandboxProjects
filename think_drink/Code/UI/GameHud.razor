	protected override void OnUpdate()
	{
		SyncOnboardingState();
		SyncOnboardingGoals();
		SyncOnboardingTipCooldown();
		UIManager.HandleInput();

		if ( ShowPhaseSkipHint && Input.Pressed( "Score" ) && UiState.Overlay == UiScreen.Lobby && !UIManager.BlocksGameplayInput )
			RequestPhaseSkip();

		if ( Phase == MatchPhase.PostMatch && CanSkipPostMatch && Input.Pressed( "Score" ) )
			SkipPostMatch();

		if ( _vignetteClear )
			VignetteActive = false;

		TrackSyncedState();
		TrackScoreChanges();
		TryFocusAnswerInput();
		TryFocusPredictInput();
		UiState.Update();
	}

	private void SyncOnboardingState()
	{
		var active = ShowOnboardingModal;
		if ( active == _onboardingSynced ) return;
		_onboardingSynced = active;
		UIManager.SetOnboardingActive( active );
	}

	private void SyncOnboardingTipCooldown()
	{
		var cooling = ShowOnboarding && _onboardingTipCooldown;
		if ( _wasOnboardingTipCooldown && !cooling )
			UiState.Bump();
		_wasOnboardingTipCooldown = cooling;
	}

	private void TrackScoreChanges()
	{
		for ( var i = 0; i < LiveScores.Count; i++ )
		{
			var p = LiveScores[i];
			var prev = _lastMatchScores.TryGetValue( p.SteamKey, out var score ) ? score : 0;
			if ( p.MatchScore > prev )
			{
				var delta = p.MatchScore - prev;
				_scorePopByName[p.PlayerName] = delta;
				UiState.AddScorePop( p.PlayerName, delta );
			}
			_lastMatchScores[p.SteamKey] = p.MatchScore;
		}
	}

	private void PulseVignette()
	{
		VignetteActive = true;
		_vignetteClear = 0.35f;
	}

	private void TrackSyncedState()
	{
		if ( Phase != _lastPhase )
		{
			_lastPhase = Phase;
			HandlePhaseEntered( Phase );
		}

		if ( MatchManager.Instance?.LastScorerName == LocalPlayer?.PlayerName )
			UiState.SetMatchStreak( MatchManager.Instance.LastScorerStreak );

		if ( BuzzWinnerKey == _lastBuzzWinnerKey ) return;

		_lastBuzzWinnerKey = BuzzWinnerKey;
		if ( IsBuzzWinner && Phase == MatchPhase.Answering )
		{
			UiState.ClearAnswerDraft();
			UiState.CloseOverlay();
			QueueAnswerFocus();
		}
	}

	private void HandlePhaseEntered( MatchPhase phase )
	{
		UIManager.OnMatchPhaseChanged( phase );

		if ( ShouldRunOnboarding && phase is not MatchPhase.Lobby and not MatchPhase.PostMatch )
			_onboardingInFirstMatch = true;

		if ( ShouldRunOnboarding && phase is MatchPhase.QuestionReveal or MatchPhase.BuzzIn )
			_onboardingReachedBuzzPhase = true;

		if ( phase is MatchPhase.BuzzIn or MatchPhase.ScoreboardReveal or MatchPhase.MatchEnd )
			PulseVignette();

		if ( phase == MatchPhase.MatchEnd && !string.IsNullOrWhiteSpace( WinnerName ) )
			UiState.ShowToast( $"{WinnerName} wins the match!", true );

		switch ( phase )
		{
			case MatchPhase.CategoryReveal:
			case MatchPhase.QuestionReveal:
			case MatchPhase.BuzzIn:
			case MatchPhase.AnswerReveal:
			case MatchPhase.ScoreboardReveal:
			case MatchPhase.MatchEnd:
			case MatchPhase.PostMatch:
			case MatchPhase.Lobby:
				UiState.ClearRoundDrafts();
				break;
			case MatchPhase.CreativeSubmit:
			case MatchPhase.CreativeVote:
			case MatchPhase.Answering when !ActiveModeUsesBuzzers && LocalPlayer?.IsParticipant == true:
			case MatchPhase.Answering when IsBuzzWinner:
			case MatchPhase.StealAttempt when !IsBuzzWinner:
				UiState.ClearAnswerDraft();
				UiState.CloseOverlay();
				QueueAnswerFocus();
				break;
			case MatchPhase.StealAttempt:
				UiState.ClearAnswerDraft();
				break;
		}
	}

	private void QueueAnswerFocus()
	{
		_answerFocusFrames = 10;
	}

	private void TryFocusAnswerInput()
	{
		if ( _answerFocusFrames <= 0 ) return;
		_answerFocusFrames--;

		if ( AnswerInput is null || !AnswerInput.IsValid() ) return;

		AnswerInput.Focus();
		AnswerInput.CaretPosition = AnswerInput.TextLength;
		_answerFocusFrames = 0;
	}

	private void TryFocusPredictInput()
	{
		if ( _predictFocusFrames <= 0 ) return;
		_predictFocusFrames--;

		if ( PredictInput is null || !PredictInput.IsValid() ) return;

		PredictInput.Focus();
		PredictInput.CaretPosition = PredictInput.TextLength;
		_predictFocusFrames = 0;
	}

	protected override int BuildHash()
	{
		var stateHashA = HashCode.Combine(
			Phase,
			RoundNumber,
			PhaseTimer,
			UiState.Revision,
			UiState.InteractionPulse,
			ShowBoardTuner,
			VignetteActive,
			CountdownActive
		);

		var stateHashB = HashCode.Combine(
			UiState.PredictionInputOpen,
			UiState.HasSubmittedPredictionThisRound,
			IsCreativeMode,
			CreativeVoteOptions.Count
		);

		var stateHashC = HashCode.Combine(
			QuestionText,
			BuzzWinnerKey,
			VotedThreshold,
			ConnectedCount,
			FlashMessage,
			CountdownRemaining,
			SelectedMode.Id,
			LiveScores.Count
		);

		var stateHashD = HashCode.Combine(
			PlayerLobbyHash,
			UIManager.Toasts.Count,
			UiState.LevelUpMessage,
			UiState.MatchStreak,
			ShowOnboarding,
			ShowOnboardingModal,
			_onboardingGoalIndex,
			_onboardingTipDismissedGoal,
			CanSkipPostMatch
		);

		var stateHashE = HashCode.Combine(
			UsesMultipleChoice,
			PhaseSkipCount,
			CurrentOnboardingTip?.Title
		);

		return HashCode.Combine(
			HashCode.Combine(stateHashA, stateHashB),
			ActiveModeUsesBuzzers,
			BotActive,
			HashCode.Combine(stateHashC, HashCode.Combine(stateHashD, stateHashE, UIManager.Tooltip.Visible, UIManager.InputContext))
		);
	}
}

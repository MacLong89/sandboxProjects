	private void AdjustVolume( string channel, float delta )
	{
		UiFeedback.Click();
		switch ( channel )
		{
			case "master":
				GameSettings.Current.MasterVolume = Math.Clamp( GameSettings.Current.MasterVolume + delta, 0f, 1f );
				break;
			case "music":
				GameSettings.Current.MusicVolume = Math.Clamp( GameSettings.Current.MusicVolume + delta, 0f, 1f );
				break;
			default:
				GameSettings.Current.SfxVolume = Math.Clamp( GameSettings.Current.SfxVolume + delta, 0f, 1f );
				break;
		}

		GameSettings.Save();
		UiState.Bump();
	}


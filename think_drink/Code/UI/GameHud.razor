	private bool CanShowOnboardingGoal( int goalIndex ) => goalIndex switch
	{
		0 => Phase == MatchPhase.Lobby,
		1 => Phase is not MatchPhase.Lobby and not MatchPhase.PostMatch
			&& (_onboardingInFirstMatch || _onboardingReachedBuzzPhase),
		2 => _onboardingHasBuzzed || _onboardingHasSubmittedAnswer,
		_ => false
	};

	private void SyncOnboardingGoals()
	{
		if ( !ShouldRunOnboarding )
			return;

		if ( _onboardingGoalIndex == 0 && (LocalReady || BotActive) )
			AdvanceOnboardingAfterGoal( 0 );
		else if ( _onboardingGoalIndex == 1 && (_onboardingHasBuzzed || _onboardingHasSubmittedAnswer) )
			AdvanceOnboardingAfterGoal( 1 );
	}

	private void AdvanceOnboardingAfterGoal( int completedGoalIndex )
	{
		if ( _onboardingGoalIndex != completedGoalIndex )
			return;

		if ( completedGoalIndex >= MaxOnboardingGoalIndex )
		{
			CompleteOnboarding();
			return;
		}

		_onboardingGoalIndex = completedGoalIndex + 1;
		_onboardingTipDismissedGoal = -1;
		_onboardingTipCooldown = 0.55f;
		UiState.Bump();
	}

	private void TrackOnboardingAnswerSubmitted()
	{
		if ( !ShouldRunOnboarding )
			return;

		_onboardingHasSubmittedAnswer = true;
		SyncOnboardingGoals();
	}

	private void TrackOnboardingBuzz()
	{
		if ( !ShouldRunOnboarding )
			return;

		_onboardingHasBuzzed = true;
		SyncOnboardingGoals();
	}


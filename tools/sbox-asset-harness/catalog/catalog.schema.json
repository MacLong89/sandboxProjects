{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/sbox-asset-harness/catalog.schema.json",
  "title": "s&box asset catalog",
  "type": "object",
  "required": ["version", "entries"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "games", "lane", "kind", "title", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "games": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "lane": { "enum": ["kit", "mesh", "place"] },
          "kind": { "type": "string" },
          "title": { "type": "string" },
          "status": {
            "enum": ["ready", "placeholder", "blocked_no_blender", "needs_import"]
          },
          "vmdl": { "type": ["string", "null"] },
          "vmat": { "type": ["string", "null"] },
          "kit": { "type": "object" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}

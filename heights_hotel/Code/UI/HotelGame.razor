	string FormatGoalProgress( DailyGoal goal )
	{
		var progress = GoalProgressValue( goal );
		if ( goal.Metric == DailyGoalMetric.EarnCents )
			return $"{HotelSimulation.FormatMoney( progress )}/{HotelSimulation.FormatMoney( goal.Target )}";
		if ( goal.Metric == DailyGoalMetric.ReachOccupancy )
			return $"{progress}%/{goal.Target}%";
		return $"{Math.Min( progress, goal.Target )}/{goal.Target}";
	}


	bool EscapePressed()
	{
		if ( Input.EscapePressed )
		{
			// Consume so s&box does not open the default pause menu.
			Input.EscapePressed = false;
			return true;
		}
		return Input.Pressed( "cancel" ) || Input.Keyboard.Pressed( "ESCAPE" );
	}
	void HandleEscape()
	{
		if ( BuildMode )
		{
			CancelBuildFully();
			return;
		}
		if ( ConfirmUpgrade || ConfirmDemolish || ConfirmNewGame || PendingFireId is not null )
		{
			ConfirmUpgrade = false;
			ConfirmDemolish = false;
			ConfirmNewGame = false;
			PendingFireId = null;
			_localRevision++;
			return;
		}
		if ( SelectedCell is not null )
		{
			ClearSelection();
			_localRevision++;
			return;
		}
		if ( ActiveTab is not null )
		{
			CloseDock();
			_localRevision++;
		}
	}
	void SetSpeed(int index) => Sim?.SetSpeed(index);
	void ZoomIn() => AdjustZoom(1);
	void ZoomOut() => AdjustZoom(-1);
	void AdjustZoom(int direction)
	{
		var next = Math.Clamp(ZoomIndex + direction, 0, Zooms.Length - 1);
		if ( next == ZoomIndex ) return;
		var center = ViewportCenter;
		var oldZoom = Zooms[ZoomIndex];
		var worldX = (center.x - PanX) / oldZoom;
		var worldY = (center.y - PanY) / oldZoom;
		ZoomIndex = next;
		var newZoom = Zooms[ZoomIndex];
		PanX = center.x - worldX * newZoom;
		PanY = center.y - worldY * newZoom;
	}

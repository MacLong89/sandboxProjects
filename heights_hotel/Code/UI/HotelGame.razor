@namespace HeightsHotel
@using System
@using System.Collections.Generic
@using System.Linq
@using Sandbox
@using Sandbox.UI
@inherits PanelComponent
@attribute [Title( "Hotel HUD" )]

<root class="hotel-root @(CompactHeight ? "compact-height" : "") @(SelectedCell is not null ? "has-inspector" : "") @(ActiveTab is not null ? "dock-open" : "")">
	@if ( Sim is null )
	{
		<div class="boot-screen">
			<strong>Heights Hotel</strong>
			<span>Starting front desk…</span>
		</div>
	}
	else
	{
	<div class="city-backdrop"></div>

	<aside class="left-rail">
		<div class="logo"></div>

		<section class="hud-panel rating-panel">
			<header>Hotel rating</header>
			<div class="rating-line">
				<div class="rating-star"></div>
				<strong>@RatingText</strong>
			</div>
			<div class="stars">@RatingStars</div>
			<div class="progress-track"><div class="progress-fill gold" style="width:@RatingPercent%;"></div></div>
			<div class="subline"><span>Reputation</span><span>@(Rep > 6 ? $"Prestige {Rep - 6}" : $"Level {Rep}")</span></div>
		</section>

		<section class="hud-panel guests-panel">
			<header>Guests</header>
			<div class="split"><strong>@OccupiedBeds/@GuestCapacity</strong><span>occupancy</span></div>
			<div class="income-label">Net / minute</div>
			<div class="daily-income @NetClass">@NetPerMin</div>
		</section>

		<section class="hud-panel goals-panel">
			<header>Today's goals</header>
			@foreach ( var goal in ActiveGoals.Take( 3 ) )
			{
				var progress = GoalProgressValue( goal );
				var pct = goal.Target <= 0 ? 0 : Math.Min( 100, progress * 100 / goal.Target );
				<div class="goal-row @(IsGoalDone( goal ) ? "complete" : "")">
					<span>@goal.Title</span><b>@FormatGoalProgress( goal )</b>
				</div>
				<div class="mini-track @(IsGoalDone( goal ) ? "complete" : "")"><div style="width:@pct%;"></div></div>
			}
		</section>

		<section class="hud-panel notifications-panel">
			<header>Notifications</header>
			@foreach ( var notice in Notifications )
			{
				<button class="notice" @onclick="@(() => HandleNotice( notice ))">
					<div class="notice-dot @notice.Kind"></div>
					<span>@notice.Text</span>
				</button>
			}
		</section>
	</aside>

	<div class="top-right">
		<div class="resources hud-panel">
			<div class="resource-row"><div class="resource-icon coin"></div><strong>@Money</strong></div>
			<div class="resource-row @NetClass"><div class="resource-icon income"></div><strong>@NetPerMin/min</strong></div>
			<div class="resource-row"><div class="resource-icon rep"></div><strong>Rep @Rep</strong></div>
		</div>
		<div class="clock hud-panel">
			<strong>DAY @Day</strong>
			<span>@ClockText</span>
			<div class="weather-row">
				<div class="weather-icon weather-@WeatherClass"></div>
				<span class="weather-label">@WeatherLabel</span>
			</div>
		</div>
		<div class="time-controls hud-panel">
			<button class="pause-control @SpeedClass(0)" Tooltip="Pause simulation" @onclick="@(() => SetSpeed(0))"></button>
			<button class="@SpeedClass(1)" Tooltip="Normal speed" @onclick="@(() => SetSpeed(1))">▶</button>
			<button class="speed-control @SpeedClass(2)" Tooltip="Fast speed" @onclick="@(() => SetSpeed(2))">2×</button>
			<button class="speed-control @SpeedClass(3)" Tooltip="Very fast speed" @onclick="@(() => SetSpeed(3))">4×</button>
			<div class="control-divider"></div>
			<button class="@(ZoomIndex == 0 ? "limit" : "")" Tooltip="Zoom out" @onclick="@ZoomOut">−</button>
			<button class="@(ZoomIndex == Zooms.Length - 1 ? "limit" : "")" Tooltip="Zoom in" @onclick="@ZoomIn">+</button>
		</div>
	</div>

	@if ( SelectedBuild is RoomType placing )
	{
		<div class="build-mode-banner">
			<strong>Placing @GameBalance.GetRoom(placing).DisplayName</strong>
			<span>Click a glowing plot · Build again to change type · Esc cancels</span>
			<button class="small" @onclick="@CancelBuild">Cancel</button>
		</div>
	}

	<main class="viewport @(_dragging ? "dragging" : "")"
		  onmousedown=@( ( MousePanelEvent e ) => OnViewMouseDown( e ) )
		  onmouseup=@( ( MousePanelEvent e ) => OnViewMouseUp( e ) )
		  onmousemove=@( ( MousePanelEvent e ) => OnViewMouseMove( e ) )>
		<div class="hotel-pan" style="@PanStyle">
		<div class="hotel-world" style="@ZoomStyle">
			<div class="hotel-shell" style="@HotelShellStyle">
				<div class="roof-lights"></div>
				<div class="rooftop-decor"></div>
				<div class="roof-sign">HEIGHTS HOTEL</div>
			</div>
			<div class="ground-line" style="@GroundStyle"></div>

			@foreach ( var floor in Floors )
			{
				<div class="floor-number" style="@FloorLabelStyle(floor)">@FloorNumber(floor)</div>
				<div class="elevator-segment" style="@ElevatorStyle(floor)">
					<div class="elevator-doors"></div>
				</div>
			}

			@foreach ( var cell in Cells )
			{
				var cx = cell.X;
				var cy = cell.Y;
				<div class="room-cell @RoomClass(cell) @RoomStateClass(cell) @(IsSelected(cell) ? "selected" : "")"
					 style="@CellStyle(cell)"
					 Tooltip="@RoomTooltip(cell)"
					 @onclick="@(() => SelectRoom(cx, cy))">
					<div class="room-level">Lv @cell.Level</div>
					@if ( cell.AssignedEmployeeId is int )
					{
						<div class="staff-pin"></div>
					}
					@if ( cell.Level > 1 )
					{
						<div class="overlay level-@cell.Level"></div>
					}
					@if ( cell.UnderConstruction )
					{
						<div class="overlay construction"></div>
						<div class="construction-dust"></div>
					}
					@if ( cell.Cleanliness < 0.65f )
					{
						<div class="overlay dirty"></div>
					}
					@if ( cell.Broken )
					{
						<div class="overlay broken"></div>
						<div class="repair-sparks"></div>
					}
					else if ( cell.OccupantGuestIds.Count > 0 && cell.Cleanliness >= 0.65f )
					{
						<div class="state-bubble bubble-happy"></div>
					}
					@if ( cell.Broken || NeedsCleaningAlert(cell) )
					{
						<div class="room-service-alerts">
							@if ( cell.Broken )
							{
								<div class="room-service-alert fix-alert">
									<div class="service-alert-icon bubble-broken"></div>
									<span>Fix</span>
								</div>
							}
							@if ( NeedsCleaningAlert(cell) )
							{
								<div class="room-service-alert clean-alert">
									<div class="service-alert-icon bubble-dirty"></div>
									<span>Clean</span>
								</div>
							}
						</div>
					}
					@if ( cell.Type == RoomType.Lobby && Guests.Any(g => g.Phase == GuestPhase.CheckingIn) )
					{
						<div class="state-bubble bubble-queue"></div>
					}
					@if ( cell.Type is RoomType.Cafe or RoomType.Restaurant )
					{
						<div class="ambient-steam"></div>
					}
					@if ( GameBalance.GetRoom(cell.Type).Category == RoomCategory.Amenity && cell.OccupantGuestIds.Count > 0 )
					{
						<div class="income-fx"></div>
					}
					<div class="room-label">@RoomLabel(cell)</div>
				</div>
			}

			@if ( BuildMode )
			{
				@foreach ( var spot in BuildSpots )
				{
					var sx = spot.X;
					var sy = spot.Y;
					<div class="room-cell preview" style="@GhostStyle(sx, sy)" @onclick="@(() => PlaceBuild(sx, sy))">
						<div class="build-plus">+</div>
					</div>
				}
			}

			@foreach ( var guest in Guests )
			{
				<div class="agent guest v@(guest.Variant) @(guest.FacingLeft ? "flip" : "") @GuestAnim(guest)"
					 style="@AgentStyle(guest.PosX, guest.PosY)">
					@if ( guest.Satisfaction >= 0.88f )
					{
						<div class="guest-heart"></div>
					}
				</div>
			}
			@foreach ( var employee in Employees )
			{
				<div class="agent employee @EmployeeClass(employee) @(employee.FacingLeft ? "flip" : "") @EmployeeAnim(employee)"
					 style="@AgentStyle(employee.PosX, employee.PosY)"></div>
			}
		</div>
		</div>
	</main>

	@if ( SelectedCell is GridCell selected )
	{
		<section class="room-inspector hud-panel">
			<button class="close" Tooltip="Close inspector" @onclick="@ClearSelection">×</button>
			<header>@RoomLabel(selected)</header>
			<div class="inspector-grid">
				<span>Level</span><b>@selected.Level/@GameBalance.MaxRoomLevel</b>
				<span>Clean</span><b>@Percent(selected.Cleanliness)</b>
				<span>Guests</span><b>@selected.OccupantGuestIds.Count/@Capacity(selected)</b>
				<span>Staff</span><b>@AssignedStaffName(selected)</b>
			</div>
			@if ( selected.Broken )
			{
				<div class="warning">Needs maintenance</div>
			}
			<div class="service-actions">
				@if ( GameBalance.GetRoom(selected.Type).Category == RoomCategory.Lodging && selected.Cleanliness < 0.95f )
				{
					<button class="service clean-service" Tooltip="Send an available housekeeper" @onclick="@DispatchClean">Clean</button>
				}
				@if ( selected.Broken )
				{
					<button class="service fix-service" Tooltip="Send an available maintenance worker" @onclick="@DispatchFix">Fix</button>
				}
				@if ( selected.Type is RoomType.Cafe or RoomType.Restaurant )
				{
					<button class="service cook-service" Tooltip="Send an available cook" @onclick="@DispatchCook">Staff kitchen</button>
				}
				@foreach ( var staff in CompatibleStaff(selected) )
				{
					var role = staff.Role;
					<button class="service staff-service"
							Tooltip="@($"Permanently assign an idle {staff.DisplayName}")"
							@onclick="@(() => AutoAssignStaff(role))">
						Assign @staff.DisplayName
					</button>
				}
			</div>
			@if ( selected.Type != RoomType.Lobby && selected.Level < GameBalance.MaxRoomLevel )
			{
				<div class="upgrade-preview">@UpgradePreview(selected)</div>
				<button class="primary @(ConfirmUpgrade ? "confirm" : "") @(!CanAffordUpgrade(selected) ? "unaffordable" : "")"
						Tooltip="@(!CanAffordUpgrade(selected) ? "Not enough cash" : "Preview, then confirm this upgrade")"
						@onclick="@RequestUpgrade">
					@(ConfirmUpgrade ? "Confirm upgrade" : "Upgrade") · @HotelSimulation.FormatMoney(GameBalance.UpgradeCost(selected.Type, selected.Level))
				</button>
			}
			@if ( selected.Type != RoomType.Lobby )
			{
				<button class="danger demolish @(ConfirmDemolish ? "confirm" : "")"
						Tooltip="Refunds part of the build cost. Cannot disconnect the hotel."
						@onclick="@RequestDemolish">
					@(ConfirmDemolish ? "Confirm demolish" : "Demolish") · @HotelSimulation.FormatMoney(GameBalance.DemolishRefund(selected.Type, selected.Level, RoomCount))
				</button>
			}
		</section>
	}

	@if ( ActiveTab is not null )
	{
		<section class="management-dock tab-@ActiveTab hud-panel">
			<div class="dock-heading">
				<header>@TabTitle</header>
				<button class="close" Tooltip="Close management" @onclick="@CloseDock">×</button>
			</div>

			@if ( ActiveTab == "build" )
			{
				<div class="card-grid">
					@foreach ( var room in AllBuildRooms )
					{
						var type = room.Type;
						<button class="management-card @(SelectedBuild == type ? "active" : "") @(!CanAffordBuild(type) && IsRoomUnlocked(type) ? "unaffordable" : "") @(!IsRoomUnlocked(type) ? "locked" : "")"
								Tooltip="@BuildTooltip(room)"
								@onclick="@(() => SelectBuild(type))">
							@if ( SelectedBuild == type )
							{
								<div class="selection-check">✓</div>
							}
							<div class="card-icon @IconClass(type)"></div>
							<div class="card-copy">
								<b>@room.DisplayName</b>
								<span>@(IsRoomUnlocked(type) ? FormatCost(type) : $"Rep {room.UnlockReputation}")</span>
								<small>@RoomEffect(room)</small>
							</div>
							@if ( !IsRoomUnlocked(type) )
							{
								<div class="lock-icon"></div>
							}
						</button>
					}
				</div>
				<div class="dock-help">Choose a room, then select a glowing adjacent cell.</div>
			}
			else if ( ActiveTab == "rooms" )
			{
				<div class="list-scroll">
					@foreach ( var room in Cells.OrderByDescending(c => c.Y).ThenBy(c => c.X) )
					{
						var x = room.X;
						var y = room.Y;
						<button class="list-row @(IsSelected(room) ? "active" : "")" @onclick="@(() => SelectRoom(x, y))">
							<span>@RoomLabel(room) · Floor @(room.Y + 1)</span>
							<span>@Percent(room.Cleanliness) clean · @room.OccupantGuestIds.Count guests</span>
						</button>
					}
				</div>
			}
			else if ( ActiveTab == "staff" )
			{
				@if ( SelectedCell is GridCell targetRoom )
				{
					<div class="staff-target-banner">
						<span>Assignment target:</span>
						<strong>@RoomLabel(targetRoom) · Floor @(targetRoom.Y + 1)</strong>
						<span>Pick an employee below and click Assign here.</span>
					</div>
				}
				<div class="staff-columns">
					<div class="hire-strip">
						<h3>Hire staff</h3>
						<div class="hire-grid">
							@foreach ( var staff in AllStaffRoles )
							{
								var role = staff.Role;
								var unlocked = IsStaffUnlocked(role);
								var canAfford = unlocked && CanAffordHire(role);
								<button class="hire-card @(!unlocked ? "locked" : "") @(!canAfford && unlocked ? "unaffordable" : "")"
										Tooltip="@HireTooltip(staff)"
										@onclick="@(() => Hire(role))">
									<div class="hire-card-heading">
										<strong>@staff.DisplayName</strong>
										@if ( !unlocked )
										{
											<span class="hire-action locked-action">Rep @staff.UnlockReputation</span>
										}
										else
										{
											<span class="hire-action">Hire</span>
										}
									</div>
									<span class="hire-cost">@HotelSimulation.FormatMoney(staff.HireCostCents)</span>
									<span class="hire-wage">@HotelSimulation.FormatMoney(staff.WagePerMinuteCents)/min</span>
								</button>
							}
						</div>
					</div>
					<div class="staff-roster">
						<h3>Roster (@Employees.Count())</h3>
						<div class="staff-grid">
							@foreach ( var employee in Employees )
							{
								var id = employee.Id;
								<div class="staff-card @(SelectedEmployeeId == id ? "selected" : "")">
									@if ( SelectedEmployeeId == id )
									{
										<div class="selection-check staff-check">✓</div>
									}
									<div class="staff-portrait @EmployeeClass(employee)" @onclick="@(() => SelectEmployee(id))"></div>
									<div class="staff-info" @onclick="@(() => SelectEmployee(id))">
										<b>@employee.Name</b>
										<span>@employee.Role · @employee.Task</span>
										<span>@EmployeeAssignment(employee)</span>
									</div>
									<div class="staff-actions">
										@if ( SelectedCell is GridCell assignmentRoom
											&& GameBalance.CanAssignStaff(employee.Role, assignmentRoom.Type) )
										{
											<button class="small" @onclick="@(() => AssignEmployee(id))">Assign here</button>
										}
										else if ( SelectedCell is not null )
										{
											<button class="small incompatible" disabled>Incompatible</button>
										}
										<button class="small muted-button" @onclick="@(() => UnassignEmployee(id))">General</button>
										<button class="small danger @(PendingFireId == id ? "confirm" : "")" @onclick="@(() => RequestFire(id))">
											@(PendingFireId == id ? "Confirm" : "Fire")
										</button>
									</div>
								</div>
							}
							@if ( !Employees.Any() )
							{
								<div class="empty">No staff yet — hire someone on the left.</div>
							}
						</div>
					</div>
				</div>
			}
			else if ( ActiveTab == "guests" )
			{
				<div class="list-scroll">
					@foreach ( var guest in Guests )
					{
						<div class="list-row guest-row">
							<span>@guest.Name · @guest.Phase</span>
							<span>@GuestDetail( guest )</span>
						</div>
					}
					@if ( !Guests.Any() )
					{
						<div class="empty">Build lodging and guests will arrive.</div>
					}
				</div>
			}
			else if ( ActiveTab == "goals" )
			{
				<div class="goal-cards">
					@foreach ( var goal in ActiveGoals )
					{
						var progress = GoalProgressValue( goal );
						<div class="goal-card @(IsGoalDone( goal ) ? "complete" : "") @(goal.Claimed ? "claimed" : "")">
							<b>@goal.Title</b>
							<span>@goal.Description</span>
							<strong>@FormatGoalProgress( goal )</strong>
							@if ( goal.Claimed )
							{
								<small class="claimed-label">Claimed</small>
							}
							else if ( IsGoalDone( goal ) )
							{
								<button class="small primary" @onclick="@(() => ClaimGoal( goal.Id ))">
									Claim @HotelSimulation.FormatMoney( goal.RewardCents )
								</button>
							}
							else
							{
								<small>Reward @HotelSimulation.FormatMoney( goal.RewardCents )</small>
							}
						</div>
					}
				</div>
			}
			else if ( ActiveTab == "stats" )
			{
				<div class="stats-grid">
					<div><span>Cash</span><strong>@Money</strong></div>
					<div><span>Lifetime income</span><strong>@LifetimeIncome</strong></div>
					<div><span>Lifetime expenses</span><strong>@LifetimeExpenses</strong></div>
					<div><span>Lifetime profit</span><strong>@LifetimeProfit</strong></div>
					<div><span>Wages / minute</span><strong>@WagesPerMinute</strong></div>
					<div><span>Upkeep / minute</span><strong>@UpkeepPerMinute</strong></div>
					<div><span>Hotel value</span><strong>@HotelValue</strong></div>
					<div><span>Occupancy</span><strong>@OccupancyPct%</strong></div>
					<div><span>Satisfaction</span><strong>@SatisfactionPct%</strong></div>
				</div>
				<div class="ledger">
					@foreach ( var entry in Ledger )
					{
						<div class="ledger-row @(entry.DeltaCents < 0 ? "negative" : "positive")">
							<span>@entry.Label</span><b>@HotelSimulation.FormatMoney(entry.DeltaCents)</b>
						</div>
					}
				</div>
			}
			else if ( ActiveTab == "menu" )
			{
				<div class="menu-actions">
					<button class="primary" Tooltip="Write a manual save" @onclick="@SaveNow">Save now</button>
					<button Tooltip="Fit the hotel in view" @onclick="@CenterHotel">Center hotel</button>
					<button class="danger @(ConfirmNewGame ? "confirm" : "")"
							Tooltip="Wipe the current hotel and start fresh"
							@onclick="@RequestNewGame">
						@(ConfirmNewGame ? "Confirm new game" : "New game")
					</button>
					<div class="save-note">Autosaves every 30 seconds and after management actions. Weather, daily goals, and soft prestige carry in saves.</div>
				</div>
			}
		</section>
	}

	<nav class="bottom-nav">
		@foreach ( var tab in Tabs )
		{
			var id = tab.Id;
			<button class="nav-button @(ActiveTab == id || (id == "build" && BuildMode) ? "active" : "")" Tooltip="@($"{tab.Label} management")" @onclick="@(() => ToggleTab(id))">
				<div class="nav-icon @tab.Icon"></div>
				<span>@tab.Label</span>
				@if ( ActiveTab == id || (id == "build" && BuildMode) )
				{
					<div class="selection-pip"></div>
				}
			</button>
		}
	</nav>

	@if ( !string.IsNullOrWhiteSpace(ToastStatus) )
	{
		<div class="toast">@ToastStatus</div>
	}

	@if ( !string.IsNullOrWhiteSpace(Tutorial) )
	{
		<div class="tutorial hud-panel">
			<strong>Manager tip</strong>
			<span>@TutorialText</span>
			<button class="primary" @onclick="@DismissTutorial">Got it</button>
		</div>
	}
	}
</root>

@code
{
	HotelGameManager Mgr => HotelGameManager.Instance;
	HotelSimulation Sim => Mgr?.Sim;

	readonly (string Id, string Label, string Icon)[] Tabs =
	{
		("build", "Build", "build"),
		("rooms", "Rooms", "rooms"),
		("staff", "Staff", "staff"),
		("guests", "Guests", "guests"),
		("goals", "Goals", "goals"),
		("stats", "Stats", "stats"),
		("menu", "Menu", "menu")
	};

	string ActiveTab;
	RoomType? SelectedBuild;
	int? SelectedX;
	int? SelectedY;
	int? SelectedEmployeeId;
	int? PendingFireId;
	bool ConfirmUpgrade;
	bool ConfirmDemolish;
	bool ConfirmNewGame;
	bool BuildMode => SelectedBuild.HasValue;
	bool CompactHeight => HudHeight < 700f;
	float PanX = 200;
	float PanY = 400;
	int ZoomIndex = 2;
	static readonly float[] Zooms = { 0.75f, 1f, 1.25f, 1.5f, 2f };
	const float ViewportLeftInset = 328f;
	const float ViewportBottomInset = 100f;
	const float GroundPad = 12f;
	bool _dragging;
	bool _panPending;
	bool _initialCentered;
	Vector2 _lastMouse;
	Vector2 _mouseDownPosition;
	float _suppressClickUntil;
	string _observedStatus;
	int _observedStatusRevision = -1;
	float _toastUntil;
	bool _toastVisible;
	int _localRevision;
	int _lastScreenWidth;
	int _lastScreenHeight;

	protected override int BuildHash()
	{
		var state = Sim?.State;
		if ( state is null ) return HashCode.Combine( 1, _localRevision );
		var stateHash = HashCode.Combine(
			state.CashCents,
			(int)(state.SimTime * 4),
			state.Cells.Count,
			state.Guests.Count,
			state.Employees.Count,
			state.Revision
		);
		var interactionHash = HashCode.Combine(
			SelectedX,
			SelectedY,
			SelectedEmployeeId,
			ZoomIndex,
			ConfirmUpgrade,
			PendingFireId,
			(int)PanX,
			(int)PanY
		);
		return HashCode.Combine(stateHash, ActiveTab, SelectedBuild, interactionHash, _localRevision);
	}

	protected override void OnStart()
	{
		Log.Info( $"[HeightsHotel] HotelGame OnStart sim={(Sim is not null)} panel={(Panel is not null)} size={Panel?.Box?.Rect}" );
	}

	protected override void OnUpdate()
	{
		base.OnUpdate();
		Mouse.Visibility = MouseVisibility.Visible;
		if ( Sim is not null )
		{
			var screenW = (int)HudWidth;
			var screenH = (int)HudHeight;
			// Wait until the ScreenPanel reports a real size — centering on a
			// 0×0 first frame parks the lobby near the top of the sky.
			if ( screenW >= 100 && screenH >= 100 )
			{
				if ( !_initialCentered )
				{
					_initialCentered = true;
					if ( screenW <= 900 )
						ZoomIndex = Math.Min( ZoomIndex, 2 );
					CenterHotel();
					_lastScreenWidth = screenW;
					_lastScreenHeight = screenH;
				}
				else if ( screenW != _lastScreenWidth || screenH != _lastScreenHeight )
				{
					_lastScreenWidth = screenW;
					_lastScreenHeight = screenH;
					CenterHotel();
				}
			}
		}
		if ( Status != _observedStatus || (Sim?.State.StatusRevision ?? 0) != _observedStatusRevision )
		{
			_observedStatus = Status;
			_observedStatusRevision = Sim?.State.StatusRevision ?? 0;
			if ( !string.IsNullOrWhiteSpace(Status) )
			{
				_toastUntil = Time.Now + 4f;
				_toastVisible = true;
				_localRevision++;
			}
		}
		if ( _dragging && !Input.Down("Attack1") )
		{
			_dragging = false;
			_panPending = false;
		}
		if ( EscapePressed() )
			HandleEscape();
		if ( _toastVisible && Time.Now >= _toastUntil )
		{
			_toastVisible = false;
			_localRevision++;
		}
		var wheel = Input.MouseWheel.y;
		if ( ActiveTab is null )
		{
			if ( wheel > 0 ) ZoomIn();
			else if ( wheel < 0 ) ZoomOut();
		}
	}


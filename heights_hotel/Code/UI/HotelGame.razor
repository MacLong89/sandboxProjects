				yield return ("info", "Guests are waiting at reception", "queue");
			if ( ActiveGoals.Any( g => IsGoalDone( g ) && !g.Claimed ) )
				yield return ("good", "Daily goal ready to claim", "goals");
			if ( !Cells.Any(c => c.Broken || c.Cleanliness < 0.65f) && !Guests.Any(g => g.Phase == GuestPhase.CheckingIn) )
				yield return ("good", "Hotel operations are running smoothly", null);

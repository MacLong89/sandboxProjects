	{
		if ( SelectedX is not int x || SelectedY is not int y || Mgr is null )
			return;
		var result = Mgr.DispatchService( role, x, y );
		if ( result.Ok )
			return;

		Sim?.ShowStatus( result.Message );
		if ( !Employees.Any( e => e.Role == role ) )
			ActiveTab = "staff";
	}

	void AutoAssignStaff(StaffRole role)
	{
		if ( Mgr is null || SelectedX is not int x || SelectedY is not int y )
			return;

		var result = Mgr.AutoAssign( x, y, out var noAvailableStaff, role );
		if ( result.Ok )
		{
			ActiveTab = null;
			SelectedEmployeeId = null;
			if ( !string.IsNullOrWhiteSpace( result.Message ) )
				Sim?.ShowStatus( result.Message );
			return;
		}

		Sim?.ShowStatus( result.Message );
		if ( noAvailableStaff )
		{
			ActiveTab = "staff";
			SelectedEmployeeId = null;
		}
	}


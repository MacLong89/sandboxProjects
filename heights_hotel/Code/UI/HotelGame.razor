	void RequestNewGame()
	{
		if ( !ConfirmNewGame )
		{
			ConfirmNewGame = true;
			return;
		}
		Mgr?.StartNewGame();
		ConfirmNewGame = false;
		ActiveTab = null;
		ClearSelection();
		_initialCentered = false;
	}

	void HandleNotice( (string Kind, string Text, string Action) notice )
	{
		if ( string.IsNullOrEmpty( notice.Action ) )
			return;
		switch ( notice.Action )
		{
			case "broken":
			{
				var room = Cells.FirstOrDefault( c => c.Broken );
				if ( room is not null ) SelectRoom( room.X, room.Y );
				ActiveTab = "staff";
				break;
			}
			case "dirty":
			{
				var room = Cells.Where( c => c.Cleanliness < 0.65f ).OrderBy( c => c.Cleanliness ).FirstOrDefault();
				if ( room is not null ) SelectRoom( room.X, room.Y );
				ActiveTab = "staff";
				break;
			}
			case "queue":
				SelectRoom( 0, 0 );
				ActiveTab = "guests";
				break;
			case "goals":
				ActiveTab = "goals";
				break;
		}
	}

	void Hire(StaffRole role)
	{
		if ( Mgr is null ) return;
		if ( !IsStaffUnlocked(role) )
		{
			var def = GameBalance.GetStaff(role);
			Sim?.ShowStatus($"{def.DisplayName} unlocks at reputation {def.UnlockReputation}.");
			return;
		}
		var result = Mgr.Hire(role);
		if ( !result.Ok ) Sim.ShowStatus(result.Message);
	}

	void RequestFire(int id)
	{
		if ( PendingFireId != id )
		{
			PendingFireId = id;
			return;
		}
		Mgr?.Fire(id);
		PendingFireId = null;
	}
	void SelectEmployee(int id) => SelectedEmployeeId = id;

	void AssignEmployee(int id)
	{
		if ( Mgr is null || SelectedX is not int x || SelectedY is not int y ) return;
		var result = Mgr.Assign(id, x, y);
		if ( !result.Ok ) Sim.ShowStatus(result.Message);
	}

	void UnassignEmployee(int id)
	{
		if ( Mgr is null ) return;
		var result = Mgr.Unassign(id);
		if ( !result.Ok ) Sim.ShowStatus(result.Message);
	}

	void DismissTutorial() => Sim?.DismissTutorial();

	void OnViewMouseDown(MousePanelEvent e)
	{
		_panPending = true;
		_dragging = false;
		_mouseDownPosition = Mouse.Position;
		_lastMouse = _mouseDownPosition;
	}

	void OnViewMouseUp(MousePanelEvent e)
	{
		if ( _dragging )
			_suppressClickUntil = Time.Now + 0.12f;
		_panPending = false;
		_dragging = false;
	}

	void OnViewMouseMove(MousePanelEvent e)
	{
		var position = Mouse.Position;
		var delta = position - _lastMouse;
		_lastMouse = position;
		if ( _panPending && !_dragging && (position - _mouseDownPosition).Length > 5f )
			_dragging = true;
		if ( !_dragging ) return;
		PanX += delta.x;
		PanY += delta.y;
	}
}

	/// <summary>
	/// Size of the play viewport in local pixels. Pan/zoom live inside
	/// <c>.viewport</c>, which is already inset from the left rail and nav —
	/// so these are NOT full-screen coordinates.
	/// </summary>
	Vector2 ViewportSize
	{
		get
		{
			var bottom = CompactHeight ? 96f : ViewportBottomInset;
			return new(
				Math.Max( 200f, HudWidth - ViewportLeftInset ),
				Math.Max( 200f, HudHeight - bottom )
			);
		}
	}
	Vector2 ViewportCenter
	{
		get
		{
			var size = ViewportSize;
			// Match CenterHotel: horizontal middle of the full screen, in viewport space.
			return new( HudWidth * 0.5f - ViewportLeftInset, size.y * 0.5f );
		}
	}
	void CenterHotel()
	{
		var zoom = Zooms[ZoomIndex];
		var size = ViewportSize;
		// Center the room block itself (not floor-label gutters — those pull the lobby right).
		var worldCenterX = (MinX * GameBalance.CellWidth + (MaxX + 1) * GameBalance.CellWidth) * 0.5f;
		var groundY = GameBalance.CellHeight;

		// Aim at the true horizontal middle of the full HUD, expressed in viewport-local coords.
		// (Play-area-only centering sits the hotel too far right beside the left rail.)
		var screenCenterInViewport = HudWidth * 0.5f - ViewportLeftInset;
		PanX = screenCenterInViewport - worldCenterX * zoom;
		// Sit ground floor flush above the bottom nav.
		PanY = size.y - GroundPad - groundY * zoom;
	}
	void SaveNow() { Mgr?.TrySave(); Sim?.ShowStatus("Hotel saved."); }

	void SelectBuild(RoomType type)
	{
		if ( !IsRoomUnlocked(type) )
		{
			Sim?.ShowStatus($"{GameBalance.GetRoom(type).DisplayName} unlocks at reputation {GameBalance.GetRoom(type).UnlockReputation}.");
			return;
		}
		if ( !CanAffordBuild(type) )
		{
			Sim?.ShowStatus($"Not enough cash to build {GameBalance.GetRoom(type).DisplayName}.");
			return;
		}

		if ( SelectedBuild == type )
		{
			// Toggle off — reopen the build dock.
			SelectedBuild = null;
			ActiveTab = "build";
			return;
		}

		SelectedBuild = type;
		SelectedX = SelectedY = null;
		// Close the picker so glowing plots are clickable.
		ActiveTab = null;
		CenterHotel();
		Sim?.ShowStatus( $"Placing {GameBalance.GetRoom( type ).DisplayName} — click a glowing plot." );
	}

	void SelectRoom(int x, int y)
	{
		if ( Time.Now < _suppressClickUntil ) return;
		SelectedX = x;
		SelectedY = y;
		SelectedBuild = null;
		ConfirmUpgrade = false;
		ConfirmDemolish = false;
	}

	void ClearSelection() { SelectedX = SelectedY = null; ConfirmUpgrade = false; ConfirmDemolish = false; }

	void PlaceBuild(int x, int y)
	{
		if ( Time.Now < _suppressClickUntil ) return;
		if ( SelectedBuild is not RoomType type || Mgr is null ) return;
		var result = Mgr.Build(type, x, y);
		if ( !result.Ok ) Sim.ShowStatus(result.Message);
		else
		{
			// Stay in placement mode so multiple rooms can be laid quickly.
			SelectedX = SelectedY = null;
			Sim?.ShowStatus( $"Built {GameBalance.GetRoom( type ).DisplayName}. Click another plot or Cancel." );
		}
	}

	void UpgradeSelected()
	{
		if ( SelectedX is not int x || SelectedY is not int y || Mgr is null ) return;
		var result = Mgr.Upgrade(x, y);
		if ( !result.Ok ) Sim.ShowStatus(result.Message);
		ConfirmUpgrade = false;
	}

	void RequestUpgrade()
	{
		if ( SelectedCell is GridCell cell && !CanAffordUpgrade(cell) )
		{
			Sim?.ShowStatus("Not enough cash for this upgrade.");
			return;
		}
		if ( !ConfirmUpgrade )
		{
			ConfirmUpgrade = true;
			ConfirmDemolish = false;
			return;
		}
		UpgradeSelected();
	}

	void RequestDemolish()
	{
		if ( SelectedCell is null || SelectedCell.Type == RoomType.Lobby )
			return;
		if ( !ConfirmDemolish )
		{
			ConfirmDemolish = true;
			ConfirmUpgrade = false;
			return;
		}
		if ( SelectedX is not int x || SelectedY is not int y || Mgr is null ) return;
		var result = Mgr.Demolish( x, y );
		if ( !result.Ok ) Sim?.ShowStatus( result.Message );
		else ClearSelection();
		ConfirmDemolish = false;
	}


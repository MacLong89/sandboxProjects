@using Sandbox
@using Sandbox.UI
@using Fauna2
@inherits PanelComponent
@namespace Fauna2.UI

@* Center-screen coach tips — high z-index so HudRoot / catch UI cannot bury clicks. *@
<root class="@(HasTip ? "visible" : "")">
	@if ( HasTip )
	{
		var tip = UiState.ActiveOnboardingTip;
		<div class="tip-overlay">
			<div class="tutorial-tip">
				<i class="icon tip-icon">@tip.Icon</i>
				<div class="tip-title">@tip.Title</div>
				<div class="tip-body">
					@foreach ( var block in BodyBlocks )
					{
						<div class="tip-para">@block</div>
					}
				</div>
				<div class="tip-actions">
					<div class="btn ghost" onclick=@( () => HideTips() )>
						<i class="icon">visibility_off</i><span>Hide tips</span>
					</div>
					@if ( tip.OpenAction != ObjectiveAction.None )
					{
						<div class="btn secondary" onclick=@( () => OpenTool() )>@tip.ActionLabel</div>
					}
					<div class="btn primary" onclick=@( () => Dismiss() )>Got it</div>
				</div>
			</div>
		</div>
	}
</root>

@code
{
	private bool HasTip => UiState.ActiveOnboardingTip is not null;

	private List<string> BodyBlocks
	{
		get
		{
			var body = UiState.ActiveOnboardingTip?.Body;
			var blocks = new List<string>();
			if ( string.IsNullOrWhiteSpace( body ) )
				return blocks;

			foreach ( var part in body.Replace( "\r\n", "\n" ).Split( "\n\n", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries ) )
				blocks.Add( part );

			return blocks;
		}
	}

	private void Dismiss() => UiState.DismissOnboardingTip();
	private void OpenTool() => UiState.OpenOnboardingTipTool();
	private void HideTips() => UiState.HideOnboardingTips();

	protected override void OnUpdate()
	{
		if ( Panel is null )
			return;

		// Explicit hit-testing — CSS pointer-events alone is flaky across sibling ScreenPanel roots.
		Panel.Style.PointerEvents = HasTip ? PointerEvents.All : PointerEvents.None;
		Panel.Style.ZIndex = 900;
	}

	protected override int BuildHash() => System.HashCode.Combine(
		UiState.ActiveOnboardingTip?.Id,
		UiState.ActiveOnboardingTip?.Title,
		UiState.ActiveOnboardingTip?.Body,
		UiState.ActiveOnboardingTip?.ActionLabel,
		UiState.Revision );
}

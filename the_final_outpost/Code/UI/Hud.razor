					<div class="welcome-loot">
						@if ( Core.Welcome.Scrap > 0 )
						{
							<div class="loot-row"><i class="icon">recycling</i><span>@Format(Core.Welcome.Scrap) scrap</span></div>
						}
						@if ( Core.Welcome.Wood > 0 )
						{
							<div class="loot-row"><i class="icon">park</i><span>@Core.Welcome.Wood wood</span></div>
						}
						@if ( Core.Welcome.Stone > 0 )
						{
							<div class="loot-row"><i class="icon">landscape</i><span>@Core.Welcome.Stone stone</span></div>
						}
						@if ( Core.Welcome.Water > 0 )
						{
							<div class="loot-row"><i class="icon">water_drop</i><span>@Core.Welcome.Water water</span></div>

				</div>
			</div>
		}

		@if ( Core is not null && !SettingsOpen && (Phase == GamePhase.MainMenu || Phase == GamePhase.GameOver || Phase == GamePhase.NightRecap || Phase == GamePhase.SeasonRecap || Phase == GamePhase.Victory) )

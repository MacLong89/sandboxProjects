				<div class="meta-btn sm" onclick=@OpenSettings title="Settings">
					<i class="icon">settings</i>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.MainMenu && !ShopOpen && !SettingsOpen && !LeaderboardOpen && !ConfirmReset && !TeamPickerOpen && !WelcomePending && !DailyPending )
		{
			<div class="overlay">
				<div class="modal menu wide-menu">
					<div class="brand">
						<div class="brand-title">THE FINAL OUTPOST</div>
					</div>

					<div class="mode-section">
						<div class="mode-head">Survival</div>
						<div class="mode-sub">Build by day. Defend by night. Survive as long as you can.</div>
						<div class="btn-col">
							@if ( CanContinueSurvival )
							{
								<div class="btn primary lg" onclick=@ContinueSurvival><i class="icon">play_arrow</i><span>Continue Survival</span></div>
							}
							<div class="btn lg" onclick=@AskStartSurvival><i class="icon">flag</i><span>Start New Survival</span></div>
							<div class="btn lg" onclick=@OpenLeaderboard><i class="icon">leaderboard</i><span>Survival Leaderboard</span></div>
						</div>
					</div>

					<div class="mode-section">
						<div class="mode-head">
							<span>Road to a Cure</span>
							<span class="mode-dev-warn">- IN DEVELOPMENT!!! THINGS WILL BE VERY BROKEN!</span>
						</div>
						<div class="mode-sub">Grow your colony through the seasons. Research the cure before winter breaks you.</div>
						<div class="btn-col">
							@if ( CanContinueCure )
							{
								<div class="btn primary lg" onclick=@ContinueCure><i class="icon">play_arrow</i><span>Continue Road to a Cure</span></div>
							}
							<div class="btn lg" onclick=@AskStartCure><i class="icon">science</i><span>Start New Road to a Cure</span></div>
						</div>
					</div>
				</div>
			</div>
		}

		@if ( TeamPickerOpen )
		{
			<div class="overlay">
				<div class="modal wide">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Choose Your Team</div>
							<div class="modal-sub">Specialists are locked in for this run. Select one, then begin.</div>
						</div>
						<div class="sel-close" onclick=@CancelTeamPicker><i class="icon">close</i></div>
					</div>
					<div class="list team-list">
						@foreach ( var team in CureTeamCatalog.All )
						{
							var selected = _pickedTeam == team.Id;
							<div class="row team-pick-row @(selected ? "picked" : "")" onclick=@(() => PickTeam(team.Id))>
								<div class="row-icon-wrap"><i class="icon">@team.Icon</i></div>
								<div class="row-text">
									<div class="row-name">@team.Name</div>
									<div class="row-desc">@team.Description</div>
								</div>
								<div class="team-pick-check @(selected ? "on" : "")">
									<i class="icon">@(selected ? "check_circle" : "radio_button_unchecked")</i>
								</div>
							</div>
						}
					</div>
					<div class="team-pick-actions">
						<div class="btn" onclick=@CancelTeamPicker><span>Cancel</span></div>
						<div class="btn primary lg @(_pickedTeam == CureTeamId.None ? "disabled" : "")" onclick=@ConfirmTeamPicker><span>Begin Run</span></div>
					</div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.GameOver && !ShopOpen && !SettingsOpen && !LeaderboardOpen && !ConfirmReset && !WelcomePending && !DailyPending )
		{
			<div class="overlay">
				<div class="modal menu">
					@if ( IsCure )
					{
						<div class="brand">
							<div class="brand-title wrecked">COLONY FALLEN</div>
							<div class="brand-sub">Your settlement fell — retry from the start of Year @Core.CheckpointYear · @CureConstants.SeasonName(Core.CheckpointSeason)</div>
						</div>
						<div class="btn-col">
							<div class="btn primary lg" onclick=@RetrySeason><i class="icon">replay</i><span>Retry Season</span></div>
							<div class="btn" onclick=@GoMenu><i class="icon">home</i><span>Main Menu</span></div>
						</div>
					}
					else
					{
					<div class="brand">
						<div class="brand-title wrecked">OUTPOST FALLEN</div>
						<div class="brand-sub">Your command post is gone — scrap, upgrades, buildings, and defenders are permanently lost.</div>
					</div>

					<div class="stat-grid">
						<div class="stat-cell">
							<span class="cell-k">Reached</span>
							<span class="cell-v">Night @Core.LastNightReached</span>
						</div>
						<div class="stat-cell">
							<span class="cell-k">Best Night</span>
							<span class="cell-v">@Core.Save.BestNight</span>
						</div>
					</div>

					<div class="btn-col">
						<div class="btn primary lg" onclick=@StartDay><i class="icon">restart_alt</i><span>Start Over</span></div>
						<div class="btn" onclick=@OpenLeaderboard><i class="icon">leaderboard</i><span>Leaderboard</span></div>
					</div>
					}
				</div>
			</div>
		}

		@if ( Phase == GamePhase.Victory && !ShopOpen && !SettingsOpen )
		{
			<div class="overlay">
				<div class="modal menu">
					<div class="brand">
						<div class="brand-title">CURE COMPLETE</div>
						<div class="brand-sub">Your colony survived @Core.Save.CurrentYear years and perfected the antidote.</div>
					</div>
					<div class="stat-grid">
						<div class="stat-cell">
							<span class="cell-k">Research Tier</span>
							<span class="cell-v">@Core.Save.CureResearchTier</span>
						</div>
						<div class="stat-cell">
							<span class="cell-k">Threats Survived</span>
							<span class="cell-v">@Core.Save.TotalThreatsSurvived</span>
						</div>
					</div>
					<div class="btn-col">
						<div class="btn primary lg" onclick=@GoMenu><i class="icon">home</i><span>Main Menu</span></div>
					</div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.SeasonRecap && !ShopOpen && !SettingsOpen )
		{
			<div class="overlay">
				<div class="modal confirm">
					<i class="icon confirm-icon">calendar_month</i>
					<div class="confirm-title">Season Complete</div>
					<div class="confirm-body">@Core.PendingSeasonRecap</div>
					<div class="btn primary" onclick=@DismissSeasonRecap><span>Continue</span></div>
				</div>
			</div>
		}

		@if ( ConfirmReset )
		{
			<div class="overlay">
				<div class="modal confirm">
					<i class="icon confirm-icon">warning</i>
					<div class="confirm-title">@ConfirmResetTitle</div>
					<div class="confirm-body">@ConfirmResetBody</div>
					<div class="btn-row">
						<div class="btn" onclick=@CancelReset><span>Cancel</span></div>
						<div class="btn warn" onclick=@DoReset><i class="icon">delete_forever</i><span>Wipe & Restart</span></div>
					</div>
				</div>
			</div>
		}

		@if ( TechTreeOpen )
		{
			<div class="overlay">
				<div class="modal wide">
					<div class="modal-head">
						<div class="modal-title">Tech Tree</div>
						<div class="modal-sub">Knowledge @Knowledge · Scrap @Format(Core?.Wallet.Scrap ?? 0)</div>
						<div class="sel-close" onclick=@CloseTechTree><i class="icon">close</i></div>
					</div>
					<div class="list">
						@foreach ( var node in TechTreeCatalog.All )
						{
							var unlocked = TechTreeCatalog.IsUnlocked( Core.Save, node.Id );
							var canResearch = !unlocked && TechTreeCatalog.CanResearch( Core, node );
							<div class="row @(unlocked ? "maxed" : canResearch ? "afford" : "poor")" onclick=@(() => ResearchTech(node.Id))>
								<div class="row-icon-wrap"><i class="icon">@node.Icon</i></div>
								<div class="row-text">
									<div class="row-name">@node.Name</div>
									<div class="row-desc">@node.Description</div>
									<div class="row-now">Season @node.RequiredSeason+ · @node.KnowledgeCost.ToString("0") Knowledge@(node.ScrapCost > 0 ? $" · {Format(node.ScrapCost)} Scrap" : "")</div>
								</div>
								<div class="row-cost">@(unlocked ? "DONE" : canResearch ? "Research" : "Locked")</div>
							</div>
						}
					</div>
					<div class="btn wide-btn" onclick=@CloseTechTree><span>Close</span></div>
				</div>
			</div>
		}

		@if ( CureProgressOpen )
		{
			<div class="overlay">
				<div class="modal wide">
					<div class="modal-head">
						<div class="modal-title">Cure Research</div>
						<div class="modal-sub">Lab @CureResearch.LabCount(Core) · @CureResearch.LabOutputPerSec(Core).ToString("0.0") pts/s</div>
						<div class="sel-close" onclick=@CloseCureProgress><i class="icon">close</i></div>
					</div>
					<div class="list">
						@foreach ( var tier in CureResearch.Tiers )
						{
							var unlocked = Core.Save.CureResearchTier >= tier.Tier;
							var next = Core.Save.CureResearchTier == tier.Tier - 1;
							var canUnlock = next && CureResearch.CanUnlockTier( Core, tier.Tier );
							<div class="row @(unlocked ? "maxed" : canUnlock ? "afford" : "poor")" onclick=@(() => UnlockTier(tier.Tier))>
								<div class="row-icon-wrap"><i class="icon">science</i></div>
								<div class="row-text">
									<div class="row-name">@tier.Name <span class="row-lvl">Tier @tier.Tier</span></div>
									<div class="row-desc">@tier.Description</div>
									<div class="row-now">Needs @tier.LabPointsRequired lab pts · Season @tier.MinSeason+</div>
								</div>
								<div class="row-cost">@(unlocked ? "DONE" : next ? "Unlock" : "Locked")</div>
							</div>
						}
					</div>
					<div class="btn wide-btn" onclick=@CloseCureProgress><span>Close</span></div>
				</div>
			</div>
		}

		@if ( SettingsOpen )
		{
			<div class="overlay">
				<div class="modal wide settings-modal">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Settings</div>
							<div class="modal-sub">Audio mix — saved to your profile</div>
						</div>
						<div class="sel-close" onclick=@CloseSettings><i class="icon">close</i></div>
					</div>
					<div class="settings-list">
						<div class="vol-row">
							<div class="vol-head">
								<i class="icon">volume_up</i>
								<span class="vol-label">Master Volume</span>
								<span class="vol-pct">@VolumePct(AudioMaster)%</span>
							</div>
							<div class="vol-controls">
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("master", -0.05f))><span>-</span></div>
								<div class="vol-track"><div class="vol-fill" style="width: @(VolumePct(AudioMaster))%;"></div></div>
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("master", 0.05f))><span>+</span></div>
							</div>
						</div>
						<div class="vol-row">
							<div class="vol-head">
								<i class="icon">campaign</i>
								<span class="vol-label">Sound Effects</span>
								<span class="vol-pct">@VolumePct(AudioSfx)%</span>
							</div>
							<div class="vol-controls">
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("sfx", -0.05f))><span>-</span></div>
								<div class="vol-track"><div class="vol-fill" style="width: @(VolumePct(AudioSfx))%;"></div></div>
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("sfx", 0.05f))><span>+</span></div>
							</div>
						</div>
						<div class="vol-row">
							<div class="vol-head">
								<i class="icon">forest</i>
								<span class="vol-label">Ambience</span>
								<span class="vol-pct">@VolumePct(AudioAmbience)%</span>
							</div>
							<div class="vol-controls">
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("ambience", -0.05f))><span>-</span></div>
								<div class="vol-track"><div class="vol-fill" style="width: @(VolumePct(AudioAmbience))%;"></div></div>
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("ambience", 0.05f))><span>+</span></div>
							</div>
						</div>
						<div class="vol-row">
							<div class="vol-head">
								<i class="icon">music_note</i>
								<span class="vol-label">Music</span>
								<span class="vol-pct">@VolumePct(AudioMusic)%</span>
							</div>
							<div class="vol-controls">
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("music", -0.05f))><span>-</span></div>
								<div class="vol-track"><div class="vol-fill" style="width: @(VolumePct(AudioMusic))%;"></div></div>
								<div class="btn sm vol-btn" onclick=@(() => AdjustVolume("music", 0.05f))><span>+</span></div>
							</div>
						</div>
					</div>
					<div class="btn wide-btn" onclick=@CloseSettings><span>Close</span></div>
				</div>
			</div>
		}

		@if ( ShopOpen )
		{
			<div class="overlay">
				<div class="modal wide">
					<div class="modal-head">
						<div class="modal-title">Upgrades</div>
						<div class="pill scrap sm"><i class="icon">settings</i><span class="val">@Format(Core?.Wallet.Scrap ?? 0)</span></div>
						<div class="sel-close" onclick=@CloseShop><i class="icon">close</i></div>
					</div>
					<div class="list">
						@foreach ( var def in UpgradeSystem.All )
						{
							var level = Upgrades.Level( def.Id );
							var maxed = Upgrades.IsMaxed( def.Id );
							var cost = Upgrades.NextCost( def.Id );
							var afford = !maxed && Core.Wallet.Scrap >= cost;
							<div class="row @(maxed ? "maxed" : afford ? "afford" : "poor")" onclick=@(() => Buy(def.Id))>
								<div class="row-icon-wrap"><i class="icon">@def.Icon</i></div>
								<div class="row-text">
									<div class="row-name">@def.Name <span class="row-lvl">Lv @level / @def.MaxLevel</span></div>
									<div class="row-desc">@UpgradeSystem.PerLevelEffect( def.Id )</div>
									<div class="row-now">@Upgrades.CurrentBonus( def.Id )</div>
								</div>
								<div class="row-cost">@(maxed ? "MAX" : Format(cost))</div>
							</div>
						}
					</div>
					<div class="btn wide-btn" onclick=@CloseShop><span>Close</span></div>
				</div>
			</div>
		}

		@if ( RecruitOpen )
		{
			<div class="overlay">
				<div class="modal wide">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Recruits</div>
							<div class="modal-sub">@RecruitModalSub</div>
						</div>
						<div class="pill scrap sm"><i class="icon">settings</i><span class="val">@Format(Core?.Wallet.Scrap ?? 0)</span></div>
						<div class="sel-close" onclick=@CloseRecruit><i class="icon">close</i></div>
					</div>
					<div class="list">
						@foreach ( var type in RecruitWeapons.Order )
						{
							var def = RecruitWeapons.Get( type );
							var owned = Defenders?.CountOf( type ) ?? 0;
							var trainLvl = Defenders?.TrainLevelOf( type ) ?? 0;
							var unlocked = NightUnlocks.IsRecruitUnlocked( Core.Save, type );
							var recruitCost = def.RecruitCost;
							var trainCost = Defenders?.TrainCost( type ) ?? 0;
							var canRecruit = unlocked && HasBarracks && DefenderCount < MaxRecruitCapacity && Core.Wallet.Scrap >= recruitCost;
							var canTrain = owned > 0 && Core.Wallet.Scrap >= trainCost;
							<div class="row recruit-row @(unlocked ? "" : "locked")">
								<div class="row-icon-wrap"><i class="icon">@(unlocked ? def.Icon : "lock")</i></div>
								<div class="row-text">
									<div class="row-name">@def.Name <span class="row-lvl">x@owned · Lv @trainLvl</span></div>
									<div class="row-desc">@(unlocked ? $"DMG {def.VolleyDamage(trainLvl):0} · RNG {def.Range:0} · {(1f / def.FireInterval):0.0}/s" : $"Unlocks on Night {def.UnlockNight}")</div>
								</div>
								<div class="recruit-actions">
									<div class="btn sm @(canRecruit ? "" : "poor")" onclick=@(() => Recruit(type))>
										<span>Recruit</span><span class="btn-cost">@(unlocked ? Format(recruitCost) : $"N{def.UnlockNight}")</span>
									</div>
									<div class="btn sm @(canTrain ? "" : "poor")" onclick=@(() => Train(type))>
										<span>Train</span><span class="btn-cost">@Format(trainCost)</span>
									</div>
								</div>
							</div>
						}
					</div>
					<div class="btn wide-btn" onclick=@CloseRecruit><span>Close</span></div>
				</div>
			</div>
		}

		@if ( WorkersOpen )
		{
			<div class="overlay">
				<div class="modal wide">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Workers</div>
							<div class="modal-sub">@WorkersModalSub</div>
						</div>
						<div class="pill scrap sm"><i class="icon">settings</i><span class="val">@Format(Core?.Wallet.Scrap ?? 0)</span></div>
						<div class="sel-close" onclick=@CloseWorkers><i class="icon">close</i></div>
					</div>
					<div class="list">
						@foreach ( var role in WorkerRoles )
						{
							var cost = WorkerInfo.HireCost( role );
							var unlocked = NightUnlocks.IsWorkerUnlocked( Core.Save, role );
							var canHire = unlocked && WorkerCount < MaxWorkers && Core.Wallet.Scrap >= cost;
							<div class="row recruit-row @(unlocked ? "" : "locked")">
								<div class="row-icon-wrap"><i class="icon">@(unlocked ? WorkerInfo.Icon( role ) : "lock")</i></div>
								<div class="row-text">
									<div class="row-name">@WorkerInfo.Name( role ) <span class="row-lvl">x@(Workers?.CountRole( role ) ?? 0)</span></div>
									<div class="row-desc">@(unlocked ? WorkerInfo.Blurb( role ) : WorkerUnlockHint( role ))</div>
								</div>
								<div class="recruit-actions">
									<div class="btn sm @(canHire ? "" : "poor")" onclick=@(() => HireWorker(role))>
										<span>Hire</span><span class="btn-cost">@(unlocked ? Format(cost) : WorkerUnlockCostHint( role ))</span>
									</div>
								</div>
							</div>
						}

						@if ( Workers is not null && Workers.Count > 0 )
						{
							<div class="modal-sub list-label">Stationed crew</div>
							@foreach ( var u in Workers.Units )
							{
								<div class="row recruit-row">
									<div class="row-icon-wrap"><i class="icon">@WorkerInfo.Icon( u.Role )</i></div>
									<div class="row-text">
										<div class="row-name">@WorkerInfo.Name( u.Role )</div>
										<div class="row-desc">@WorkerAssignment( u )</div>
									</div>
									<div class="recruit-actions">
										<div class="btn sm warn" onclick=@(() => DismissWorker(u))>
											<span>Dismiss</span>
										</div>
									</div>
								</div>
							}
						}
						else
						{
							<div class="empty">No workers yet. Hire a crafter or repairman here, or claim a resource plot and hire a forager on it.</div>
						}
					</div>
					<div class="btn wide-btn" onclick=@CloseWorkers><span>Close</span></div>
				</div>
			</div>
		}

		@if ( ExpeditionsOpen && Exp is not null )
		{
			<div class="overlay">
				<div class="modal wide">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Scout Expeditions</div>
							<div class="modal-sub">Send soldiers &amp; civilians to scavenge the wastes</div>
						</div>
						<div class="pill scrap sm"><i class="icon">settings</i><span class="val">@Format(Core?.Wallet.Scrap ?? 0)</span></div>
						<div class="sel-close" onclick=@CloseExpeditions><i class="icon">close</i></div>
					</div>

					@if ( Exp.IsActive )
					{
						<div class="exp-status">
							@if ( Exp.IsReadyToCollect )
							{
								<i class="icon exp-big ready">inventory_2</i>
								<div class="exp-status-title">Your party has returned!</div>
								<div class="exp-status-sub">@Exp.Party sent out · collect what they scavenged.</div>
								<div class="btn primary lg" onclick=@CollectExp><i class="icon">redeem</i><span>Collect Rewards</span></div>
							}
							else
							{
								<i class="icon exp-big">hiking</i>
								<div class="exp-status-title">@Exp.Party scouts are out there</div>
								<div class="exp-status-sub">@(Exp.IsLong ? "Long expedition" : "Short scout") · returning in @ExpCountdown</div>
							}
						</div>
					}
					else
					{
						<div class="exp-setup">
							@if ( Exp.HasResult )
							{
								<div class="exp-result">
									<i class="icon">@(Exp.LastReward.RareFind ? "auto_awesome" : "check_circle")</i>
									<span>Party returned with @Format(Exp.LastReward.Scrap) scrap@(Exp.LastReward.RareFind ? " — rare find!" : "").@(Exp.LastReward.Lost > 0 ? $" Lost {Exp.LastReward.Lost}." : " Everyone made it back.")</span>
								</div>
							}

							@if ( Exp.AvailableSoldiers + Exp.AvailableCivilians < 1 )
							{
								<div class="empty">Recruit a soldier or hire a worker first — you need people to send.</div>
							}
							else
							{
								<div class="exp-steppers">
									<div class="exp-stepper">
										<div class="exp-step-lbl"><i class="icon">military_tech</i>Soldiers</div>
										<div class="exp-party">
											<div class="btn sm" onclick=@(() => AdjustSoldiers(-1))><i class="icon">remove</i></div>
											<div class="exp-party-num">@ExpSoldiers</div>
											<div class="btn sm" onclick=@(() => AdjustSoldiers(1))><i class="icon">add</i></div>
										</div>
										<div class="exp-avail-sm">@Exp.AvailableSoldiers available · safer trips</div>
									</div>
									<div class="exp-stepper">
										<div class="exp-step-lbl"><i class="icon">engineering</i>Civilians</div>
										<div class="exp-party">
											<div class="btn sm" onclick=@(() => AdjustCivilians(-1))><i class="icon">remove</i></div>
											<div class="exp-party-num">@ExpCivilians</div>
											<div class="btn sm" onclick=@(() => AdjustCivilians(1))><i class="icon">add</i></div>
										</div>
										<div class="exp-avail-sm">@Exp.AvailableCivilians available · more loot</div>
									</div>
								</div>

								<div class="exp-prov">Party of @ExpPartyTotal · provision cost @Format(Exp.ProvisionCost(ExpPartyTotal))</div>

								<div class="exp-options">
									<div class="btn @(CanStartShortExp ? "primary" : "poor")" onclick=@StartShort>
										<span>Short Scout</span>
										<span class="btn-cost">@(ShortExpeditionUnlocked ? $"{(int)GameConstants.ExpeditionShortSeconds}s · safe · ~{Format(ExpPartyTotal * GameConstants.ExpeditionScrapPerScoutShort)}" : $"Night {NightUnlocks.ShortExpeditionNight}")</span>
									</div>
									<div class="btn @(CanStartLongExp ? "warn" : "poor")" onclick=@StartLong>
										<span>Long Expedition</span>
										<span class="btn-cost">@(LongExpeditionUnlocked ? $"{(int)GameConstants.ExpeditionLongSeconds}s · risky · ~{Format(ExpPartyTotal * GameConstants.ExpeditionScrapPerScoutLong)} + loot" : $"Night {NightUnlocks.LongExpeditionNight}")</span>
									</div>
								</div>
							}
						</div>
					}

					<div class="btn wide-btn" onclick=@CloseExpeditions><span>Close</span></div>
				</div>
			</div>
		}

		@if ( MilestonesOpen )
		{
			<div class="overlay">
				<div class="modal wide goals-modal">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Goals</div>
							<div class="modal-sub">@MilestonesDone / @MilestonesTotal complete · scrap bounties for lifetime milestones</div>
						</div>
						<div class="pill scrap sm"><i class="icon">settings</i><span class="val">@Format(Core?.Wallet.Scrap ?? 0)</span></div>
						<div class="sel-close" onclick=@CloseMilestones><i class="icon">close</i></div>
					</div>

					<div class="goals-list">
						@foreach ( var m in Milestones.All )
						{
							var done = Milestones.IsDone( Core.Save, m.Id );
							var pct = (int)MathF.Round( m.Fraction( Core.Save ) * 100f );
							<div class="goal-row @(done ? "done" : "")">
								<div class="goal-icon">
									<i class="icon">@(done ? "check_circle" : m.Icon)</i>
								</div>
								<div class="goal-body">
									<div class="goal-head">
										<span class="goal-title">@m.Title</span>
										<span class="goal-reward">@(done ? "Done" : $"+{Format(m.Reward)}")</span>
									</div>
									<div class="goal-track">
										<div class="goal-fill" style="width: @(pct)%;"></div>
									</div>
									<div class="goal-meta">
										<span class="goal-progress">@MilestoneProgress(m)</span>
										<span class="goal-pct">@pct%</span>
									</div>
								</div>
							</div>
						}
					</div>

					<div class="btn wide-btn" onclick=@CloseMilestones><span>Close</span></div>
				</div>
			</div>
		}

		@if ( CatalogOpen )
		{
			<div class="overlay">
				<div class="modal wide catalog-modal">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Zombie Catalog</div>
							<div class="modal-sub">@CatalogDiscovered / @CatalogTotal encountered · stats shown for Night @CatalogNight</div>
						</div>
						<div class="sel-close" onclick=@CloseCatalog><i class="icon">close</i></div>
					</div>

					<div class="catalog-list">
						@foreach ( var def in ZombieCatalog.All )
						{
							var discovered = CatalogIsDiscovered( def.Kind );
							<div class="catalog-row @(discovered ? "" : "locked")">
								<div class="catalog-icon" style="@(discovered ? ZombieBestiary.TintStyle( def.Tint ) : "")">
									<i class="icon">@(discovered ? "coronavirus" : "lock")</i>
								</div>
								<div class="catalog-body">
									<div class="catalog-head">
										<span class="catalog-name">@(discovered ? def.Name : "Unknown")</span>
										<span class="catalog-night">Night @def.IntroNight</span>
									</div>
									@if ( discovered )
									{
										<span class="catalog-desc">@def.Description</span>
										<div class="catalog-stats">
											<span class="catalog-stat"><span class="lbl">HP</span> @FormatStat( ZombieBestiary.HpAtNight( def, CatalogNight ) )</span>
											<span class="catalog-stat"><span class="lbl">DMG</span> @FormatStat( ZombieBestiary.DamageAtNight( def, CatalogNight ) )</span>
											<span class="catalog-stat"><span class="lbl">SPD</span> @FormatStat( ZombieBestiary.SpeedAtNight( def, CatalogNight ) )</span>
										</div>
										<div class="catalog-tags">
											@foreach ( var tag in ZombieBestiary.AbilityLines( def ) )
											{
												<span class="catalog-tag">@tag</span>
											}
										</div>
										@if ( CatalogKillCount( def.Kind ) > 0 )
										{
											<span class="catalog-kills">@CatalogKillCount( def.Kind ) eliminated</span>
										}
									}
									else
									{
										<span class="catalog-desc muted">Encounter this type during a night defense to unlock its stats and abilities.</span>
									}
								</div>
							</div>
						}
					</div>

					<div class="btn wide-btn" onclick=@CloseCatalog><span>Close</span></div>
				</div>
			</div>
		}

		@if ( LegacyOpen )
		{
			<div class="overlay">
				<div class="modal wide legacy-modal">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Evacuate &amp; Legacy</div>
							<div class="modal-sub">Trade a strong run for permanent scrap bonuses</div>
						</div>
						<div class="sel-close" onclick=@CloseLegacy><i class="icon">close</i></div>
					</div>

					<div class="legacy-panel">
						<div class="legacy-lead">
							<span class="legacy-lead-copy">Evacuating ends your current run and rebuilds from Night 1. In return, survivors carry forward legacy points that permanently increase every scrap reward you earn.</span>
						</div>

						<div class="legacy-how">
							<div class="legacy-step">
								<i class="icon">restart_alt</i>
								<div class="legacy-step-text">
									<span class="step-title">You lose this run</span>
									<span class="step-body">Buildings, recruits, plots, and upgrades reset. You start fresh at Night 1.</span>
								</div>
							</div>
							<div class="legacy-step">
								<i class="icon">emoji_events</i>
								<div class="legacy-step-text">
									<span class="step-title">You keep forever</span>
									<span class="step-body">Leaderboard history, best night, milestones, and all legacy points earned so far.</span>
								</div>
							</div>
							<div class="legacy-step">
								<i class="icon">recycling</i>
								<div class="legacy-step-text">
									<span class="step-title">Legacy points = +@LegacyBonusPerPointPercent% scrap each</span>
									<span class="step-body">1 legacy point per @GameConstants.PrestigeNightsPerPoint nights reached this run (currently Night @PrestigeReachNight).</span>
								</div>
							</div>
						</div>

						<div class="legacy-stats">
							<div class="legacy-cell">
								<span class="lc-v">@PrestigeLevel</span>
								<span class="lc-k">Evacuations</span>
							</div>
							<div class="legacy-cell">
								<span class="lc-v">@LegacyPoints</span>
								<span class="lc-k">Legacy pts</span>
							</div>
							<div class="legacy-cell">
								<span class="lc-v">+@LegacyBonusPercent%</span>
								<span class="lc-k">Scrap bonus</span>
							</div>
						</div>

						@if ( PrestigeAvailable )
						{
							<div class="legacy-callout ready">
								<i class="icon">flight_takeoff</i>
								<div class="legacy-callout-text">
									<span class="callout-title">Ready to evacuate at Night @PrestigeReachNight</span>
									<span class="callout-body">Gain +@PrestigeGain legacy points for @TotalLegacyAfterEvacuate total (+@ScrapBonusAfterEvacuate% scrap on every future reward).</span>
								</div>
							</div>
							<div class="btn primary lg legacy-action" onclick=@DoPrestige>
								<i class="icon">flight_takeoff</i><span>Evacuate &amp; Rebuild</span>
							</div>
						}
						else
						{
							<div class="legacy-callout">
								<i class="icon">lock</i>
								<div class="legacy-callout-text">
									<span class="callout-title">Reach Night @GameConstants.PrestigeMinNight to evacuate</span>
									<span class="callout-body">Current run: Night @CurrentRunNight. Best ever: Night @BestNight.</span>
								</div>
							</div>
						}
					</div>

					<div class="btn wide-btn ghost" onclick=@CloseLegacy><span>Close</span></div>
				</div>
			</div>
		}

		@if ( LeaderboardOpen )
		{
			<div class="overlay">
				<div class="modal wide lb-modal">
					<div class="modal-head">
						<div class="modal-title-col">
							<div class="modal-title">Survival Leaderboard</div>
							<div class="modal-sub">Your best: Night @SurvivalBestNight@(SurvivalRunInProgress ? $" · Current run: Night {SurvivalCurrentNight}" : "")</div>
						</div>
						<div class="sel-close" onclick=@CloseLeaderboard><i class="icon">close</i></div>
					</div>

					<div class="lb-table">
						<div class="lb-head">
							<div class="lb-col rank">Rank</div>
							<div class="lb-col name">Name</div>
							<div class="lb-col nights">Night Reached</div>
						</div>

						@if ( _lbLoading )
						{
							<div class="empty">Loading…</div>
						}
						else if ( _lbEntries.Count == 0 )
						{
							<div class="empty">No entries yet.</div>
						}
						else
						{
							@foreach ( var e in _lbEntries )
							{
								<div class="lb-row @(e.IsLocal ? "you" : "") @(e.IsInProgress ? "in-progress" : "")">
									<div class="lb-col rank">@(e.IsInProgress ? "—" : e.Rank.ToString())</div>
									<div class="lb-col name">@e.Name</div>
									<div class="lb-col nights">Night @e.Nights</div>
								</div>
							}
						}
					</div>

					<div class="btn wide-btn" onclick=@CloseLeaderboard><span>Close</span></div>
				</div>
			</div>
		}
	}
</root>

@code
{
	private GameCore Core => GameCore.Instance;
	private UpgradeSystem Upgrades => Core?.Upgrades;
	private DefenderManager Defenders => DefenderManager.Instance;
	private WorkerManager Workers => WorkerManager.Instance;
	private ISelectable Selected => BuildManager.Instance?.Selected;
	private BuildableId? Placing => BuildManager.Instance?.PlacementMode;
	private PlacedBuilding Moving => BuildManager.Instance?.MovingBuilding;
	private TutorialTipDef TutorialTip => Core?.ActiveTutorialTip;
	private bool TutorialTipsHidden => Core?.TutorialTipsHidden ?? false;
	private bool ShowTipsToggle => Core is not null && (Phase == GamePhase.Day || Phase == GamePhase.Night)
		&& (IsSurvival && NightUnlocks.ProgressNight( Core.Save ) <= TutorialTips.MaxNight
			|| IsCure && CureConstants.ProgressSeason( Core.Save ) <= CureTutorialTips.MaxSeason);

	private GamePhase Phase => Core?.Phase ?? GamePhase.MainMenu;
	private NightRecap NightRecap => Core?.PendingNightRecap;
	private bool ShopOpen => Core?.ShopOpen ?? false;
	private bool SettingsOpen => Core?.SettingsOpen ?? false;
	private bool LeaderboardOpen => Core?.LeaderboardOpen ?? false;
	private bool RecruitOpen => Core?.RecruitOpen ?? false;
	private bool WorkersOpen => Core?.WorkersOpen ?? false;
	private bool ExpeditionsOpen => Core?.ExpeditionsOpen ?? false;
	private bool MilestonesOpen => Core?.MilestonesOpen ?? false;
	private bool CatalogOpen => Core?.CatalogOpen ?? false;
	private bool LegacyOpen => Core?.LegacyOpen ?? false;
	private bool CureProgressOpen => Core?.CureProgressOpen ?? false;
	private bool TechTreeOpen => Core?.TechTreeOpen ?? false;
	private bool IsSurvival => Core?.IsSurvival ?? true;
	private bool IsCure => Core?.IsCure ?? false;
	private bool CanContinueSurvival => Core?.CanContinueSurvival ?? false;
	private bool CanContinueCure => Core?.CanContinueCure ?? false;
	private string SeasonName => CureConstants.SeasonName( Core?.Save.CurrentSeason ?? 0 );
	private string TeamName => TeamBonuses.Get( TeamBonuses.Team( Core ) ).Name;
	private string Specimens => $"{Core?.Resources.Get( ResourceKind.Specimens ) ?? 0:0}";
	private string Food => $"{Core?.Resources.Get( ResourceKind.Food ) ?? 0:0}";
	private string Supplies => $"{Core?.Resources.Get( ResourceKind.Supplies ) ?? 0:0}";
	private string Knowledge => $"{Core?.Resources.Get( ResourceKind.Knowledge ) ?? 0:0}";
	private bool WelcomePending => Core?.WelcomePending ?? false;
	private bool DailyPending => Core?.DailyPending ?? false;
	private string ObjectiveToast => Core?.ObjectiveToast;

	private ExpeditionManager Exp => ExpeditionManager.Instance;
	private bool ExpeditionActive => Exp?.IsActive ?? false;
	private bool ExpeditionReady => Exp?.IsReadyToCollect ?? false;

	private int _expSoldiers;
	private int _expCivilians = 1;
	private int ExpSoldiers => Math.Clamp( _expSoldiers, 0, Exp?.AvailableSoldiers ?? 0 );
	private int ExpCivilians => Math.Clamp( _expCivilians, 0, Exp?.AvailableCivilians ?? 0 );
	private int ExpPartyTotal => Math.Min( GameConstants.ExpeditionMaxParty, ExpSoldiers + ExpCivilians );
	private int ProgressNight => NightUnlocks.ProgressNight( Core?.Save );
	private bool ShortExpeditionUnlocked => NightUnlocks.IsShortExpeditionUnlocked( Core?.Save );
	private bool LongExpeditionUnlocked => NightUnlocks.IsLongExpeditionUnlocked( Core?.Save );
	private bool CanStartShortExp => (Exp?.CanStart( ExpSoldiers, ExpCivilians, false ) ?? false) && ExpPartyTotal >= GameConstants.ExpeditionMinParty;
	private bool CanStartLongExp => (Exp?.CanStart( ExpSoldiers, ExpCivilians, true ) ?? false) && ExpPartyTotal >= GameConstants.ExpeditionMinParty;
	private string ExpCountdown => FormatTime( Exp?.SecondsRemaining ?? 0f );
	private string ExpeditionChipHint => !ExpeditionActive ? "Send a party" : (ExpeditionReady ? "Collect haul" : ExpCountdown);

	private IEnumerable<ObjectiveDef> NextObjectives => Objectives.All.Where( o => !Objectives.IsDone( Core, o.Id ) ).Take( 3 );
	private int ObjectivesDone => Objectives.CompletedCount( Core );
	private int ObjectivesTotal => Objectives.All.Count;
	private bool ShowObjectives => Core is not null && ObjectivesDone < ObjectivesTotal;

	private int MilestonesDone => Milestones.CompletedCount( Core?.Save );
	private int MilestonesTotal => Milestones.All.Count;

	private int CatalogDiscovered => ZombieBestiary.DiscoveredCount( Core?.Save );
	private int CatalogTotal => ZombieCatalog.All.Count;
	private int CatalogNight => Core?.Save.CurrentNight ?? 1;
	private bool CatalogIsDiscovered( ZombieKind kind ) => ZombieBestiary.IsDiscovered( Core?.Save, kind );
	private int CatalogKillCount( ZombieKind kind ) => ZombieBestiary.KillCount( Core?.Save, kind );
	private static string FormatStat( float value ) => value >= 100f ? $"{(int)MathF.Round( value )}" : value.ToString( "0.#" );

	private int ComboStreak => Core?.Combo?.Streak ?? 0;
	private float ComboMult => Core?.Combo?.Multiplier ?? 1f;
	private float ComboFraction => Core?.Combo?.WindowFraction ?? 0f;

	private int PrestigeLevel => Core?.Save.PrestigeLevel ?? 0;
	private int LegacyPoints => Core?.Save.LegacyPoints ?? 0;
	private int LegacyBonusPercent => (int)MathF.Round( (float)((Core?.LegacyMult ?? 1.0) - 1.0) * 100f );
	private int LegacyBonusPerPointPercent => (int)MathF.Round( (float)(GameConstants.LegacyScrapBonusPer * 100f) );
	private int PrestigeReachNight => Math.Max( BestNight, Core?.Save.CurrentNight ?? 1 );
	private int CurrentRunNight => Core?.Save.CurrentNight ?? 1;
	private int TotalLegacyAfterEvacuate => LegacyPoints + PrestigeGain;
	private int ScrapBonusAfterEvacuate => (int)MathF.Round( (float)(TotalLegacyAfterEvacuate * GameConstants.LegacyScrapBonusPer * 100f) );
	private bool PrestigeAvailable => Core?.PrestigeAvailable ?? false;
	private int PrestigeGain => Core?.PrestigeGain ?? 0;
	private int SurvivalBestNight => SaveManager.SurvivalSave.BestNight;
	private int SurvivalCurrentNight => SaveManager.SurvivalSave.CurrentNight;
	private bool SurvivalRunInProgress => SaveManager.SurvivalSave.HasRunInProgress;
	private int BestNight => Core?.Save.BestNight ?? 0;
	private string LegacyChipHint => PrestigeAvailable ? "Evacuate ready" : (LegacyPoints > 0 ? $"+{LegacyBonusPercent}% scrap" : "Prestige");

	private int DailyStreak => Core?.Daily.Streak ?? 1;
	private double DailyReward_Amount => Core?.Daily.Reward ?? 0;
	private string DailyStreakLabel => $"Day {DailyStreak} Streak";
	private string DailyRewardLabel => $"{Format( DailyReward_Amount )} Scrap";
	private string DailyNextLabel => $"Come back tomorrow for +{Format( GameConstants.DailyRewardPerStreak )} more.";

	private string Scrap => GameConstants.FormatScrap( Core?.Wallet.Scrap ?? 0 );
	private ColonyIncomeRates.Snapshot IncomeRates => ColonyIncomeRates.Get( Core );
	private string ScrapRateLabel => ColonyIncomeRates.FormatRate( IncomeRates.ScrapPerSec );
	private string WoodRateLabel => ColonyIncomeRates.FormatRate( IncomeRates.WoodPerSec );
	private string StoneRateLabel => ColonyIncomeRates.FormatRate( IncomeRates.StonePerSec );
	private string WaterRateLabel => ColonyIncomeRates.FormatRate( IncomeRates.WaterPerSec );
	private string FoodRateLabel => ColonyIncomeRates.FormatRate( IncomeRates.FoodPerSec );
	private string SuppliesRateLabel => ColonyIncomeRates.FormatRate( IncomeRates.SuppliesPerSec );
	private string KnowledgeRateLabel => ColonyIncomeRates.FormatRate( IncomeRates.KnowledgePerSec );
	private string Wood => $"{Core?.Resources.Get( ResourceKind.Wood ) ?? 0:0}";
	private string Stone => $"{Core?.Resources.Get( ResourceKind.Stone ) ?? 0:0}";
	private string Water => $"{Core?.Resources.Get( ResourceKind.Water ) ?? 0:0}";
	private int WorkerCount => Workers?.Count ?? 0;
	private int MaxWorkers => GameConstants.MaxWorkers;
	private WorkerRole[] WorkerRoles => WorkerInfo.RolesForMode( IsCure );
	private string WorkersModalSub => IsCure
		? $"{WorkerCount} / {MaxWorkers} hired · specialists boost colony output"
		: $"{WorkerCount} / {MaxWorkers} hired · foragers are assigned from claimed plots";
	private int CorePercent => (int)MathF.Round( (Core?.Outpost?.CoreHealth ?? 0) / MathF.Max( 1f, Core?.Outpost?.CoreMaxHealth ?? 1 ) * 100f );
	private int WallPercent => (int)MathF.Round( (Core?.Outpost?.WallIntegrityFraction ?? 0f) * 100f );
	private int DefensesPercent
	{
		get
		{
			var buildings = BuildManager.Instance?.Buildings;
			if ( buildings is null ) return 100;
			var cur = 0f;
			var max = 0f;
			foreach ( var b in buildings )
			{
				if ( !b.IsDefense || b.IsDestroyed ) continue;
				cur += b.Health;
				max += b.MaxHealth;
			}
			if ( max <= 0f ) return 100;
			return (int)MathF.Round( cur / max * 100f );
		}
	}

	private int RecruitsPercent
	{
		get
		{
			var units = Defenders?.Units;
			if ( units is null || units.Count <= 0 ) return 0;
			var cur = 0f;
			var max = 0f;
			foreach ( var u in units )
			{
				if ( !u.IsAlive ) continue;
				cur += u.Health;
				max += u.MaxHealth;
			}
			if ( max <= 0f ) return 0;
			return (int)MathF.Round( cur / max * 100f );
		}
	}

	private int WorkersPercent => MaxWorkers <= 0 ? 0 : (int)MathF.Round( WorkerCount / (float)MaxWorkers * 100f );
	private int SelHpPercent => Selected is null || !Selected.HasHealth || Selected.MaxHealth <= 0f ? 0 : (int)MathF.Round( Selected.Health / Selected.MaxHealth * 100f );
	private int ZombiesLeft => (NightController.Instance?.ZombiesRemainingToSpawn ?? 0) + (CombatSystem.Instance?.AliveCount ?? 0);
	private int DefenderCount => Defenders?.Count ?? 0;
	private int BarracksCount => BuildManager.Instance?.BarracksCount ?? 0;
	private int MaxRecruitCapacity => BuildManager.Instance?.RecruitCapacity ?? 0;
	private bool HasBarracks => BarracksCount > 0;
	private string RecruitSquadLabel => HasBarracks
		? $"{DefenderCount} / {MaxRecruitCapacity} squad · {GameConstants.RecruitsPerBarracks}/barracks"
		: "Build a Barracks first";
	private string RecruitModalSub => HasBarracks
		? $"{DefenderCount} / {MaxRecruitCapacity} defenders · {BarracksCount} barracks ({GameConstants.RecruitsPerBarracks} recruits each)"
		: "Build a Barracks before recruiting soldiers";

	private bool CanRepairAll => (BuildManager.Instance?.RepairAllCost() ?? 0) > 0
		&& Core.Wallet.Scrap >= (BuildManager.Instance?.RepairAllCost() ?? 0)
		&& Phase == GamePhase.Day;
	private bool RepairBusy => RepairManager.Instance?.IsBusy ?? false;
	private int RepairProgressPct => (int)MathF.Round( (RepairManager.Instance?.ActiveProgress ?? 0f) * 100f );
	private readonly List<RepairManager.RepairLine> _repairLines = new();
	private IReadOnlyList<RepairManager.RepairLine> RepairLines
	{
		get
		{
			var build = BuildManager.Instance;
			RepairManager.Instance?.FillRepairLines( _repairLines, build?.Buildings ?? Array.Empty<PlacedBuilding>() );
			return _repairLines;
		}
	}
	private bool ShowRepairPanel => RepairLines.Count > 0;
	private int RepairLineHash
	{
		get
		{
			var h = new HashCode();
			h.Add( RepairBusy );
			h.Add( RepairProgressPct );
			foreach ( var line in RepairLines )
			{
				h.Add( line.Label );
				h.Add( line.Percent );
				h.Add( line.Active );
				h.Add( line.Queued );
			}
			return h.ToHashCode();
		}
	}


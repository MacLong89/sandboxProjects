@using Sandbox
@using Sandbox.UI
@using FinalOutpost
@inherits PanelComponent
@namespace FinalOutpost.UI

<root>
	@if ( Core is not null )
	{
		@if ( Phase == GamePhase.Day || Phase == GamePhase.Night )
		{
			<div class="hud">
				<div class="topbar-shell">
					<div class="topbar">
						<div class="cluster left">
							<div class="pill scrap" title="Scrap">
								<i class="icon">settings</i>
								<div class="pill-stack">
									<span class="val">@Format(Core?.Wallet.Scrap ?? 0)</span>
									@if ( ScrapRateLabel is not null )
									{
										<span class="pill-rate">@ScrapRateLabel</span>
									}
								</div>
								<span class="pill-tag">SCRAP</span>
							</div>
							<div class="pill res wood" title="Wood">
								<i class="icon">park</i>
								<div class="pill-stack">
									<span class="val">@Wood</span>
									@if ( WoodRateLabel is not null )
									{
										<span class="pill-rate">@WoodRateLabel</span>
									}
								</div>
							</div>
							<div class="pill res stone" title="Stone">
								<i class="icon">landscape</i>
								<div class="pill-stack">
									<span class="val">@Stone</span>
									@if ( StoneRateLabel is not null )
									{
										<span class="pill-rate">@StoneRateLabel</span>
									}
								</div>
							</div>
							<div class="pill res water" title="Water">
								<i class="icon">water_drop</i>
								<div class="pill-stack">
									<span class="val">@Water</span>
									@if ( WaterRateLabel is not null )
									{
										<span class="pill-rate">@WaterRateLabel</span>
									}
								</div>
							</div>
							@if ( IsCure )
							{
								<div class="pill res specimens" title="Specimens"><i class="icon">biotech</i><span class="val">@Specimens</span></div>
								<div class="pill res food" title="Food">
									<i class="icon">restaurant</i>
									<div class="pill-stack">
										<span class="val">@Food</span>
										@if ( FoodRateLabel is not null )
										{
											<span class="pill-rate @(IncomeRates.FoodPerSec < 0 ? "neg" : "")">@FoodRateLabel</span>
										}
									</div>
								</div>
								<div class="pill res supplies" title="Supplies">
									<i class="icon">inventory_2</i>
									<div class="pill-stack">
										<span class="val">@Supplies</span>
										@if ( SuppliesRateLabel is not null )
										{
											<span class="pill-rate">@SuppliesRateLabel</span>
										}
									</div>
								</div>
								<div class="pill res knowledge" title="Knowledge">
									<i class="icon">school</i>
									<div class="pill-stack">
										<span class="val">@Knowledge</span>
										@if ( KnowledgeRateLabel is not null )
										{
											<span class="pill-rate">@KnowledgeRateLabel</span>
										}
									</div>
								</div>
							}
						</div>

						@if ( IsCure )
						{
							<div class="night-badge day cure-season">
								<i class="icon">calendar_month</i>
								<div class="night-text">
									<span class="lbl">@TeamName</span>
									<span class="num">Year @Core.Save.CurrentYear · @SeasonName</span>
									<span class="num-sub">Day @Core.Save.SeasonDay / @CureConstants.DaysPerSeason</span>
								</div>
							</div>
						}
						else
						{
						<div class="night-badge @(Phase == GamePhase.Night ? "night" : "day")">
							<i class="icon night-moon">@(Phase == GamePhase.Night ? "dark_mode" : "bedtime")</i>
							<div class="night-text">
								<span class="lbl">@(Phase == GamePhase.Night ? "DEFENDING" : "PREPARING")</span>
								<span class="num">NIGHT @Core.Save.CurrentNight</span>
							</div>
						</div>
						}

						<div class="cluster right">
							@if ( Phase == GamePhase.Night )
							{
								<div class="pill danger">
									<i class="icon">skull</i>
									<span class="val">@ZombiesLeft</span>
									<span class="pill-tag">ZOMBIES</span>
								</div>
							}
							@if ( ShowTipsToggle )
							{
								<div class="meta-btn tips-meta @(TutorialTipsHidden ? "off" : "on")" onclick=@ToggleTips title="Toggle tutorial tips (H)">
									<i class="icon">@(TutorialTipsHidden ? "visibility_off" : "help_outline")</i>
									<span>Tips</span>
								</div>
							}
							@if ( !IsCure )
							{
							<div class="meta-btn" onclick=@OpenLeaderboard title="Leaderboard">
								<i class="icon">leaderboard</i>
								<span>Stats</span>
							</div>
							}
							<div class="meta-btn" onclick=@OpenCatalog title="Zombie Catalog">
								<i class="icon">menu_book</i>
								<span>Catalog</span>
							</div>
							@if ( IsCure )
							{
								<div class="meta-btn" onclick=@OpenTechTree title="Tech Tree">
									<i class="icon">account_tree</i>
									<span>Tech</span>
								</div>
								<div class="meta-btn" onclick=@OpenCureProgress title="Cure Progress">
									<i class="icon">science</i>
									<span>Cure</span>
								</div>
							}
							<div class="meta-btn" onclick=@GoMenu title="Back to Main Menu">
								<i class="icon">home</i>
								<span>Home</span>
							</div>
							<div class="meta-btn" onclick=@OpenSettings title="Settings">
								<i class="icon">settings</i>
								<span>Settings</span>
							</div>
						</div>
					</div>
				</div>

				<div class="left-stack">
					<div class="status-card card">
						<div class="panel-head">
							<i class="icon">fort</i>
							<span class="panel-title">Outpost Status</span>
						</div>
						<div class="stat-list">
							<div class="stat">
								<div class="stat-head">
									<span class="stat-name">Command Post</span>
									<span class="stat-num">@CorePercent%</span>
								</div>
								<div class="track health-bar" style="@HealthBarStyle(CorePercent)"></div>
							</div>
							<div class="stat">
								<div class="stat-head">
									<span class="stat-name">Walls</span>
									<span class="stat-num">@WallPercent%</span>
								</div>
								<div class="track health-bar" style="@HealthBarStyle(WallPercent)"></div>
							</div>
							<div class="stat">
								<div class="stat-head">
									<span class="stat-name">Defenses</span>
									<span class="stat-num">@DefensesPercent%</span>
								</div>
								<div class="track health-bar" style="@HealthBarStyle(DefensesPercent)"></div>
							</div>
							<div class="stat">
								<div class="stat-head">
									<span class="stat-name">Recruits</span>
									<span class="stat-num">@RecruitsPercent%</span>
								</div>
								<div class="track health-bar" style="@HealthBarStyle(RecruitsPercent)"></div>
							</div>
							<div class="stat">
								<div class="stat-head">
									<span class="stat-name">Workers</span>
									<span class="stat-num">@WorkersPercent%</span>
								</div>
								<div class="track health-bar" style="@HealthBarStyle(WorkersPercent)"></div>
							</div>
						</div>
					</div>

					@if ( Phase == GamePhase.Day && ShowObjectives && !IsCure )
					{
						<div class="objectives-card card">
							<div class="panel-head">
								<i class="icon">star</i>
								<span class="panel-title">Getting Started</span>
								<span class="obj-count">@ObjectivesDone/@ObjectivesTotal</span>
							</div>
							<div class="obj-list">
								@foreach ( var o in Objectives.All )
								{
									var done = Objectives.IsDone( Core, o.Id );
									<div class="obj-row @(done ? "done" : "")">
										<i class="icon obj-check">@(done ? "check_box" : "check_box_outline_blank")</i>
										<span class="obj-label truncate">@o.Title</span>
										<span class="obj-reward">+@Format(o.Reward) <i class="icon mini">settings</i></span>
									</div>
								}
							</div>
						</div>
					}

					@if ( Phase == GamePhase.Day && IsCure )
					{
						<div class="objectives-card card">
							<div class="panel-head">
								<i class="icon">science</i>
								<span class="panel-title">Road to a Cure</span>
								<span class="obj-count">Tier @Core.Save.CureResearchTier / @CureConstants.ResearchTierCount</span>
							</div>
							<div class="stat-list">
								<div class="stat">
									<div class="stat-head">
										<span class="stat-name">Lab Points</span>
										<span class="stat-num">@Core.Save.CureLabPoints.ToString("0")</span>
									</div>
								</div>
								<div class="stat">
									<div class="stat-head">
										<span class="stat-name">Colony Sickness</span>
										<span class="stat-num">@Core.Save.ColonySickness.ToString("0")%</span>
									</div>
									<div class="track health-bar" style="@HealthBarStyle(100 - (int)Core.Save.ColonySickness)"></div>
								</div>
							</div>
							<div class="obj-list">
								@foreach ( var o in CureObjectives.All )
								{
									var done = CureObjectives.IsDone( Core, o.Id );
									<div class="obj-row @(done ? "done" : "")">
										<i class="icon obj-check">@(done ? "check_box" : "check_box_outline_blank")</i>
										<span class="obj-label truncate">@o.Title</span>
									</div>
								}
							</div>
						</div>
					}
				</div>

				@if ( Phase == GamePhase.Day && ShowRepairPanel && Selected is null )
				{
					<div class="repair-stack">
						<div class="repair-card card">
							<div class="panel-head">
								<i class="icon">build</i>
								<span class="panel-title">@(RepairBusy ? "Repair Queue" : "Needs Repair")</span>
								<span class="repair-count">@RepairLines.Count</span>
							</div>
							<div class="repair-list">
								@foreach ( var line in RepairLines )
								{
									<div class="repair-row @(line.Active ? "active" : line.Queued ? "queued" : "pending")">
										<div class="repair-row-head">
											<span class="repair-name truncate">@line.Label</span>
											<span class="repair-pct">
												@if ( line.Active )
												{
													@($"{line.Percent}%")
												}
												else if ( line.Queued )
												{
													<span class="queued">Queued</span>
												}
												else
												{
													@($"{line.Percent}%")
												}
											</span>
										</div>
										@if ( line.Active || !line.Queued )
										{
											<div class="track health-bar" style="@HealthBarStyle(line.Percent)"></div>
										}
									</div>
								}
							</div>
						</div>
					</div>
				}

				@if ( !string.IsNullOrEmpty( ObjectiveToast ) )
				{
					<div class="toast">
						<i class="icon">check_circle</i>
						<div class="toast-text">
							<span class="toast-title">Reward earned</span>
							<span class="toast-sub">@ObjectiveToast</span>
						</div>
					</div>
				}

				@if ( Phase == GamePhase.Night && ComboStreak > 1 )
				{
					<div class="combo">
						<div class="combo-mult">@($"x{ComboMult:0.0}")</div>
						<div class="combo-lbl">@ComboStreak KILL COMBO</div>
						<div class="combo-track"><div class="combo-fill" style="width: @(ComboFraction * 100f)%;"></div></div>
					</div>
				}

				@if ( Selected is not null && Selected.IsAlive )
				{
					var sel = Selected;
					<div class="selected card">
						<div class="sel-hero">
							<div class="sel-icon-wrap">
								<i class="icon sel-icon">@sel.Icon</i>
							</div>
							<div class="sel-title">
								<span class="sel-name truncate">@sel.Name</span>
								<span class="sel-lvl truncate">@sel.Subtitle</span>
							</div>
							<div class="sel-close" onclick=@Deselect><i class="icon">close</i></div>
						</div>

						@if ( Selected is WorkerSelectable worker )
						{
							<span class="sel-desc">@worker.Description</span>
						}

						@if ( sel.HasHealth )
						{
							<div class="sel-hp">
								<div class="stat-head">
									<span class="stat-name">Health</span>
									<span class="stat-num">@((int)sel.Health) / @((int)sel.MaxHealth)</span>
								</div>
								<div class="track thick health-bar" style="@HealthBarStyle(SelHpPercent)"></div>
							</div>
						}

						<div class="sel-stats">
							@foreach ( var s in sel.Stats )
							{
								<div class="sel-stat">
									<div class="sel-stat-left">
										<i class="icon stat-ic">@StatIcon(s.Label)</i>
										<span class="k">@s.Label</span>
									</div>
									<span class="v">@s.Value</span>
								</div>
							}
						</div>

						<div class="sel-actions">
							@foreach ( var a in sel.Actions )
							{
								<div class="btn action @ActionClass(a) @RepairActionClass(a.Label) @(a.Enabled ? "" : "poor")" onclick=@(() => Act(a))>
									<div class="action-main">
										<i class="icon">@ActionIcon(a.Label)</i>
										<span>@a.Label</span>
									</div>
									@if ( !string.IsNullOrEmpty( a.Detail ) )
									{
										<span class="btn-cost">@a.Detail</span>
									}
								</div>
							}
						</div>
					</div>
				}

				@if ( TutorialTip is not null )
				{
					var tip = TutorialTip;
					<div class="overlay tip-overlay">
						<div class="modal confirm tutorial-tip">
							<i class="icon confirm-icon tip-icon">@tip.Icon</i>
							<div class="confirm-title">@tip.Title</div>
							<div class="confirm-body">@tip.Body</div>
							<div class="btn-row">
								<div class="btn ghost" onclick=@HideAllTips><i class="icon">visibility_off</i><span>Hide tips</span></div>
								<div class="btn primary" onclick=@DismissTip><span>Got it</span></div>
							</div>
						</div>
					</div>
				}

				@if ( Phase == GamePhase.Day )
				{
					<div class="dock-wrap">
						<div class="dock-shell">
							<div class="dock">
								<div class="dock-tiles">
									@foreach ( var def in BuildableCatalog.ForMode( Core.ActiveMode ) )
									{
										var unlocked = NightUnlocks.IsBuildingUnlocked( Core.Save, def.Id );
										var afford = unlocked && Core.Wallet.Scrap >= BuildingPlaceCost( def );
										var active = Placing == def.Id;
										<div class="dock-tile @(active ? "active" : "") @(unlocked ? (afford ? "" : "poor") : "locked")" onclick=@(() => Place(def.Id))>
											<div class="tile-icon"><i class="icon">@(unlocked ? def.Icon : "lock")</i></div>
											<span class="tile-name truncate">@def.Name</span>
											@if ( unlocked )
											{
												<span class="tile-foot cost"><i class="icon mini">settings</i>@Format(BuildingPlaceCost(def))</span>
											}
											else
											{
												<span class="tile-foot lock">@def.GateLabel(Core.Save)</span>
											}
										</div>
									}

									<div class="dock-tile recruit @(!HasBarracks ? "needs-barracks" : "")" onclick=@OpenRecruit>
										<div class="tile-icon"><i class="icon">military_tech</i></div>
										<span class="tile-name truncate">Recruit</span>
										<span class="tile-foot sub truncate">@RecruitSquadLabel</span>
									</div>

									<div class="dock-tile upgrade" onclick=@OpenShop>
										<div class="tile-icon"><i class="icon">upgrade</i></div>
										<span class="tile-name truncate">Upgrades</span>
									</div>
									<div class="dock-tile @(CanRepairAll ? "" : "poor")" onclick=@RepairAll>
										<div class="tile-icon"><i class="icon">build</i></div>
										<span class="tile-name truncate">Repair</span>
										<div class="tile-foot cost repair-foot">
											@if ( RepairBusy )
											{
												<span class="repair-foot-line">Repairing...</span>
											}
											else if ( (BuildManager.Instance?.RepairAllCost() ?? 0) <= 0 )
											{
												<span class="repair-foot-line">Repairs</span>
												<span class="repair-foot-line">Complete</span>
											}
											else
											{
												<span class="repair-foot-line">@Format(BuildManager.Instance?.RepairAllCost() ?? 0)</span>
											}
										</div>
									</div>
									<div class="dock-tile" onclick=@OpenWorkers>
										<div class="tile-icon"><i class="icon">engineering</i></div>
										<span class="tile-name truncate">Workers</span>
										<span class="tile-foot sub">@WorkerCount/@MaxWorkers</span>
									</div>
									<div class="dock-tile @(ExpeditionReady ? "ready" : "")" onclick=@OpenExpeditions>
										<div class="tile-icon"><i class="icon">explore</i></div>
										<span class="tile-name truncate">Scouts</span>
										<span class="tile-foot sub truncate">@ExpeditionChipHint</span>
									</div>
									@if ( IsSurvival )
									{
										<div class="dock-tile" onclick=@OpenMilestones>
											<div class="tile-icon"><i class="icon">emoji_events</i></div>
											<span class="tile-name truncate">Goals</span>
											<span class="tile-foot sub">@MilestonesDone/@MilestonesTotal</span>
										</div>
										<div class="dock-tile @(PrestigeAvailable ? "ready" : "")" onclick=@OpenLegacy>
											<div class="tile-icon"><i class="icon">auto_awesome</i></div>
											<span class="tile-name truncate">Legacy</span>
											<span class="tile-foot sub truncate">@LegacyChipHint</span>
										</div>
									}
									else
									{
										<div class="dock-tile" onclick=@OpenCureProgress>
											<div class="tile-icon"><i class="icon">science</i></div>
											<span class="tile-name truncate">Research</span>
											<span class="tile-foot sub">Tier @Core.Save.CureResearchTier</span>
										</div>
									}
								</div>

								@if ( IsSurvival )
								{
									<div class="dock-start">
										<div class="btn primary lg start-btn" onclick=@StartNight>
											<i class="icon">sports_martial_arts</i>
											<div class="start-text">
												<span class="start-title">Start Night</span>
												<span class="start-sub">Prepare your defenses</span>
											</div>
										</div>
									</div>
								}
							</div>
						</div>
					</div>

					<div class="controls-hint">LMB place / select · RMB or Esc cancel · WASD pan · Scroll zoom · H tips</div>

					@if ( Placing is BuildableId placingId )
					{
						var placingDef = BuildableCatalog.Get( placingId );
						<div class="place-preview card">
							<div class="pp-hero">
								<div class="pp-icon-wrap">
									<i class="icon pp-icon">@placingDef.Icon</i>
								</div>
								<div class="pp-title">
									<span class="pp-name">@placingDef.Name</span>
									<span class="pp-sub">@placingDef.Subtitle</span>
								</div>
							</div>
							<div class="pp-desc">@placingDef.Description</div>
							<div class="pp-stats">
								@foreach ( var s in placingDef.PlacementStats() )
								{
									<div class="pp-stat">
										<div class="pp-stat-left">
											<i class="icon stat-ic">@StatIcon(s.Label)</i>
											<span class="k">@s.Label</span>
										</div>
										<span class="v">@s.Value</span>
									</div>
								}
							</div>
							<div class="pp-hint">Click terrain to place · RMB or Esc cancel</div>
							@if ( BuildManager.CountsTowardPlotStructureLimit( placingId ) )
							{
								<div class="pp-hint plot-cap">Max @GameConstants.MaxPlotStructures towers &amp; barracks per plot — claim adjacent land to expand.</div>
							}
						</div>
					}
					else if ( Moving is PlacedBuilding moving )
					{
						var movingDef = BuildableCatalog.Get( moving.Type );
						<div class="place-preview card">
							<div class="pp-hero">
								<div class="pp-icon-wrap">
									<i class="icon pp-icon">@movingDef.Icon</i>
								</div>
								<div class="pp-title">
									<span class="pp-name">Move @movingDef.Name</span>
									<span class="pp-sub">Relocate this structure</span>
								</div>
							</div>
							<div class="pp-hint">Click terrain to move · RMB or Esc cancel</div>
							@if ( BuildManager.CountsTowardPlotStructureLimit( moving.Type ) )
							{
								<div class="pp-hint plot-cap">Max @GameConstants.MaxPlotStructures towers &amp; barracks per plot — claim adjacent land to expand.</div>
							}
						</div>
					}
				}
			</div>
		}

		@if ( DailyPending )
		{
			<div class="overlay">
				<div class="modal confirm daily-modal">
					<i class="icon confirm-icon welcome">calendar_month</i>
					<div class="confirm-title">Daily Supply Drop</div>
					<div class="daily-streak">@DailyStreakLabel</div>
					<div class="confirm-body">Thanks for coming back, Commander.</div>
					<div class="welcome-loot">
						<div class="loot-row daily-reward">
							<i class="icon">recycling</i>
							<span>@DailyRewardLabel</span>
						</div>
						@if ( DailyStreak < GameConstants.DailyStreakCap )
						{
							<div class="daily-next">@DailyNextLabel</div>
						}
					</div>
					<div class="btn primary daily-claim" onclick=@ClaimDaily><i class="icon">redeem</i><span>Claim</span></div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.NightRecap && NightRecap is not null )
		{
			<div class="overlay">
				<div class="modal confirm recap-modal">
					<i class="icon confirm-icon welcome">bedtime</i>
					<div class="confirm-title">Night @NightRecap.ClearedNight Cleared</div>
					<div class="confirm-body">Dawn breaks — prepare for Night @NightRecap.NextNight.</div>

					<div class="welcome-loot">
						<div class="loot-row">
							<i class="icon">recycling</i>
							<span>+@Format(NightRecap.ClearBonus) Scrap (survival bonus)</span>
						</div>
						@if ( NightRecap.FirstNightBonus > 0 )
						{
							<div class="loot-row">
								<i class="icon">emoji_events</i>
								<span>+@Format(NightRecap.FirstNightBonus) Scrap (first night)</span>
							</div>
						}
						@if ( NightRecap.PlotExpansionBonus > 0 )
						{
							<div class="loot-row">
								<i class="icon">map</i>
								<span>+@Format(NightRecap.PlotExpansionBonus) Scrap (claim a plot)</span>
							</div>
						}
					</div>

					<div class="recap-status">
						@foreach ( var line in NightRecap.StatusLines )
						{
							<div class="recap-line @(line.Warn ? "warn" : "")">
								<i class="icon">@line.Icon</i>
								<span class="recap-text">@line.Text</span>
								@if ( !string.IsNullOrEmpty( line.Detail ) )
								{
									<span class="recap-detail">@line.Detail</span>
								}
							</div>
						}
					</div>

					@if ( !string.IsNullOrEmpty( NightRecap.UnlockMsg ) )
					{
						<div class="recap-unlock">
							<i class="icon">lock_open</i>
							<span>Unlocked: @NightRecap.UnlockMsg</span>
						</div>
					}


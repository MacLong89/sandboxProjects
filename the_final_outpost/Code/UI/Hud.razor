		@if ( !DailyPending && WelcomePending && Core.Welcome.Any )
		{
			<div class="overlay">
				<div class="modal confirm">
					<i class="icon confirm-icon welcome">redeem</i>
					<div class="confirm-title">Welcome back!</div>

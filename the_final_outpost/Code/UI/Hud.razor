	protected override void OnUpdate()
	{
		if ( Core is null ) return;

		if ( LeaderboardOpen && !_lbFetchStarted )
		{
			_lbFetchStarted = true;
			_ = FetchLeaderboardAsync();
		}

		if ( Input.Pressed( "TutorialTips" ) )
			Core.ToggleTutorialTipsHidden();
		if ( Input.Pressed( "Score" ) )
		{
			if ( Core?.ShopOpen != true )
				UiClick();
			Core.ToggleShop();
		}

		if ( Input.Pressed( "Leaderboard" ) )
		{
			if ( Core.LeaderboardOpen ) CloseLeaderboard();
			else OpenLeaderboard();
		}
	}

	private async Task FetchLeaderboardAsync()
	{
		_lbLoading = true;
		StateHasChanged();

		var entries = await LeaderboardService.FetchDisplayAsync( SaveManager.SurvivalSave, 100 );
		_lbEntries = entries.Select( e => new LbEntry
		{
			Rank = e.Rank,
			Name = e.Name,
			Nights = e.Nights,
			IsLocal = e.IsLocal,
			IsInProgress = e.IsInProgress
		} ).ToList();

		_lbLoading = false;
		StateHasChanged();
	}

	private sealed class LbEntry
	{
		public int Rank;
		public string Name;
		public int Nights;
		public bool IsLocal;
		public bool IsInProgress;
	}

	protected override int BuildHash() => System.HashCode.Combine(
		System.HashCode.Combine( Phase, ShopOpen, SettingsOpen, LeaderboardOpen, RecruitOpen, WorkersOpen, ConfirmReset, HasRunInProgress ),
		System.HashCode.Combine( Core?.Wallet.Scrap ?? 0, Placing, Moving?.Type ),
		System.HashCode.Combine(
			System.HashCode.Combine( CorePercent, WallPercent, DefensesPercent, RecruitsPercent, WorkersPercent ),
			ZombiesLeft, Core?.Save.CurrentNight ?? 0, ProgressNight, NightRecap?.ClearedNight ?? 0 ),
		System.HashCode.Combine(
			System.HashCode.Combine( Selected?.Name?.GetHashCode() ?? -1, SelHpPercent, DefenderCount, WorkerCount, _lbEntries.Count, _lbLoading, RepairLineHash ),
			RepairBusy ),
		System.HashCode.Combine( (int)(Core?.Resources.Get( ResourceKind.Wood ) ?? 0), (int)(Core?.Resources.Get( ResourceKind.Stone ) ?? 0), (int)(Core?.Resources.Get( ResourceKind.Water ) ?? 0) ),
		System.HashCode.Combine(
			(int)(IncomeRates.ScrapPerSec * 10f), (int)(IncomeRates.FoodPerSec * 10f),
			(int)(IncomeRates.SuppliesPerSec * 10f), (int)(IncomeRates.KnowledgePerSec * 10f),
			WorkerCount, DefenderCount ),
		System.HashCode.Combine( ExpeditionsOpen, ExpeditionActive, (int)(Exp?.SecondsRemaining ?? 0f), ObjectivesDone, WelcomePending, ObjectiveToast?.GetHashCode() ?? 0, System.HashCode.Combine( ExpSoldiers, ExpCivilians ) ),
		System.HashCode.Combine(
			System.HashCode.Combine( MilestonesOpen, CatalogOpen, LegacyOpen, DailyPending, MilestonesDone, PrestigeLevel, LegacyPoints ),
			System.HashCode.Combine( ComboStreak, (int)(ComboFraction * 20f), TutorialTip?.Id?.GetHashCode() ?? 0, TutorialTipsHidden, ShowTipsToggle, CatalogDiscovered ) )
	);

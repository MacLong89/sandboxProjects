	private void AdjustVolume( string channel, float delta )
	{
		switch ( channel )
		{
			case "master": AudioSettings.Master = AudioSettings.Master + delta; break;
			case "sfx": AudioSettings.Sfx = AudioSettings.Sfx + delta; break;
			case "ambience": AudioSettings.Ambience = AudioSettings.Ambience + delta; break;

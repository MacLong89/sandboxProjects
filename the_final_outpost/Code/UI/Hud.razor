	private static string FormatTime( float s )
	{
		s = MathF.Max( 0f, s );
		var m = (int)(s / 60f);
		var sec = (int)(s % 60f);
		return m > 0 ? $"{m}m {sec:00}s" : $"{sec}s";
	}


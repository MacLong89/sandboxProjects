	private static string ActionIcon( string label )
	{
		if ( string.IsNullOrEmpty( label ) ) return "touch_app";
		if ( label.Contains( "Upgrade", StringComparison.OrdinalIgnoreCase ) || label.Contains( "Reinforce", StringComparison.OrdinalIgnoreCase ) || label.Contains( "Fortify", StringComparison.OrdinalIgnoreCase ) ) return "trending_up";
		if ( label.Contains( "Repair", StringComparison.OrdinalIgnoreCase ) ) return "build";
		if ( label.Contains( "Sell", StringComparison.OrdinalIgnoreCase ) || label.Contains( "Tear", StringComparison.OrdinalIgnoreCase ) || label.Contains( "Dismiss", StringComparison.OrdinalIgnoreCase ) ) return "delete";
		if ( label.Contains( "Recruit", StringComparison.OrdinalIgnoreCase ) || label.Contains( "Train", StringComparison.OrdinalIgnoreCase ) ) return "military_tech";
		if ( label.Contains( "Claim", StringComparison.OrdinalIgnoreCase ) ) return "flag";
		if ( label.Contains( "Hire", StringComparison.OrdinalIgnoreCase ) ) return "person_add";
		if ( label.Contains( "Recall", StringComparison.OrdinalIgnoreCase ) ) return "undo";
		return "touch_app";
	}


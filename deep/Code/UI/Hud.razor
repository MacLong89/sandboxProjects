@using Sandbox
@using Sandbox.UI
@using Deep
@inherits PanelComponent
@namespace Deep.UI

<root>
	@if ( Game is not null )
	{
		@* Surface brand / economy *@
		@if ( Phase == GamePhase.SurfaceIdle || Phase == GamePhase.DiverHub || Phase == GamePhase.JournalMenu )
		{
			<div class="brand-block ui-panel">
				<div class="brand">DEEP</div>
				<div class="meta-row">
					<div class="ui-chip">BEST @(Deepest)m</div>
					<div class="ui-chip gold">$@(Money)</div>
					<div class="ui-chip shell">@(Shells) shells</div>
					<div class="ui-chip">DAY @DayNumber</div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.SurfaceIdle )
		{
			<div class="surface-panel">
				<div class="surface-actions">
					<button class="btn dive-cta" onclick="@ClickStartDive">START DIVE</button>
					<button class="btn hub-cta" onclick="@OpenHub">DIVER HUB</button>
					<button class="btn hub-cta" onclick="@OpenJournal">JOURNAL</button>
				</div>
				<div class="ui-footnote">Cursor free on the boat · E also starts a dive · Esc closes menus</div>
			</div>
		}

		@if ( Phase == GamePhase.JournalMenu )
		{
			<div class="hub-overlay">
				<div class="hub-window journal-window">
					<div class="hub-header">
						<div class="hub-tabs">
							<button class="hub-tab shop @(JournalTab == JournalTabKind.Loot ? "on" : "")" onclick="@(() => SetJournalTab( JournalTabKind.Loot ))">LOOT</button>
							<button class="hub-tab diver @(JournalTab == JournalTabKind.Creatures ? "on" : "")" onclick="@(() => SetJournalTab( JournalTabKind.Creatures ))">CREATURES</button>
							<button class="hub-tab diver @(JournalTab == JournalTabKind.Zones ? "on" : "")" onclick="@(() => SetJournalTab( JournalTabKind.Zones ))">ZONES</button>
							<button class="hub-tab diver @(JournalTab == JournalTabKind.Story ? "on" : "")" onclick="@(() => SetJournalTab( JournalTabKind.Story ))">STORY</button>
						</div>
						<div class="hub-currencies">
							<button class="hub-close" onclick="@CloseMenus">X</button>
						</div>
					</div>
					<div class="journal-body">
						@if ( JournalTab == JournalTabKind.Loot )
						{
							@foreach ( var def in CollectibleCatalog.All )
							{
								var known = Game.Progression.DiscoveredCollectibles.Contains( def.Id );
								<div class="journal-row ui-card">
									<div class="journal-name">@(known ? def.DisplayName : "???")</div>
									<div class="journal-desc">@(known ? def.Description : "Undiscovered salvage.")</div>
									@if ( known )
									{
										<div class="journal-meta">$@((int)def.BaseValue) · @def.Rarity</div>
									}
								</div>
							}
						}
						else if ( JournalTab == JournalTabKind.Creatures )
						{
							@foreach ( var def in CreatureCatalog.All )
							{
								var known = Game.Progression.DiscoveredCreatures.Contains( def.Id );
								<div class="journal-row ui-card">
									<div class="journal-name">@(known ? def.DisplayName : "???")</div>
									<div class="journal-desc">@(known ? def.Description : "Unknown lifeform.")</div>
									@if ( known )
									{
										<div class="journal-meta">@def.Disposition</div>
									}
								</div>
							}
						}
						else if ( JournalTab == JournalTabKind.Zones )
						{
							@foreach ( DepthZone zone in Enum.GetValues<DepthZone>() )
							{
								var known = Game.Progression.DiscoveredZones.Contains( zone.ToString() );
								<div class="journal-row ui-card">
									<div class="journal-name">@(known ? zone.ToString() : "???")</div>
									<div class="journal-desc">@(known ? "Charted depth band." : "Unexplored waters.")</div>
								</div>
							}
						}
						else
						{
							@foreach ( var def in StoryCatalog.All )
							{
								var known = Game.Progression.DiscoveredStories.Contains( def.Id );
								<div class="journal-row ui-card">
									<div class="journal-name">@(known ? def.Title : "???")</div>
									<div class="journal-desc">@(known ? def.Text : "A mystery waits in the dark.")</div>
									@if ( known )
									{
										<div class="journal-meta">@def.RelatedMystery</div>
									}
								</div>
							}
						}
					</div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.DiverHub )
		{
			<div class="hub-overlay">
				<div class="hub-window">
					<div class="hub-header">
						<div class="hub-tabs">
							<button class="hub-tab shop @(HubPage == HubPageKind.Shop ? "on" : "")" onclick="@(() => SetHubPage( HubPageKind.Shop ))">SHOP</button>
							<button class="hub-tab diver @(HubPage == HubPageKind.Diver ? "on" : "")" onclick="@(() => SetHubPage( HubPageKind.Diver ))">DIVER</button>
						</div>
						<div class="hub-currencies">
							<div class="hub-cur gold"><div class="hub-cur-ico coin"></div>@MoneyFormatted</div>
							<div class="hub-cur shell"><div class="hub-cur-ico shell"></div>@Shells</div>
							<button class="hub-close" onclick="@CloseMenus">X</button>
						</div>
					</div>

					@if ( HubPage == HubPageKind.Shop )
					{
						<div class="hub-columns shop-view">
							<div class="hub-col shop">
								<div class="hub-col-head">ITEMS</div>
								<div class="shop-filters">
									<button class="filter-chip @(ShopFilter == ShopCategory.All ? "on" : "")" onclick="@(() => SetShopFilter( ShopCategory.All ))">All</button>
									<button class="filter-chip @(ShopFilter == ShopCategory.Equipment ? "on" : "")" onclick="@(() => SetShopFilter( ShopCategory.Equipment ))">Gear</button>
									<button class="filter-chip @(ShopFilter == ShopCategory.Tools ? "on" : "")" onclick="@(() => SetShopFilter( ShopCategory.Tools ))">Tools</button>
									<button class="filter-chip @(ShopFilter == ShopCategory.Resources ? "on" : "")" onclick="@(() => SetShopFilter( ShopCategory.Resources ))">Res</button>
								</div>
								<div class="hub-list">
									@foreach ( var item in ShopItems )
									{
										var can = Game.Shop.CanBuy( item, Game.Progression, Game.Loadout );
										<div class="shop-row clickable @(SelectedShopId == item.Id ? "selected" : "") @(ShopFlashing( item.Id ) ? "flash-success" : "")" onclick="@(() => SelectShop( item.Id ))">
											<div class="shop-ico" style="background-image: url( '@item.IconPath' );"></div>
											<div class="shop-info">
												<div class="shop-name">@item.DisplayName</div>
												<div class="shop-desc">@item.Description</div>
											</div>
											<button class="btn shop-buy @(can ? "can" : "disabled")" onclick="@(() => BuyShop( item.Id ))">$@((int)item.GoldCost)</button>
										</div>
									}
								</div>
								<div class="hub-col-foot">NEW STOCK IN: @StockTimer</div>
							</div>

							<div class="hub-col upgrades">
								<div class="hub-col-head">UPGRADES</div>
								<div class="hub-list">
									@foreach ( var up in UpgradeCatalog.All )
									{
										var level = Game.Upgrades.GetLevel( up.Id );
										var maxed = level >= up.MaxLevel;
										var cost = maxed ? 0 : (int)Game.Upgrades.NextCost( up.Id );
										var can = Game.Upgrades.CanBuy( up.Id );
										<div class="upgrade-card clickable @(SelectedUpgradeId == up.Id ? "selected" : "") @(UpgradeFlashing( up.Id ) ? "flash-success" : "")" onclick="@(() => SelectUpgrade( up.Id ))">
											<div class="upgrade-top">
												<div class="upgrade-name">@up.DisplayName</div>
												<div class="upgrade-level">@level / @up.MaxLevel</div>
											</div>
											<div class="upgrade-desc">@up.Description</div>
											<div class="seg-bar">
												@for ( var s = 0; s < up.MaxLevel && s < 10; s++ )
												{
													<div class="seg @(s < level ? "on" : "")"></div>
												}
											</div>
											@if ( maxed )
											{
												<button class="btn disabled">MAX</button>
											}
											else
											{
												var shell = Game.Upgrades.UsesShells( up.Id );
												<button class="btn shop-buy @(can ? "can" : "disabled")" onclick="@(() => Buy( up.Id ))">@(shell ? $"{cost} sh" : $"${cost}")</button>
											}
										</div>
									}
								</div>
								<div class="hub-col-foot">GOLD &amp; SHELL UPGRADES</div>
							</div>
						</div>
					}
					else
					{
						<div class="hub-columns diver-view">
							<div class="hub-col diver-stats">
								<div class="hub-col-head">DIVER STATS</div>
								<div class="diver-stats-grid">
									<div class="diver-stat-block">
										<div class="diver-section-head">VITALS</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">OXYGEN</div>
											<div class="diver-stat-val accent">@StatOxygen s</div>
										</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">STAMINA</div>
											<div class="diver-stat-val">@StatStamina</div>
										</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">HEALTH</div>
											<div class="diver-stat-val health">@StatHealth</div>
										</div>
									</div>

									<div class="diver-stat-block">
										<div class="diver-section-head">PERFORMANCE</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">SWIM SPEED</div>
											<div class="diver-stat-val">@StatSwimSpeed</div>
										</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">SAFE DEPTH</div>
											<div class="diver-stat-val accent">@StatSafeDepth m</div>
										</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">HAUL</div>
											<div class="diver-stat-val">@StatHaul slots</div>
										</div>
									</div>

									<div class="diver-stat-block">
										<div class="diver-section-head">CAREER</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">DEEPEST</div>
											<div class="diver-stat-val gold">@Deepest m</div>
										</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">SUCCESS</div>
											<div class="diver-stat-val">@SuccessfulDives</div>
										</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">FAILED</div>
											<div class="diver-stat-val">@FailedDives</div>
										</div>
										<div class="diver-stat-row">
											<div class="diver-stat-key">FOUND</div>
											<div class="diver-stat-val">@DiscoveredCount / @TotalCollectibles</div>
										</div>
									</div>
								</div>

								<div class="diver-loadout-section">
									<div class="diver-section-head">LOADOUT</div>
									<div class="loadout-grid">
										@for ( var ti = 0; ti < HotbarSlots; ti++ )
										{
											var tool = ToolCatalog.GetBySlot( ti );
											if ( tool is null ) continue;
											var owned = SlotOwned( ti );
											var reserve = owned && !tool.InfiniteCharges ? Game.Loadout.GetReserve( ti ) : -1;
											<div class="loadout-row @(owned ? "owned" : "locked")">
												<div class="loadout-ico" style="background-image: url( '@tool.IconPath' );"></div>
												<div class="loadout-info">
													<div class="loadout-name">@tool.DisplayName</div>
													<div class="loadout-meta">@(owned ? (tool.InfiniteCharges ? "Equipped" : $"{reserve} charges") : "Locked")</div>
												</div>
											</div>
										}
									</div>
								</div>
								<div class="hub-col-foot">STATS REFLECT CURRENT UPGRADES &amp; GEAR</div>
							</div>

							<div class="hub-col history">
								<div class="hub-col-head">DIVE HISTORY</div>
								<div class="hub-list">
									@if ( HistoryEntries.Count == 0 )
									{
										<div class="history-empty">No dives logged yet. Complete a dive to fill this log.</div>
									}
									else
									{
										@foreach ( var h in HistoryEntries )
										{
											<div class="history-card @(h.Success ? "ok" : "fail")">
												<div class="history-meta">Day @h.DayNumber · @h.TimeOfDay</div>
												<div class="history-row">
													<div class="history-stat">@((int)h.MaxDepthMeters)m</div>
													<div class="history-stat">@FormatDuration( h.DurationSeconds )</div>
													<div class="history-stat money">$@((int)h.MoneyEarned)</div>
												</div>
												<div class="history-loot">
													@for ( var li = 0; li < h.LootLabels.Count; li++ )
													{
														var ico = li < h.LootIcons.Count ? h.LootIcons[li] : "/ui/icons/map_loot.png";
														<div class="loot-chip">
															<div class="loot-ico" style="background-image: url( '@ico' );"></div>
														</div>
													}
												</div>
											</div>
										}
									}
								</div>
								<div class="hub-col-foot">Showing last @HistoryEntries.Count dives</div>
							</div>
						</div>
					}
				</div>
				<div class="hub-esc">ESC CLOSE</div>
			</div>
		}

		@if ( Phase == GamePhase.Diving || Phase == GamePhase.Paused )
		{
			@* Top-left: depth + pressure *@
			<div class="ui-col accent-cyan hud-solid dive-status">
				<div class="ui-col-head">DIVE STATUS</div>
				<div class="diver-stat-block compact">
					<div class="diver-stat-row">
						<div class="diver-stat-key">DEPTH</div>
						<div class="diver-stat-val">@(CurrentDepth)m</div>
					</div>
					<div class="diver-stat-row @(PressureWarn ? "warn" : "") @(PressureDamage ? "crit" : "")">
						<div class="diver-stat-key">PRESSURE</div>
						<div class="diver-stat-val">@(PressureMult)x</div>
					</div>
				</div>
			</div>

			@* Top-right: run data + objectives stacked *@
			<div class="hud-top-right">
				<div class="ui-col accent-cyan hud-solid meta-panel">
					<div class="ui-col-head">RUN DATA</div>
					<div class="meta-grid">
						<div class="meta-item">
							<div class="meta-icon coin"></div>
							<div class="meta-text">@MoneyFormatted</div>
						</div>
						<div class="meta-item">
							<div class="meta-icon clock"></div>
							<div class="meta-text">@ClockTime</div>
						</div>
						<div class="meta-item">
							<div class="meta-icon day"></div>
							<div class="meta-text">DAY @DayNumber</div>
						</div>
					</div>
				</div>

				<div class="ui-col accent-blue hud-solid objective-panel">
					<div class="ui-col-head">CURRENT OBJECTIVE</div>
					<div class="objective-body">
						<div class="objective-title">@ObjectiveTitle</div>
						@foreach ( var task in ObjectiveTasks )
						{
							<div class="objective-task ui-card @(task.IsComplete ? "done" : "")">
								<div class="task-check @(task.IsComplete ? "done" : "")"></div>
								<div class="task-label">@task.Label</div>
							</div>
						}
					</div>
				</div>
			</div>

			@* Bottom-left: compact log + vitals *@
			<div class="corner-log">
				<div class="ui-col accent-purple hud-solid log-panel">
					<div class="ui-col-head">DIVE LOG</div>
					<div class="hub-list compact">
						@if ( LogEntries.Count == 0 )
						{
							<div class="history-empty">No finds yet</div>
						}
						else
						{
							@foreach ( var entry in LogEntries )
							{
								<div class="loadout-row @(entry.Known ? "owned" : "locked")">
									<div class="loadout-ico" style="background-image: url( '@entry.IconPath' );"></div>
									<div class="loadout-info">
										<div class="loadout-name">@(entry.Known ? entry.Title : "Undiscovered")</div>
									</div>
								</div>
							}
						}
					</div>
					<div class="ui-col-foot">LMB · 1-8 · SCAN</div>
				</div>

				<div class="ui-col accent-purple hud-solid vitals-panel">
					<div class="ui-col-head">VITALS</div>
					<div class="vitals-bar">
					<div class="vital-chip health">
						<div class="vital-ico heart"></div>
						<div class="vital-track"><div class="vital-fill" style="width: @(HealthPercent)%;"></div></div>
						<div class="vital-nums">@HealthCurrent/@HealthMax</div>
					</div>
					<div class="vital-chip oxygen @OxygenClass">
						<div class="vital-ico oxygen"></div>
						<div class="vital-track"><div class="vital-fill" style="width: @(OxygenPercent)%;"></div></div>
						<div class="vital-nums">@(OxygenPercent)%</div>
					</div>
					<div class="vital-chip energy @(IsBoosting ? "active" : "")">
						<div class="vital-ico bolt"></div>
						<div class="vital-track"><div class="vital-fill" style="width: @(BoostPercent)%;"></div></div>
						<div class="vital-nums">@BoostCurrent/@BoostMax</div>
					</div>
					</div>
				</div>
			</div>

			@* Bottom-center: hotbar *@
			<div class="hotbar">
				<div class="ui-col accent-cyan hud-solid hotbar-inner">
					@for ( var i = 0; i < HotbarSlots; i++ )
					{
						var owned = SlotOwned( i );
						var selected = owned && i == SelectedSlot;
						var charges = SlotCharges( i );
						var icon = SlotIcon( i );
						var empty = owned && !SlotHasCharges( i );
						<div class="hot-slot @(selected ? "selected" : "") @(!owned ? "unowned" : "") @(empty ? "empty" : "")">
							<div class="slot-key">@(i + 1)</div>
							@if ( owned )
							{
								@if ( charges > 0 )
								{
									<div class="slot-qty">@charges</div>
								}
								<div class="slot-icon" style="background-image: url( '@icon' );"></div>
							}
						</div>
					}
				</div>
			</div>

			@* Bottom-right: minimap with integrated depth rail *@
			<div class="map-stack">
				<div class="ui-col accent-blue hud-solid minimap">
					<div class="ui-col-head">MAP</div>
					<div class="minimap-body">
						<div class="minimap-depth-rail">
							<div class="rail-mark top">0</div>
							<div class="rail-player" style="top: @(DepthGaugeNeedle)%;"></div>
							<div class="rail-mark bot">200</div>
						</div>
						<div class="minimap-view">
							<div class="minimap-grid"></div>
							@foreach ( var blip in MapBlips )
							{
								var cls = blip.Kind switch
								{
									MinimapBlipKind.Player => "player",
									MinimapBlipKind.Threat => "threat",
									MinimapBlipKind.Loot => "loot",
									_ => "objective"
								};
								<div class="map-blip @cls" style="left: @(Pct( blip.Nx )); top: @(Pct( blip.Ny ));"></div>
							}
						</div>
					</div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.DiveSuccess && Summary is not null )
		{
			<div class="hub-overlay recap-overlay">
				<div class="hub-window recap-window">
					<div class="hub-header">
						<div class="hub-tabs">
							<div class="hub-tab diver on">@(Summary.DiveNumber). DIVE RECAP</div>
						</div>
						<div class="hub-currencies">
							<div class="hub-cur gold"><div class="hub-cur-ico coin"></div>@MoneyFormatted</div>
						</div>
					</div>

					<div class="hub-columns recap-cols">
						<div class="hub-col diver-stats">
							<div class="hub-col-head">DIVE STATS</div>
							<div class="hub-list">
								<div class="diver-stat-block">
									<div class="diver-stat-row">
										<div class="diver-stat-key">MAX DEPTH</div>
										<div class="diver-stat-val">@(DiveMax) m</div>
									</div>
									@if ( BrokeRecord )
									{
										<div class="record-tag">NEW RECORD!</div>
									}
									<div class="diver-stat-row">
										<div class="diver-stat-key">DIVE TIME</div>
										<div class="diver-stat-val">@DiveTimeFormatted</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">ITEMS COLLECTED</div>
										<div class="diver-stat-val">@SummaryItems</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">TOTAL VALUE</div>
										<div class="diver-stat-val">$@(SummaryHaul)</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">OXYGEN USED</div>
										<div class="diver-stat-val">@(OxygenUsedPct)%</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">DAMAGE TAKEN</div>
										<div class="diver-stat-val">@(DamageTakenPct)%</div>
									</div>
								</div>
							</div>
						</div>

						<div class="hub-col shop">
							<div class="hub-col-head">TOP ITEMS</div>
							<div class="hub-list">
								@if ( Summary.TopItems.Count == 0 )
								{
									<div class="history-empty">No items collected</div>
								}
								else
								{
									@foreach ( var item in Summary.TopItems )
									{
										<div class="shop-row">
											<div class="item-dot @RarityClass( item.Rarity )"></div>
											<div class="shop-info">
												<div class="shop-name">@item.Name</div>
												<div class="shop-desc">$@((int)item.Value)</div>
											</div>
										</div>
									}
								}
							</div>
						</div>

						<div class="hub-col history">
							<div class="hub-col-head">DISCOVERIES</div>
							<div class="hub-list">
								<div class="diver-stat-block">
									<div class="diver-stat-row">
										<div class="diver-stat-key">CREATURES</div>
										<div class="diver-stat-val">@Summary.CreaturesFound / @Summary.CreaturesTotal</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">ARTIFACTS</div>
										<div class="diver-stat-val">@Summary.ArtifactsFound / @Summary.ArtifactsTotal</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">LOCATIONS</div>
										<div class="diver-stat-val">@Summary.LocationsFound / @Summary.LocationsTotal</div>
									</div>
								</div>
							</div>
						</div>

						<div class="hub-col upgrades">
							<div class="hub-col-head">PAYOUT</div>
							<div class="hub-list">
								<div class="diver-stat-block">
									<div class="diver-section-head">BONUS BREAKDOWN</div>
									@if ( Summary.Bonuses.Count == 0 )
									{
										<div class="history-empty">No bonuses</div>
									}
									else
									{
										@foreach ( var b in Summary.Bonuses )
										{
											<div class="diver-stat-row">
												<div class="diver-stat-key">@b.Label</div>
												<div class="diver-stat-val payout">+$@((int)b.Amount)</div>
											</div>
										}
									}
									<div class="diver-stat-row total">
										<div class="diver-stat-key">TOTAL BONUS</div>
										<div class="diver-stat-val payout">+$@((int)Summary.BonusValue)</div>
									</div>
								</div>
								<div class="diver-stat-block earned-block">
									<div class="diver-section-head">TOTAL EARNED</div>
									<div class="earned-value">$@(SummaryEarned)</div>
								</div>
							</div>
						</div>
					</div>

					<div class="recap-actions">
						<button class="btn recap-secondary" onclick="@ReturnNoSell">RETURN TO SURFACE</button>
						<button class="btn recap-primary" onclick="@SellContinue">SELL &amp; CONTINUE</button>
					</div>

					<div class="recap-footer ui-col accent-cyan">
						<div class="prog-level">PROGRESSION LEVEL @Summary.ProgressionLevel</div>
						<div class="prog-bar-wrap">
							<div class="seg-bar wide">
								@for ( var px = 0; px < 10; px++ )
								{
									<div class="seg @(px < ProgressXpPercent / 10 ? "on" : "")"></div>
								}
							</div>
							<div class="prog-xp">@Summary.ProgressionXp / @Summary.ProgressionXpMax XP</div>
						</div>
						<div class="prog-next">NEXT: @Summary.NextUnlock</div>
					</div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.DiveFailed )
		{
			<div class="hub-overlay recap-overlay fail">
				<div class="hub-window recap-window compact">
					<div class="hub-header">
						<div class="hub-tabs">
							<div class="hub-tab shop on fail-tab">DIVE FAILED</div>
						</div>
					</div>
					<div class="fail-hero">@FailureTitle</div>

					<div class="hub-columns diver-view">
						<div class="hub-col diver-stats">
							<div class="hub-col-head">LAST DIVE</div>
							<div class="hub-list">
								<div class="diver-stat-block">
									<div class="diver-stat-row">
										<div class="diver-stat-key">MAX DEPTH</div>
										<div class="diver-stat-val">@(DiveMax) m</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">DIVE TIME</div>
										<div class="diver-stat-val">@DiveTimeFormatted</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">HAUL LOST</div>
										<div class="diver-stat-val lost">$@(SummaryHaul)</div>
									</div>
									<div class="diver-stat-row">
										<div class="diver-stat-key">ITEMS LOST</div>
										<div class="diver-stat-val">@SummaryItems</div>
									</div>
								</div>
							</div>
						</div>

						<div class="hub-col history">
							<div class="hub-col-head">LOST ITEMS</div>
							<div class="hub-list">
								@if ( Summary is null || Summary.TopItems.Count == 0 )
								{
									<div class="history-empty">Nothing aboard</div>
								}
								else
								{
									@foreach ( var item in Summary.TopItems )
									{
										<div class="shop-row">
											<div class="item-dot @RarityClass( item.Rarity )"></div>
											<div class="shop-info">
												<div class="shop-name">@item.Name</div>
												<div class="shop-desc">$@((int)item.Value)</div>
											</div>
										</div>
									}
								}
							</div>
						</div>
					</div>

					<div class="recap-actions">
						<button class="btn recap-primary" onclick="@DismissFail">RETURN TO SURFACE</button>
					</div>
				</div>
			</div>
		}

		@if ( Phase == GamePhase.Paused )
		{
			<div class="hub-overlay pause-overlay">
				<div class="hub-window pause-window">
					<div class="hub-header">
						<div class="hub-tabs">
							<div class="hub-tab diver on">PAUSED</div>
						</div>
					</div>
					<div class="ui-footnote center">Esc to resume</div>
				</div>
			</div>
		}

		@if ( Phase != GamePhase.DiveSuccess && Phase != GamePhase.DiveFailed && Phase != GamePhase.Paused && Phase != GamePhase.UpgradeMenu && Phase != GamePhase.JournalMenu && Phase != GamePhase.DiverHub )
		{
			@* Left-center status popups — matches dive-status width *@
			<div class="status-stack">
				@if ( !string.IsNullOrEmpty( Status ) )
				{
					<div class="ui-card toast">@Status</div>
				}
				@if ( (Phase == GamePhase.Diving || Phase == GamePhase.Paused) && (IsCriticalOxygen || IsLowOxygen) )
				{
					<div class="ui-card alert oxygen-alert @(IsCriticalOxygen ? "crit" : "")">
						@(IsCriticalOxygen ? "LOW OXYGEN!" : "Oxygen running low")
					</div>
				}
				@if ( (Phase == GamePhase.Diving || Phase == GamePhase.Paused) && PressureWarn )
				{
					<div class="ui-card alert pressure-alert">
						@(PressureDamage ? "Extreme pressure! Return to shallower water!" : "Pressure rising — mind your suit rating")
					</div>
				}
			</div>
		}
	}
</root>

@code
{
	private enum HubPageKind { Shop, Diver }
	private enum JournalTabKind { Loot, Creatures, Zones, Story }

	private HubPageKind HubPage = HubPageKind.Shop;
	private JournalTabKind JournalTab = JournalTabKind.Loot;
	private DeepGame Game => DeepGame.Instance;
	private GamePhase Phase => Game?.Phase ?? GamePhase.SurfaceIdle;
	private DiverController Diver => Game?.Diver;
	private OxygenComponent Oxygen => Game?.Oxygen;
	private HealthComponent Health => Game?.Health;
	private PressureComponent Pressure => Game?.Pressure;
	private BoostComponent Boost => Game?.Boost;
	private ToolSystem Tools => Game?.Tools;
	private DiveRunState Run => Game?.Run;
	private DiveSummary Summary => Game?.LastSummary;

	private int CurrentDepth => (int)(Diver?.CurrentDepthMeters ?? 0f);
	private int DiveMax => (int)(Diver?.DiveMaxDepthMeters ?? Run?.MaxDepthMeters ?? 0f);
	private int Deepest => (int)(Game?.Progression.DeepestEverMeters ?? 0f);
	private int SuccessfulDives => Game?.Progression.SuccessfulDives ?? 0;
	private int FailedDives => Game?.Progression.FailedDives ?? 0;
	private int StatOxygen => (int)(Game?.Balance.MaxOxygenSeconds ?? 28f);
	private int StatStamina => (int)(Game?.Balance.BoostMaxEnergy ?? 40f);
	private int StatHealth => (int)(Game?.Balance.MaxHealth ?? 55f);
	private int StatSwimSpeed => (int)(Game?.Balance.SwimSpeed ?? 9f);
	private int StatAscentSpeed => (int)(Game?.Balance.AscentSpeed ?? 10f);
	private int StatDescentSpeed => (int)(Game?.Balance.DescentSpeed ?? 11f);
	private int StatSafeDepth => (int)(Game?.Balance.SafeDepthMeters ?? 18f);
	private int StatHaul => Game?.Balance.BaseHaulCapacity ?? 4;
	private int Money => (int)(Game?.Progression.Money ?? 0f);
	private int Shells => (int)(Game?.Progression.Shells ?? 0f);
	private string MoneyFormatted => Money.ToString( "N0" );
	private int DayNumber => Game?.Clock?.DayNumber ?? 1;
	private string ClockTime => Game?.Clock?.TimeFormatted ?? "08:35 AM";

	private ShopCategory ShopFilter = ShopCategory.All;
	private string SelectedShopId = "";
	private string SelectedUpgradeId = "";
	private string _shopFlashId = "";
	private string _upgradeFlashId = "";
	private TimeUntil _shopFlashUntil;
	private TimeUntil _upgradeFlashUntil;
	private int _uiPulse;
	private IEnumerable<ShopItemDefinition> ShopItems => ShopCatalog.Filtered( ShopFilter );
	private IReadOnlyList<DiveHistoryEntry> HistoryEntries =>
		Game?.History?.Entries ?? Array.Empty<DiveHistoryEntry>();

	private string StockTimer
	{
		get
		{
			var t = (int)(Time.Now * 10f) % (3 * 3600);
			var left = 3 * 3600 - t;
			var h = left / 3600;
			var m = (left % 3600) / 60;
			var s = left % 60;
			return $"{h:00}:{m:00}:{s:00}";
		}
	}

	private int DiveSeconds => (int)(Summary?.DurationSeconds ?? Run?.DiveDurationSeconds ?? 0f);
	private string DiveTimeFormatted
	{
		get
		{
			var total = DiveSeconds;
			var m = total / 60;
			var s = total % 60;
			return $"{m}:{s:00}";
		}
	}
	private bool BrokeRecord => Summary?.BrokeDepthRecord ?? false;
	private int SummaryItems => Summary?.ItemCount ?? 0;
	private int SummaryHaul => (int)(Summary?.HaulValue ?? 0f);
	private int SummaryEarned => (int)(Summary?.MoneyEarned ?? 0f);
	private int OxygenUsedPct => (int)MathF.Round( (Summary?.OxygenUsedFraction ?? 0f) * 100f );
	private int DamageTakenPct => (int)MathF.Round( (Summary?.DamageTakenFraction ?? 0f) * 100f );
	private int ProgressXpPercent
	{
		get
		{
			if ( Summary is null || Summary.ProgressionXpMax <= 0 ) return 0;
			var t = Summary.ProgressionXp / (float)Summary.ProgressionXpMax * 100f;
			if ( t < 0f ) t = 0f;
			if ( t > 100f ) t = 100f;
			return (int)MathF.Round( t );
		}
	}

	private bool PressureWarn => Pressure?.IsWarning == true || Pressure?.IsDamaging == true;
	private bool PressureDamage => Pressure?.IsDamaging == true;
	private bool IsBoosting => Boost?.IsBoosting ?? false;
	private int DiscoveredCount => Game?.Progression.DiscoveredCollectibles.Count ?? 0;
	private int TotalCollectibles => CollectibleCatalog.All.Count;

	private int OxygenPercent => ClampPct( Oxygen?.Fraction ?? 1f );
	private int HealthPercent => ClampPct( Health?.Fraction ?? 1f );
	private int BoostPercent => ClampPct( Boost?.Fraction ?? 1f );
	private int HealthCurrent => (int)MathF.Round( Health?.CurrentHealth ?? 100f );
	private int HealthMax => (int)MathF.Round( Health?.MaxHealth ?? 100f );
	private int BoostCurrent => (int)MathF.Round( Boost?.CurrentEnergy ?? 100f );
	private int BoostMax => (int)MathF.Round( Boost?.MaxEnergy ?? 100f );

	/// <summary>Atmospheric pressure vs surface — rises with depth.</summary>
	private string PressureMult
	{
		get
		{
			var depth = Diver?.CurrentDepthMeters ?? 0f;
			var mult = 1f + depth / 150f;
			return mult.ToString( "0.0" );
		}
	}

	private float MaxDepth => Game?.Balance.MaxOceanDepthMeters ?? 200f;

	private int DepthGaugeFill
	{
		get
		{
			var t = CurrentDepth / MathF.Max( 1f, MaxDepth );
			return ClampPct( t );
		}
	}

	private int DepthGaugeNeedle
	{
		get
		{
			var t = CurrentDepth / MathF.Max( 1f, MaxDepth );
			return (int)MathF.Round( Math.Clamp( t, 0f, 1f ) * 88f + 6f );
		}
	}

	private string ObjectiveTitle => Game?.Objectives?.Title ?? "Explore The Depths";
	private IReadOnlyList<ObjectiveTask> ObjectiveTasks =>
		Game?.Objectives?.Tasks ?? Array.Empty<ObjectiveTask>();

	private List<DiveLogEntry> LogEntries =>
		Game?.DiveLog?.VisibleEntries().ToList() ?? new List<DiveLogEntry>();

	private int HotbarSlots => ToolCatalog.SlotCount;
	private int SelectedSlot => Tools?.Hotbar.SelectedIndex ?? 0;

	private IReadOnlyList<MinimapBlip> MapBlips =>
		Tools?.BuildMinimapBlips( Game ) ?? Array.Empty<MinimapBlip>();

	private bool IsLowOxygen => Oxygen?.IsLow ?? false;
	private bool IsCriticalOxygen => Oxygen?.IsCritical ?? false;
	private string Status => Game?.StatusMessage ?? "";

	private string FailureTitle => (Summary?.FailureReason ?? Run?.FailureReason ?? DiveFailureReason.None) switch
	{
		DiveFailureReason.OxygenDepleted => "OUT OF OXYGEN",
		DiveFailureReason.HealthDepleted => "SUIT RUPTURED",
		DiveFailureReason.PressureDamage => "CRUSHED",
		DiveFailureReason.LeftWorldBounds => "LOST IN THE DARK",
		_ => "DIVE FAILED"
	};

	private string OxygenClass
	{
		get
		{
			var f = Oxygen?.Fraction ?? 1f;
			var low = Game?.Balance.LowOxygenFraction ?? 0.25f;
			var crit = Game?.Balance.CriticalOxygenFraction ?? 0.1f;
			if ( f <= crit ) return "crit";
			if ( f <= low ) return "low";
			return "";
		}
	}

	private int SlotCharges( int i ) => Tools?.Hotbar.GetCharges( i ) ?? 0;
	private bool SlotHasCharges( int i ) => Tools?.Hotbar.HasCharges( i ) ?? false;
	private bool SlotOwned( int i ) => Game?.Loadout?.IsUnlocked( i ) ?? ( ToolCatalog.GetBySlot( i )?.InfiniteCharges ?? false );
	private string SlotIcon( int i ) => ToolCatalog.GetBySlot( i )?.IconPath ?? "/ui/icons/icon_unknown.png";

	private static string Pct( float n01 ) => $"{(int)MathF.Round( Math.Clamp( n01, 0f, 1f ) * 100f )}%";

	private static int ClampPct( float f )
	{
		var pct = f * 100f;
		if ( pct < 0f ) pct = 0f;
		if ( pct > 100f ) pct = 100f;
		return (int)MathF.Round( pct );
	}

	private void OpenHub()
	{
		HubPage = HubPageKind.Shop;
		UiSfx.Click();
		Game?.OpenDiverHub();
	}

	private void OpenJournal()
	{
		JournalTab = JournalTabKind.Loot;
		UiSfx.Click();
		Game?.OpenJournal();
	}

	private void SetJournalTab( JournalTabKind tab )
	{
		if ( JournalTab == tab ) return;
		JournalTab = tab;
		UiSfx.Click();
	}

	private void ClickStartDive()
	{
		UiSfx.Click( 1.08f );
		Game?.StartDive();
	}

	private void CloseMenus()
	{
		UiSfx.Click( 0.95f );
		Game?.State.TryCloseMenuToSurface();
	}

	private void Buy( string id )
	{
		if ( Game?.TryBuyUpgrade( id ) == true )
		{
			FlashUpgrade( id );
			UiSfx.Purchase();
			return;
		}

		UiSfx.Deny();
	}

	private void BuyShop( string id )
	{
		if ( Game?.TryBuyShopItem( id ) == true )
		{
			FlashShop( id );
			UiSfx.Purchase();
			return;
		}

		UiSfx.Deny();
	}

	private void SelectShop( string id )
	{
		if ( SelectedShopId == id )
			return;

		SelectedShopId = id;
		UiSfx.Click( 1.02f );
		PulseUi();
	}

	private void SelectUpgrade( string id )
	{
		if ( SelectedUpgradeId == id )
			return;

		SelectedUpgradeId = id;
		UiSfx.Click( 1.02f );
		PulseUi();
	}

	private void SetShopFilter( ShopCategory cat )
	{
		if ( ShopFilter == cat )
			return;

		ShopFilter = cat;
		UiSfx.Click( 1.04f );
		PulseUi();
	}

	private void SetHubPage( HubPageKind page )
	{
		if ( HubPage == page )
			return;

		HubPage = page;
		UiSfx.Click( 1.03f );
		PulseUi();
	}

	private void SellContinue()
	{
		UiSfx.Purchase( 1.1f );
		Game?.SellAndContinue();
	}

	private void ReturnNoSell()
	{
		UiSfx.Click( 0.95f );
		Game?.ReturnWithoutSelling();
	}

	private void DismissFail()
	{
		UiSfx.Click( 0.95f );
		Game?.ContinueAfterFail();
	}

	private bool ShopFlashing( string id ) => id == _shopFlashId && !_shopFlashUntil;
	private bool UpgradeFlashing( string id ) => id == _upgradeFlashId && !_upgradeFlashUntil;

	private void FlashShop( string id )
	{
		_shopFlashId = id;
		_shopFlashUntil = 0.38f;
		SelectedShopId = id;
		PulseUi();
	}

	private void FlashUpgrade( string id )
	{
		_upgradeFlashId = id;
		_upgradeFlashUntil = 0.38f;
		SelectedUpgradeId = id;
		PulseUi();
	}

	private void PulseUi() => _uiPulse++;

	protected override void OnUpdate()
	{
		base.OnUpdate();

		var cleared = false;
		if ( _shopFlashId != "" && _shopFlashUntil )
		{
			_shopFlashId = "";
			cleared = true;
		}

		if ( _upgradeFlashId != "" && _upgradeFlashUntil )
		{
			_upgradeFlashId = "";
			cleared = true;
		}

		if ( cleared )
			PulseUi();
	}

	private static string FormatDuration( float seconds )
	{
		var total = (int)seconds;
		var m = total / 60;
		var s = total % 60;
		return $"{m}:{s:00}";
	}

	private static string RarityClass( CollectibleRarity rarity ) => rarity switch
	{
		CollectibleRarity.Uncommon => "uncommon",
		CollectibleRarity.Rare => "rare",
		CollectibleRarity.Epic => "epic",
		_ => "common"
	};

	protected override int BuildHash() => System.HashCode.Combine(
		System.HashCode.Combine( Phase, CurrentDepth, Deepest, Money ),
		System.HashCode.Combine( OxygenPercent, HealthPercent, BoostPercent, SelectedSlot ),
		System.HashCode.Combine( DayNumber, ClockTime, ObjectiveTitle, Status ),
		System.HashCode.Combine( LogEntries.Count, MapBlips.Count, SummaryEarned, Shells ),
		System.HashCode.Combine( ShopFilter, SelectedShopId, SelectedUpgradeId, HistoryEntries.Count, StockTimer ),
		System.HashCode.Combine( _uiPulse, _shopFlashId, _upgradeFlashId, HubPage, JournalTab )
	);
}
